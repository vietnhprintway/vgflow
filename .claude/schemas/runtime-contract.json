{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vg.runtime-contract",
  "description": "Skill-MD frontmatter runtime_contract block. Parsed by orchestrator at run-start, evaluated at run-complete.",
  "type": "object",
  "properties": {
    "must_write": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": {"type": "string"},
              "content_min_bytes": {"type": "integer", "minimum": 1, "default": 1},
              "glob_min_count": {
                "type": "integer",
                "minimum": 1,
                "description": "Treat path as a glob; require at least N matches."
              },
              "required_unless_flag": {
                "type": "string",
                "description": "Waive this artifact check when the named CLI flag is present."
              },
              "must_be_created_in_run": {
                "type": "boolean",
                "default": false,
                "description": "Require evidence-manifest entry creator_run_id == current run."
              },
              "check_provenance": {
                "type": "boolean",
                "default": false,
                "description": "Also verify source_inputs hashes still match on disk."
              },
              "content_required_sections": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        ]
      },
      "description": "Files that MUST exist + meet content thresholds at run-complete. Path supports ${PHASE_DIR}, ${PHASE_NUMBER}."
    },
    "must_touch_markers": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string"},
              "namespace": {
                "type": "string",
                "default": "shared",
                "description": "Separates markers per-command to avoid conflicts. e.g. 'build/1_parse_args' vs 'blueprint/1_parse_args'"
              },
              "severity": {
                "type": "string",
                "enum": ["block", "warn"],
                "default": "block",
                "description": "OHOK-9 (d): 'block' = missing marker violates contract (default, preserves legacy behavior). 'warn' = missing marker emits contract.marker_warn telemetry event but run continues. Use for cross-cutting optional steps (crossai_review, reflection) that shouldn't hard-stop the pipeline."
              },
              "required_unless_flag": {
                "type": "string",
                "description": "OHOK-9 (d): when this flag appears in run_args (e.g. '--skip-crossai'), the marker check is waived entirely and contract.marker_waived INFO event is emitted. Matches the documented skip semantics of the named step."
              }
            }
          }
        ]
      }
    },
    "must_emit_telemetry": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "required": ["event_type"],
            "properties": {
              "event_type": {"type": "string"},
              "phase": {"type": "string"},
              "min_count": {"type": "integer", "minimum": 1, "default": 1},
              "must_pair_with": {"type": "string"},
              "required_unless_flag": {
                "type": "string",
                "description": "Waive this telemetry requirement when the named CLI flag is present."
              }
            }
          }
        ]
      }
    },
    "must_call": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["function"],
        "properties": {
          "function": {"type": "string"},
          "min_calls": {"type": "integer", "minimum": 1, "default": 1}
        }
      }
    },
    "forbidden_without_override": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^--[a-z0-9-]+(=.*)?$"
      }
    },
    "validators": {
      "type": "object",
      "description": "Lifecycle-aware validator dispatch",
      "properties": {
        "entry": {"type": "array", "items": {"$ref": "#/$defs/validator-ref"}},
        "during": {"type": "array", "items": {"$ref": "#/$defs/validator-ref"}},
        "exit": {"type": "array", "items": {"$ref": "#/$defs/validator-ref"}}
      }
    }
  },
  "$defs": {
    "validator-ref": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {"type": "string"},
        "path": {"type": "string"},
        "args": {"type": "array", "items": {"type": "string"}},
        "trigger": {"type": "string"},
        "blocks_on": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
