64:def _parse_crud_resources(phase_dir: Path) -> set[str]:
65:    """Return resources from CRUD-SURFACES.md that have at least one POST."""
66:    surfaces = phase_dir / "CRUD-SURFACES.md"
67:    if not surfaces.is_file():
68:        # also try CRUD-SURFACES/ split form
69:        sd = phase_dir / "CRUD-SURFACES"
70:        if sd.is_dir():
71:            text = "\n".join(p.read_text(encoding="utf-8", errors="replace")
72:                              for p in sd.glob("*.md"))
73:        else:
74:            return set()
75:    else:
76:        text = surfaces.read_text(encoding="utf-8", errors="replace")
77:
78:    resources: set[str] = set()
79:    # Split text by resource heading; for each block, check POST presence.
80:    last_resource: str | None = None
81:    last_start = 0
82:    chunks: list[tuple[str, str]] = []
83:    for m in RESOURCE_RE.finditer(text):
84:        if last_resource is not None:
85:            chunks.append((last_resource, text[last_start:m.start()]))
86:        last_resource = m.group(1)
87:        last_start = m.end()
88:    if last_resource is not None:
89:        chunks.append((last_resource, text[last_start:]))
90:
91:    for resource, block in chunks:
92:        if CREATE_METHOD_RE.search(block):
93:            resources.add(resource)
94:    return resources
