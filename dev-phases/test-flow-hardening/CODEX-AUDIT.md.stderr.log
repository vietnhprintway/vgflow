5507:182:def _meaningful(value: Any) -> bool:
5508:183:    if value is None:
5509:184:        return False
5510:185:    text = re.sub(r"\s+", " ", str(value).strip()).lower()
5511:186:    return text not in EMPTY_VALUES and not text.startswith(("none", "n/a", "na"))
