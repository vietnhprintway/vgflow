552:def _goal_decision_refs(goal: dict[str, Any], decisions: dict[str, dict[str, str]]) -> list[str]:
553:    """Extract D-XX refs from goal text — match against parsed decisions."""
554:    if not decisions:
555:        return []
556:    haystack = _combined(goal)
557:    found: set[str] = set()
558:    for m in DECISION_REF_RE.finditer(haystack):
559:        d_id = m.group(1)
560:        if d_id in decisions:
561:            found.add(d_id)
562:    return sorted(found)
