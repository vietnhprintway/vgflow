8044:562:    # Batch 41: state observation stubs (empty / error_4xx / loading).
8045:563:    # Scanner now actively probes these states; we emit per-state G-AUTO
8046:564:    # stubs carrying the observed selector so spec generator binds
8047:565:    # expect() to a real selector instead of guessing.
8048:566:    state_obs = scan.get("state_observations") or {}
8049:567:    state_map = [
