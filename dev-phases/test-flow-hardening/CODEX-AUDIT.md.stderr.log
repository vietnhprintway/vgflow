6070:745:def _parse_acceptance_criteria(goal: dict[str, Any]) -> list[str]:
6071:746:    """Batch 36 R3: extract acceptance_criteria from goal frontmatter.
6072:747:
6073:748:    Goal frontmatter may declare criteria in multiple shapes:
6074:749:      - list[str]: ["criterion 1", "criterion 2"]
6075:750:      - dict {"main": [...], "alternate": [...]}
6076:751:      - prose string: "Criteria: A. B. C." (split on sentence punctuation)
6077:752:      - alternate keys: acceptance_criteria, success_criteria, criteria
6078:753:    Returns deduplicated non-empty list.
6079:754:    """
6080:755:    candidates = (
6081:756:        goal.get("acceptance_criteria")
6082:757:        or goal.get("success_criteria")
6083:758:        or goal.get("criteria")
6084:759:        or []
6085:760:    )
6086:761:    items: list[str] = []
6087:762:    if isinstance(candidates, list):
6088:763:        for c in candidates:
6089:764:            if isinstance(c, str) and c.strip():
6090:765:                items.append(c.strip())
6091:766:            elif isinstance(c, dict):
6092:767:                for v in c.values():
6093:768:                    if isinstance(v, str) and v.strip():
6094:769:                        items.append(v.strip())
6095:770:    elif isinstance(candidates, dict):
6096:771:        for v in candidates.values():
6097:772:            if isinstance(v, list):
6098:773:                items.extend(s.strip() for s in v if isinstance(s, str) and s.strip())
6099:774:            elif isinstance(v, str) and v.strip():
6100:775:                items.append(v.strip())
6101:776:    elif isinstance(candidates, str):
6102:777:        for chunk in re.split(r"(?<=[.!?])\s+|\n+", candidates):
6103:778:            chunk = chunk.strip().lstrip("-•").strip()
6104:779:            if chunk:
6105:780:                items.append(chunk)
6106:781:    # Dedup preserving order
6107:782:    seen: set[str] = set()
6108:783:    out: list[str] = []
6109:784:    for it in items:
6110:785:        if it not in seen:
6111:786:            seen.add(it)
6112:787:            out.append(it)
6113:788:    return out
