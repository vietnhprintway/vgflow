42:def view_slug(view_url: str) -> str:
43:    """Convert URL path to a goal-id-safe slug. /admin/topup-requests → admin-topup-requests"""
44:    s = view_url.strip("/").replace("/", "-")
45:    s = re.sub(r":[a-zA-Z_]+", "id", s)
46:    s = re.sub(r"[^a-zA-Z0-9-]", "-", s)
47:    s = re.sub(r"-+", "-", s).strip("-")
48:    return s or "root"
