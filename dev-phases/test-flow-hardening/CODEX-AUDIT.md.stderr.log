7539:57:def load_existing_goals(phase_dir: Path) -> tuple[set[str], dict[str, list[str]]]:
7540:58:    """Return (existing_goal_ids, declared_controls_per_view).
7541:59:    declared_controls_per_view maps view→list of declared filter/sort/page names
7542:60:    so we don't regenerate goals for things blueprint already specified.
7543:61:    """
7544:62:    tg_path = phase_dir / "TEST-GOALS.md"
7545:63:    if not tg_path.is_file():
7546:64:        return set(), {}
7547:65:
7548:66:    text = tg_path.read_text(encoding="utf-8", errors="replace")
7549:67:    ids: set[str] = set()
7550:68:    declared: dict[str, list[str]] = {}
7551:69:
7552:70:    try:
7553:71:        import yaml  # type: ignore
7554:72:    except ImportError:
7555:73:        yaml = None  # type: ignore
7556:74:
7557:75:    if yaml is not None:
7558:76:        blocks: list[str] = []
7559:77:        cur: list[str] = []
7560:78:        in_block = False
7561:79:        for line in text.splitlines():
7562:80:            if line.strip() == "---":
7563:81:                if in_block:
7564:82:                    blocks.append("\n".join(cur))
7565:83:                    cur = []
7566:84:                    in_block = False
7567:85:                else:
7568:86:                    in_block = True
7569:87:                continue
7570:88:            if in_block:
7571:89:                cur.append(line)
7572:90:        for blob in blocks:
7573:91:            try:
7574:92:                data = yaml.safe_load(blob) or {}
7575:93:            except Exception:
7576:94:                continue
7577:95:            if not isinstance(data, dict):
7578:96:                continue
7579:97:            gid = str(data.get("id", ""))
7580:98:            if gid:
7581:99:                ids.add(gid)
7582:100:            ic = data.get("interactive_controls") or {}
7583:101:            view_key = str(data.get("maps_to_view") or data.get("view") or "")
7584:102:            if view_key and isinstance(ic, dict):
7585:103:                names = []
7586:104:                for f in ic.get("filters") or []:
7587:105:                    if isinstance(f, dict) and "name" in f:
7588:106:                        names.append(f"filter:{f['name']}")
7589:107:                    elif isinstance(f, str):
7590:108:                        names.append(f"filter:{f}")
7591:109:                if ic.get("pagination"):
7592:110:                    names.append("pagination")
7593:111:                if ic.get("sort"):
7594:112:                    names.append("sort")
7595:113:                declared.setdefault(view_key, []).extend(names)
7596:114:
7597:115:    if not ids:
7598:116:        for m in re.finditer(r"\bG-[A-Z0-9-]+\b", text):
7599:117:            ids.add(m.group(0))
7600:118:
7601:119:    return ids, declared
