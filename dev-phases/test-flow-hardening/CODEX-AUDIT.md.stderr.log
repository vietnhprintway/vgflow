5623:298:def _extract_endpoints(goal: dict[str, Any]) -> list[dict[str, str]]:
5624:299:    seen: set[tuple[str, str]] = set()
5625:300:    endpoints: list[dict[str, str]] = []
5626:301:    for method, path in ENDPOINT_RE.findall(_combined(goal)):
5627:302:        key = (method.upper(), path)
5628:303:        if key in seen:
5629:304:            continue
5630:305:        seen.add(key)
5631:306:        endpoints.append({"method": method.upper(), "path": path})
5632:307:    return endpoints
