627:def _derive_edge_cases(goal: dict[str, Any]) -> list[dict[str, Any]]:
628:    """Batch 37 F3: emit first-class edge_cases[] per goal.
629:
630:    Defaults cover boundary + empty + unicode + large-payload variants
631:    every spec must include. Spec generator emits test.each([variants])
632:    where variants come from this list.
633:    """
634:    gtype = (goal.get("goal_type") or "").lower()
635:    cases: list[dict[str, Any]] = [
636:        {
637:            "kind": "boundary",
638:            "label": "min boundary value",
639:            "input_hint": "use lowest allowed value (0, '', 1 char, min date)",
640:            "expected": "accept or reject per spec; no crash",
641:        },
642:        {
643:            "kind": "boundary",
644:            "label": "max boundary value",
645:            "input_hint": "use highest allowed (max int, max length, future date)",
646:            "expected": "accept or reject per spec; no truncation silently",
647:        },
648:        {
649:            "kind": "empty_string",
650:            "label": "empty string for non-required field",
651:            "input_hint": "submit empty for optional fields",
652:            "expected": "no validation error if optional",
653:        },
654:        {
655:            "kind": "unicode_special",
656:            "label": "unicode + emoji + RTL + special chars",
657:            "input_hint": "包含中文 🎉 العربية ' \" < > & --",
658:            "expected": "stored/displayed unchanged; no XSS/SQL injection",
659:        },
660:    ]
661:    if gtype in {"create-only", "update-only", "create", "update", "mutation"} or not gtype:
662:        cases.append({
663:            "kind": "large_payload",
664:            "label": "payload at limit",
665:            "input_hint": "field at max allowed size + many array items",
666:            "expected": "accept or 413/422 per contract; no timeout",
667:        })
668:    if gtype == "read-only":
669:        cases.extend([
670:            {
671:                "kind": "filter_combination",
672:                "label": "multiple filters combined",
673:                "input_hint": "apply >=2 filters simultaneously",
674:                "expected": "AND semantics; URL reflects all; reset clears all",
675:            },
676:            {
677:                "kind": "pagination_edge",
678:                "label": "out-of-range page",
679:                "input_hint": "?page=99999",
680:                "expected": "clamp to last page OR empty state; no 500",
681:            },
682:        ])
683:    return cases
