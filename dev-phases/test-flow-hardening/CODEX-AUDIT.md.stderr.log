6132:807:def _step_description(stage: str, goal: dict[str, Any], endpoint: dict[str, str] | None) -> str:
6133:808:    """G3 Batch 3: build action description from endpoint binding when available.
6134:809:
6135:810:    When endpoint is bound, embed method + path directly in the description so
6136:811:    codegen has concrete references instead of generic template strings.
6137:812:    Falls back to _DEFAULT_DESCRIPTIONS[stage] when endpoint is absent.
6138:813:    """
6139:814:    if endpoint and endpoint.get("method") and endpoint.get("path"):
6140:815:        method, path = endpoint["method"], endpoint["path"]
6141:816:        if stage == "create":
6142:817:            return f"{method} {path} with sample payload from API-CONTRACTS; assert response status + body."
6143:818:        if stage == "update":
6144:819:            return f"{method} {path} for the created entity; assert update applied."
6145:820:        if stage == "delete":
6146:821:            return f"{method} {path}; assert 204/200 and resource gone."
6147:822:        if stage.startswith("read_"):
6148:823:            state = stage.replace("read_", "").replace("_", " ")
6149:824:            return f"GET {path}; assert {state} state per persistence_check."
6150:825:    return _DEFAULT_DESCRIPTIONS.get(stage, f"Execute {stage} stage.")
