4932:127:  #                    click → detail loads → edit → cascade check → delete →
4933:128:  #                    archive check. Dispatches FEATURE_CHAIN_STAGES in
4934:129:  #                    generate-lifecycle-specs.py: read_before, create,
4935:130:  #                    read_after_create, visibility_check, interaction_chain,
4936:131:  #                    update, read_after_update, cascade_check, delete,
4937:132:  #                    read_after_delete, archive_visibility_check.)
4938:133:  # post_create_cascade: alias for feature_chain (B62)
4939:134:
4940:135:# ─────────────────────────────────────────────────────────────────────
4941:136:# B62: Feature-chain frontmatter (REQUIRED when goal_class=feature_chain)
4942:137:# ─────────────────────────────────────────────────────────────────────
4943:138:# Closed-loop modeling. Captures inverse-dependency edges + downstream
4944:139:# state propagation. Validated by verify-feature-chain-coverage.py +
4945:140:# verify-enables-deps-symmetry.py (B62-pre).
4946:141:
4947:142:enables:
4948:143:  # OPTIONAL but recommended for mutation/crud-roundtrip/feature_chain.
4949:144:  # List of G-XX goal ids that BECOME testable AFTER this goal succeeds.
4950:145:  # Forward-edge declaration. Must mirror backward Dependencies[] on
4951:146:  # target goal (validator: verify-enables-deps-symmetry.py).
4952:147:  # Example: G-01 creates a site → enables: [G-04 (dashboard visible),
4953:148:  #                                          G-07 (audit log entry)]
4954:149:  # Truth-source rule: Dependencies[] is canonical; enables[] is a
4955:150:  # readability + coverage hint. Both must agree or symmetry gate fires.
4956:151:  - G-04
4957:152:  - G-07
4958:153:
4959:154:chain_consumes_state:
4960:155:  # OPTIONAL. Named state precondition this goal expects to exist.
4961:156:  # Examples: "customer_exists", "tenant_authenticated", "site_in_active_pool".
4962:157:  # Used by codegen subagent to wire beforeEach fixtures matching the
4963:158:  # chain_produces_state of upstream goals.
4964:159:  # Namespaced (B62 audit ID-11) to avoid collision with potential
4965:160:  # state-machine `produces_state` / `consumes_state` fields in FLOW-SPEC.
4966:161:  customer_exists: true
4967:162:
4968:163:chain_produces_state:
4969:164:  # OPTIONAL. Named state postcondition this goal establishes.
4970:165:  # Examples: "invoice_persisted", "site_in_active_pool", "user_logged_in".
4971:166:  # Downstream goals reference this via chain_consumes_state.
4972:167:  invoice_persisted: true
4973:168:
4974:169:chain_steps:
4975:170:  # REQUIRED when goal_class=feature_chain. List of explicit chain steps.
4976:171:  # MIN 8 entries (B62 + audit ID-3 anti-cheat). MIN 1 entry must have
4977:172:  # target_view_class NOT in {source_view, source_view_modal,
4978:173:  # source_view_form} — chain MUST traverse to a structurally different view.
4979:174:  # MIN 2 entries must have non-empty downstream_effects[] — chain MUST
4980:175:  # observe at least 2 downstream consequences, not just rename existing
4981:176:  # shallow mutation steps.
4982:177:  #
4983:178:  # target_view_class enum (B62 + audit ID-6 view-rename-stable identity):
4984:179:  #   - source_view: the originating view (e.g. /sites)
4985:180:  #   - source_view_modal: modal/drawer on source view
4986:181:  #   - source_view_form: dedicated form route for the source view
4987:182:  #   - primary_list: list view for the resource type (NOT source_view)
4988:183:  #   - dashboard_summary: aggregate dashboard cards / metrics
4989:184:  #   - audit_log: change-log / activity feed view
4990:185:  #   - sibling_list: list view for a related resource type
4991:186:  #   - notification_feed: in-app notification surface
4992:187:  #   - report_view: detailed report / drill-down
4993:188:  #
4994:189:  # Goal-id derived from (entity_canonical_id + target_view_class), NOT raw
4995:190:  # view path → stable across view renames.
4996:191:  - step_id: S1
4997:192:    description: User authenticates and navigates to source view
4998:193:    target_view_class: source_view
4999:194:    expected_state: list_loaded_with_baseline_items
5000:195:    downstream_effects: []
5001:196:  - step_id: S2
5002:197:    description: User clicks Create → form opens
5003:198:    target_view_class: source_view_modal
5004:199:    expected_state: create_form_visible
5005:200:    downstream_effects: []
5006:201:  - step_id: S3
5007:202:    description: User fills form + submits, server returns 201
5008:203:    target_view_class: source_view_modal
5009:204:    expected_state: form_closes_toast_visible
5010:205:    downstream_effects:
5011:206:      - "row_count[/sites] increments by 1"
5012:207:      - "audit_log entry appended"
5013:208:  - step_id: S4
5014:209:    description: Navigate to dashboard → newly created entity visible
5015:210:    target_view_class: dashboard_summary
5016:211:    expected_state: entity_in_active_count
5017:212:    downstream_effects:
5018:213:      - "dashboard counter +1"
5019:214:  - step_id: S5
5020:215:    description: Click entity card → detail view loads
5021:216:    target_view_class: sibling_list
5022:217:    expected_state: detail_route_resolved
5023:218:    downstream_effects: []
5024:219:  - step_id: S6
5025:220:    description: Edit entity → status flips
5026:221:    target_view_class: source_view
5027:222:    expected_state: entity_status_updated
5028:223:    downstream_effects:
5029:224:      - "status badge updated"
5030:225:  - step_id: S7
5031:226:    description: Delete entity → confirm modal → confirmed
5032:227:    target_view_class: source_view_modal
5033:228:    expected_state: entity_deleted
5034:229:    downstream_effects:
5035:230:      - "row_count[/sites] decrements by 1"
5036:231:  - step_id: S8
5037:232:    description: Navigate to archive list → entity searchable but not in active
5038:233:    target_view_class: audit_log
5039:234:    expected_state: entity_in_archive_only
5040:235:    downstream_effects:
5041:236:      - "archive_count +1"
5042:237:      - "active_count -1"
5043:238:
5044:239:goal_grounding: api | flow | presentation
5045:240:  # REQUIRED post-2026-05-01 (PR-F). Drives /vg:test verification strategy
5046:241:  # dispatch — different grounding = different proof shape:
5047:242:  #
5048:243:  # `api`            (B2B billing/orders/payments/wallet — most goals here)
5049:244:  #   Anchor: API-CONTRACTS endpoint shape + business invariants.
5050:245:  #   Verification: recipe_executor against openapi.json + lifecycle.post_state.
5051:246:  #   UI = thin client, may have extras/gaps but NOT the source of truth.
5052:247:  #
5053:248:  # `flow`           (onboarding wizard, KYC, password recovery, multi-step)
5054:249:  #   Anchor: FLOW-SPEC.md state-machine + checkpoint transitions.
5055:250:  #   Verification: flow-runner walks declarative steps with assertions
5056:251:  #   per checkpoint. Multiple API calls per step OK.
5057:252:  #   API endpoints fragmented; flow itself IS the business semantics.
5058:253:  #
5059:254:  # `presentation`   (dashboards, charts, pricing previews, reports)
5060:255:  #   Anchor: API raw data + UI display computation (totals, percentages,
5061:256:  #   formatted dates).
5062:257:  #   Verification: screenshot diff + computation check (verify
5063:258:  #   formula: display_total = sum(items) × (1 + tax_rate)).
5064:259:  #   UI legitimately has "extra fields" derived from API data — they're
5065:260:  #   not phantom.
5066:261:  #
5067:262:  # Default if unspecified: infer from surface (api/data/integration → api;
5068:263:  # ui + multi-step flow_ref → flow; ui + chart/dashboard/preview → presentation).
5069:264:  # Validator (verify-goal-grounding) warns on unspecified for new phases.
5070:265:
5071:266:# ─────────────────────────────────────────────────────────────────────
5072:267:# v2.5 Phase B enrichment — Security + Performance
5073:268:# ─────────────────────────────────────────────────────────────────────
5074:269:# Optional but REQUIRED for critical_goal_domains (auth/payment/billing).
5075:270:# Severity logic in verify-goal-security.py:
5076:271:#   - critical_goal_domain + section empty → HARD BLOCK
5077:272:#   - mutation endpoint + csrf OR rate_limit empty → HARD BLOCK
5078:273:#   - read-only GET + section empty → WARN + override debt
5079:274:
5080:275:security_checks:
5081:276:  # OWASP Top 10 2021 subset relevant cho endpoint (không phải hết 10).
5082:277:  # Format: "AXX:name: justification" — validator cross-references với
5083:278:  # API-CONTRACTS schema để auto-tick (vd Zod schema → A03 injection OK).
5084:279:  owasp_top10_2021:
5085:280:    - "A01:Broken-Access-Control: owner check on update via ownerId middleware"
5086:281:    - "A03:Injection: Zod schema parameterized query via Prisma"
5087:282:    - "A05:Security-Misconfig: CSP default-src 'self' inherits project baseline"
5088:283:    # Relevant categories (add as applicable):
5089:284:    # - "A02:Cryptographic-Failures: bcrypt work factor 12, no SHA1"
5090:285:    # - "A04:Insecure-Design: rate-limit + step-up auth cho destructive op"
5091:286:    # - "A06:Vulnerable-Components: lockfile integrity + CVE scan CI"
5092:287:    # - "A07:Identification-Auth: session fixation prevented + logout server-side"
5093:288:    # - "A08:Software-Integrity: signed commits + dependency provenance"
5094:289:    # - "A09:Logging-Monitoring: audit log with user_id + IP + UA"
5095:290:    # - "A10:SSRF: URL whitelist, block 169.254/10/172.16/192.168"
5096:291:
5097:292:  # ASVS Level 2 controls (granular validation beyond OWASP Top 10).
5098:293:  # Free-form string citing ASVS ID + justification.
5099:294:  asvs_level2:
5100:295:    - "V5.1.1: input validation per field via Zod schema"
5101:296:    - "V5.3.3: output encoding context-aware (React auto-escape + CSP)"
5102:297:    # - "V7.1.1: session generation cryptographically strong"
5103:298:    # - "V9.1.2: TLS 1.2+ enforced cho all endpoints"
5104:299:
5105:300:  # Rate limiting: per-user + per-IP. Required cho mutation endpoints.
5106:301:  # Empty → HARD BLOCK cho mutation. Format: free-form description.
5107:302:  rate_limit: "10/min per user, 30/min per IP, 5/min anonymous"
5108:303:
5109:304:  # CSRF protection mechanism. Required cho state-changing endpoints
5110:305:  # (POST/PUT/PATCH/DELETE) nếu accept cookie auth. Empty → HARD BLOCK
5111:306:  # cho mutation + cookie auth (Bearer-only API có thể để trống).
5112:307:  csrf: "SameSite=Strict session cookie + double-submit token verify"
5113:308:
5114:309:  # XSS protection — framework default + explicit overrides.
5115:310:  xss_protection: "React auto-escape + CSP strict default-src 'self'"
5116:311:
5117:312:  # Auth model classification (cross-ref với API-CONTRACTS Block 1 auth line).
5118:313:  # Values: public | authenticated | role:<name> | owner_only | multi
5119:314:  auth_model: "owner_only"
5120:315:
5121:316:  # PII fields (if endpoint accepts/returns PII). Encryption + masking policy.
5122:317:  pii_fields: ["email", "phone", "dob"]
5123:318:
5124:319:# ─────────────────────────────────────────────────────────────────────
5125:320:# v2.8.4 Phase J enrichment — Interactive Controls (URL state)
5126:321:# ─────────────────────────────────────────────────────────────────────
5127:322:# REQUIRED for goals with surface=ui AND main_steps mention list/table/grid
5128:323:# AND any of {filter, sort, paginate, search}. Empty → BLOCK at /vg:review
5129:324:# phase 2.7 (verify-url-state-sync.py). Phase 0-13 grandfather: WARN only.
5130:325:#
5131:326:# Convention default (locked in FOUNDATION §9 + vg.config.md):
5132:327:#   - list_view_state_in_url: true        (URL params reflect filter/sort/page state)
5133:328:#   - url_param_naming: kebab             (status, sort-by, page-size — config override)
5134:329:#   - array_format: csv                   (?tags=a,b,c — alternative: repeat-key)
5135:330:#   - debounce_search_ms: 300             (search input debounce default)
5136:331:#
5137:332:# Override semantics:
5138:333:#   url_sync: false → declare local-only state (e.g. modal-internal filter,
5139:334:#     transient sort that resets on close). REQUIRES `url_sync_waive_reason`
5140:335:#     to log soft debt + survive validator.
5141:336:
5142:337:interactive_controls:
5143:338:  # Master flag — defaults true. Set false ONLY for local/transient state.
5144:339:  url_sync: true
5145:340:  url_sync_waive_reason: ""             # required when url_sync: false
5146:341:
5147:342:  # Filters: dropdown / chip / multi-select. Each entry = 1 user-controllable
5148:343:  # filter. Validator clicks each value → asserts URL + data subset.
5149:344:  filters:
5150:345:    - name: status                      # filter id (matches data attr or test id)
5151:346:      values: [active, paused, completed, archived]
5152:347:      url_param: status                 # default: same as name (apply naming convention)
5153:348:      assertion: "rows.status all match selected value; URL ?status={value} synced; reload preserves"
5154:349:    # Multi-value example (array filter):
5155:350:    # - name: tags
5156:351:    #   values: [premium, mobile, video]
5157:352:    #   url_param: tags
5158:353:    #   array: true                     # → ?tags=premium,mobile (csv) or ?tags=premium&tags=mobile
5159:354:    #   assertion: "rows have ALL selected tags; URL contains all values"
5160:355:
5161:356:  # Pagination: required if list expects > page_size rows.
5162:357:  # UI MANDATORY pattern (v2.8.4 Phase J — locked convention):
5163:358:  #   << < {N-5} {N-4} … {N} … {N+4} {N+5} > >>
5164:359:  # which means: first-page (<<), prev (<), numbered window of current ±5,
5165:360:  # next (>), last-page (>>). Plus visible "Showing X-Y of Z records" /
5166:361:  # "Page N of M". Plain "prev / next + page-number-display" is BANNED —
5167:362:  # it requires too many clicks to reach a known target page.
5168:363:  pagination:
5169:364:    page_size: 20                       # rows per page (validator inspects total ÷ size)
5170:365:    url_param_page: page                # ?page=2
5171:366:    url_param_size: pageSize            # ?pageSize=50 (optional — only if user-controllable)
5172:367:    ui_pattern: "first-prev-numbered-window-next-last"  # MANDATORY value
5173:368:    window_radius: 5                    # numbered buttons = current ±5 (locked default)
5174:369:    show_total_records: true            # MANDATORY — "Showing X-Y of Z"
5175:370:    show_total_pages: true              # MANDATORY — "Page N of M"
5176:371:    assertion: "page2 first_row_id ≠ page1 first_row_id; total count consistent across pages; URL ?page=N synced; reload page=N preserves; UI shows << < numbered-window > >> + Showing X-Y of Z + Page N of M"
5177:372:
5178:373:  # Search: text input that filters list. Required if list has search box.
5179:374:  search:
5180:375:    field: name                         # which entity field is searched (or "fulltext")
5181:376:    url_param: q                        # ?q=xyz
5182:377:    debounce_ms: 300                    # framework debounce — must match config default
5183:378:    assertion: "type query → debounce wait → URL ?q={query} synced; result rows all contain query (case-insensitive); empty query clears URL param"
5184:379:
5185:380:  # Sort: column header click toggles sort. Required if table has sortable columns.
5186:381:  sort:
5187:382:    columns: [created_at, name, status, updated_at]
5188:383:    url_param_field: sort               # ?sort=created_at
5189:384:    url_param_dir: dir                  # ?dir=desc
5190:385:    default: created_at desc            # initial state when no URL params
5191:386:    assertion: "click header toggles asc↔desc; URL ?sort={col}&dir={asc|desc} synced; ORDER BY assertion holds in data; reload preserves"
5192:387:
5193:388:# Performance budget — Required cho mutation + list endpoints.
5194:389:# Read-only single-record GET có thể để trống (default project baseline).
5195:390:perf_budget:
5196:391:  p50_ms: 80                    # median response time target
5197:392:  p95_ms: 250                   # 95th percentile target (alarm threshold)
5198:393:  p99_ms: 500                   # 99th percentile (outlier floor)
5199:394:  n_plus_one_max: 3             # max DB round-trips per request
5200:395:  bundle_kb_fe_route: 250       # FE route-split bundle size (only applicable cho ui surface)
5201:396:  cache_strategy: "Redis 5min TTL + tag-invalidate on mutation"
5202:397:
5203:398:# ─────────────────────────────────────────────────────────────────────
5204:399:# v2.21 enrichment — Adversarial / cheat-path coverage
5205:400:# ─────────────────────────────────────────────────────────────────────
5206:401:# Declarative threat model per goal. Required cho mutation/auth/payment
5207:402:# domains; warn-only cho read-only/UI presentation goals.
5208:403:#
5209:404:# verify-adversarial-coverage.py reads this block + emits WARN nếu thiếu
5210:405:# cho domain bắt buộc. User opt-out qua `--skip-adversarial=<reason>` →
5211:406:# OVERRIDE-DEBT critical entry → reviewer triage tại /vg:accept.
5212:407:#
5213:408:# Threat taxonomy (v1):
5214:409:#   auth_bypass        — other-tenant ID, expired session, role downgrade
5215:410:#   injection          — SQL / XSS / SSTI / cmd-injection payloads
5216:411:#   race               — concurrent submit, double-spend, TOCTOU
5217:412:#   duplicate_submit   — replay protection, idempotency-key
5218:413:#   boundary_overflow  — int overflow, length limit, file size
5219:414:#   role_escalation    — privilege jump, IDOR
5220:415:#   csrf_replay        — cross-site request without token
5221:416:
5222:417:adversarial_scope:
5223:418:  threats: [auth_bypass, injection, duplicate_submit]
5224:419:  per_threat:
5225:420:    auth_bypass:
5226:421:      paths: ["other-tenant-id", "different-role", "expired-session"]
5227:422:      assertions:
5228:423:        - "status: 403 OR 404"
5229:424:        - "no PII leak in error body"
5230:425:    injection:
5231:426:      payloads: ["${SQLI_PAYLOAD}", "${XSS_PAYLOAD}", "${SSTI_PAYLOAD}"]
5232:427:      assertions:
5233:428:        - "no payload execution (response echo escaped)"
5234:429:        - "no DB error 500 with SQL fragment in body"
5235:430:    duplicate_submit:
5236:431:      method: "replay POST within 100ms"
5237:432:      assertions:
5238:433:        - "second response: 409 OR 200-with-existing-id (idempotent)"
5239:434:        - "exactly 1 row created (verify via DB)"
5240:435:  # Empty `threats: []` is an EXPLICIT decision — AI must include
5241:436:  # comment why the goal is low-risk (e.g., "read-only GET, no PII").
5242:437:
5243:438:# Evidence fields (populated by /vg:test, /vg:review)
5244:439:status: NOT_SCANNED | READY | BLOCKED | UNREACHABLE | FAILED | DEFERRED | INFRA_PENDING | MANUAL
5245:440:evidence_file: apps/web/e2e/xxx.spec.ts:42 | apps/api/test/xxx.test.ts
5246:441:adversarial_evidence:                            # populated by /vg:test
5247:442:  - threat: auth_bypass
5248:443:    file: apps/web/e2e/G-01.adversarial.auth_bypass.spec.ts
5249:444:    status: PASS
5250:445:---
5251:446:
5252:447:## Prose description (optional)
5253:448:
5254:449:Narrative context for humans reviewing goal. Not parsed by validators.
5255:450:```
