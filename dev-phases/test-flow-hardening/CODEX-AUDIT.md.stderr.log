182:def _meaningful(value: Any) -> bool:
183:    if value is None:
184:        return False
185:    text = re.sub(r"\s+", " ", str(value).strip()).lower()
186:    return text not in EMPTY_VALUES and not text.startswith(("none", "n/a", "na"))
