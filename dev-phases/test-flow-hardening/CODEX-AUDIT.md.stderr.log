153:def _validate_chain(goal: dict) -> list[str]:
154:    """Return list of validation error messages (empty if PASS)."""
155:    errors: list[str] = []
156:    gid = goal["id"]
157:    steps = goal["chain_steps"]
158:    if len(steps) < MIN_CHAIN_STEPS:
159:        errors.append(
160:            f"{gid}: chain_steps len {len(steps)} < {MIN_CHAIN_STEPS} (audit ID-3 threshold)"
161:        )
162:    # distinct expected_state
163:    expected_states = [s["expected_state"] for s in steps if s["expected_state"]]
164:    if len(expected_states) != len(set(expected_states)):
165:        errors.append(
166:            f"{gid}: duplicate expected_state across chain_steps (each MUST be distinct)"
167:        )
168:    # at least 1 step traverses out of source view family
169:    target_classes = [s["target_view_class"] for s in steps]
170:    out_of_source = [tc for tc in target_classes if tc and tc not in SOURCE_VIEW_CLASSES]
171:    if not out_of_source:
172:        errors.append(
173:            f"{gid}: chain stays in source view family; need ≥1 step with "
174:            f"target_view_class NOT in {sorted(SOURCE_VIEW_CLASSES)}"
175:        )
176:    # at least 2 steps with non-empty downstream_effects
177:    with_effects = [s for s in steps if s["downstream_effects"]]
178:    if len(with_effects) < MIN_STEPS_WITH_DOWNSTREAM_EFFECTS:
179:        errors.append(
180:            f"{gid}: only {len(with_effects)} step(s) have downstream_effects; "
181:            f"need ≥{MIN_STEPS_WITH_DOWNSTREAM_EFFECTS} (audit ID-3 anti-cheat)"
182:        )
183:    return errors
