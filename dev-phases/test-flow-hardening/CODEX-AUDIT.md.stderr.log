8022:540:            "title": f"Accessibility: {rule} on {view} — WCAG {finding.get('wcag', '?')} ({severity})",
8023:541:            "priority": "important" if severity == "critical" else "nice-to-have",
8024:542:            "surface": "ui",
8025:543:            "source": "review.runtime_discovery",
8026:544:            "evidence": {
8027:545:                "view": view,
8028:546:                "axe_rule": rule,
8029:547:                "wcag": finding.get("wcag"),
8030:548:                "severity": severity,
8031:549:                "selector": selector,
8032:550:                "description": finding.get("description"),
8033:551:                "help_url": finding.get("help_url"),
8034:552:            },
8035:553:            "trigger": f"Page loaded on {view}",
8036:554:            "main_steps": [
8037:555:                {"S1": f"Navigate to {view}"},
8038:556:                {"S2": f"Run axe-core scan with WCAG 2A+2AA rules"},
8039:557:                {"S3": f"Assert NO violation of rule '{rule}' on selector '{selector}'"},
8040:558:                {"S4": "Manual review if violation re-appears: fix per help_url"},
8041:559:            ],
8042:560:        })
