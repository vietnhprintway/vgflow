5600:275:def _needs_lifecycle(goal: dict[str, Any]) -> bool:
5601:276:    goal_type = str(goal.get("goal_type") or "").lower()
5602:277:    goal_class = str(goal.get("goal_class") or "").lower()
5603:278:    if goal_type in {"mutation", "multi-actor", "workflow"}:
5604:279:        return True
5605:280:    # G14 Batch 2: read-only goals get lifecycle too (single read_before stage).
5606:281:    if goal_type == "read-only":
5607:282:        return True
5608:283:    if goal_class in {"mutation", "crud", "workflow", "multi-actor"}:
5609:284:        return True
5610:285:    if _meaningful(goal.get("mutation_evidence")) or _meaningful(goal.get("persistence_check")):
5611:286:        return True
5612:287:    return bool(SIDE_EFFECT_WORD_RE.search(_combined(goal)))
