686:def _derive_negative_specs(goal: dict[str, Any]) -> list[dict[str, Any]]:
687:    """Batch 37 F4: emit first-class negative_specs[] per goal.
688:
689:    Negative paths previously prompt-only. Codegen told 'never invent
690:    assertions beyond TEST-GOALS' → no 401/403/422 coverage.
691:    """
692:    gtype = (goal.get("goal_type") or "").lower()
693:    negs: list[dict[str, Any]] = [
694:        {
695:            "kind": "unauthorized_401",
696:            "label": "missing/expired auth token",
697:            "expected_status": 401,
698:            "setup": "clear cookies/Authorization header before request",
699:            "assert": "response.status == 401 with envelope {ok:false, error:{code:'UNAUTHORIZED'}}",
700:        },
701:        {
702:            "kind": "forbidden_403",
703:            "label": "wrong role / lacks permission",
704:            "expected_status": 403,
705:            "setup": "login as role without permission to this action",
706:            "assert": "response.status == 403; UI hides/disables action; no state change",
707:        },
708:    ]
709:    if gtype in {"create-only", "update-only", "mutation", "create", "update"} or not gtype:
710:        negs.extend([
711:            {
712:                "kind": "validation_422",
713:                "label": "invalid/missing required field",
714:                "expected_status": 422,
715:                "setup": "submit payload with required field absent or malformed",
716:                "assert": "422 with envelope {error:{code:'VALIDATION_ERROR', fields:[...]}}; no DB write",
717:            },
718:            {
719:                "kind": "not_found_404",
720:                "label": "operate on non-existent resource",
721:                "expected_status": 404,
722:                "setup": "use id that doesn't exist or was deleted",
723:                "assert": "404; no partial mutation; envelope error.code='NOT_FOUND'",
724:            },
725:        ])
726:    if gtype == "read-only":
727:        negs.append({
728:            "kind": "not_found_404",
729:            "label": "GET non-existent resource",
730:            "expected_status": 404,
731:            "setup": "navigate to URL with id that doesn't exist",
732:            "assert": "404 page or empty state; no white-screen",
733:        })
734:    negs.append({
735:        "kind": "rate_limit_429",
736:        "label": "burst traffic triggers rate limit",
737:        "expected_status": 429,
738:        "setup": "issue rapid repeated requests beyond burst limit",
739:        "assert": "429 with Retry-After header; subsequent OK after delay",
740:        "advisory": True,
741:    })
742:    return negs
