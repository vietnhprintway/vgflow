606:def _read_before_action(goal: dict[str, Any]) -> str:
607:    """Build read_before action description. Special-case read-only goals (G14)."""
608:    gtype = (goal.get("goal_type") or "").strip().lower()
609:    if gtype == "read-only":
610:        pc = goal.get("persistence_check") or ""
611:        return f"Execute read endpoint and assert filter/result semantics: {pc}"
612:    return "Read baseline via read endpoint or DB query from TEST-GOALS; assert target entity absent or initial state matches precondition."
