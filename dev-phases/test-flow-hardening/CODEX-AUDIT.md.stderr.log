5514:189:def _field(body: str, name: str) -> str:
5515:190:    patterns = (
5516:191:        rf"^\*\*{re.escape(name)}:\*\*\s*(.+?)(?=^\*\*|\n##|\n#\s+G-|\Z)",
5517:192:        rf"^{re.escape(name)}:\s*(.+?)(?=^\w[\w -]*:|\n##|\n#\s+G-|\Z)",
5518:193:        rf"^###\s+{re.escape(name)}\s*\n(.+?)(?=^###\s+|\n##\s+|\n#\s+|\Z)",
5519:194:    )
5520:195:    for pattern in patterns:
5521:196:        match = re.search(pattern, body, re.MULTILINE | re.DOTALL | re.IGNORECASE)
5522:197:        if match:
5523:198:            return match.group(1).strip()
5524:199:    return ""
