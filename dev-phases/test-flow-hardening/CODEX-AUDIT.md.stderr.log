7392:174:    phase_dir = _find_phase_dir(args.phase, args.phase_dir)
7393:175:    lifecycle_path = phase_dir / "LIFECYCLE-SPECS.json"
7394:176:    if not lifecycle_path.is_file():
7395:177:        print(f"⛔ Batch 48 F7: LIFECYCLE-SPECS.json missing at {lifecycle_path}", file=sys.stderr)
7396:178:        print(f"   Run /vg:test-spec ${args.phase} first (deep-specs gen).", file=sys.stderr)
