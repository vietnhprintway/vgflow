5952:627:def _derive_edge_cases(goal: dict[str, Any]) -> list[dict[str, Any]]:
5953:628:    """Batch 37 F3: emit first-class edge_cases[] per goal.
5954:629:
5955:630:    Defaults cover boundary + empty + unicode + large-payload variants
5956:631:    every spec must include. Spec generator emits test.each([variants])
5957:632:    where variants come from this list.
5958:633:    """
5959:634:    gtype = (goal.get("goal_type") or "").lower()
5960:635:    cases: list[dict[str, Any]] = [
5961:636:        {
5962:637:            "kind": "boundary",
5963:638:            "label": "min boundary value",
5964:639:            "input_hint": "use lowest allowed value (0, '', 1 char, min date)",
5965:640:            "expected": "accept or reject per spec; no crash",
5966:641:        },
5967:642:        {
5968:643:            "kind": "boundary",
5969:644:            "label": "max boundary value",
5970:645:            "input_hint": "use highest allowed (max int, max length, future date)",
5971:646:            "expected": "accept or reject per spec; no truncation silently",
5972:647:        },
5973:648:        {
5974:649:            "kind": "empty_string",
5975:650:            "label": "empty string for non-required field",
5976:651:            "input_hint": "submit empty for optional fields",
5977:652:            "expected": "no validation error if optional",
5978:653:        },
5979:654:        {
5980:655:            "kind": "unicode_special",
5981:656:            "label": "unicode + emoji + RTL + special chars",
5982:657:            "input_hint": "包含中文 🎉 العربية ' \" < > & --",
5983:658:            "expected": "stored/displayed unchanged; no XSS/SQL injection",
5984:659:        },
5985:660:    ]
5986:661:    if gtype in {"create-only", "update-only", "create", "update", "mutation"} or not gtype:
5987:662:        cases.append({
5988:663:            "kind": "large_payload",
5989:664:            "label": "payload at limit",
5990:665:            "input_hint": "field at max allowed size + many array items",
5991:666:            "expected": "accept or 413/422 per contract; no timeout",
5992:667:        })
5993:668:    if gtype == "read-only":
5994:669:        cases.extend([
5995:670:            {
5996:671:                "kind": "filter_combination",
5997:672:                "label": "multiple filters combined",
5998:673:                "input_hint": "apply >=2 filters simultaneously",
5999:674:                "expected": "AND semantics; URL reflects all; reset clears all",
6000:675:            },
6001:676:            {
6002:677:                "kind": "pagination_edge",
6003:678:                "label": "out-of-range page",
6004:679:                "input_hint": "?page=99999",
6005:680:                "expected": "clamp to last page OR empty state; no 500",
6006:681:            },
6007:682:        ])
6008:683:    return cases
