6693:137:def _check_goal_parity(phase_dir: Path) -> tuple[bool, list[str]]:
6694:138:    """Returns (ok, omitted_goal_ids). Goals are 'automatable' unless skipped."""
6695:139:    import re
6696:140:    tg_path = phase_dir / "TEST-GOALS.md"
6697:141:    ls_path = phase_dir / "LIFECYCLE-SPECS.json"
6698:142:    if not tg_path.is_file() or not ls_path.is_file():
6699:143:        return True, []  # nothing to check
6700:144:    automatable_goals: set[str] = set()
6701:145:    body = tg_path.read_text(encoding="utf-8")
6702:146:    for m in re.finditer(r"^##\s+(G-\d+)\b", body, re.M):
6703:147:        gid = m.group(1)
6704:148:        # Find this goal's section
6705:149:        sec_start = m.start()
6706:150:        next_sec = re.search(r"\n##\s+G-\d+\b", body[sec_start + 1:])
6707:151:        sec_end = sec_start + 1 + next_sec.start() if next_sec else len(body)
6708:152:        sec = body[sec_start:sec_end]
6709:153:        if re.search(r"automation:\s*(?:no|skip|deferred)", sec, re.I):
6710:154:            continue
6711:155:        automatable_goals.add(gid)
6712:156:    try:
6713:157:        ls = json.loads(ls_path.read_text(encoding="utf-8"))
6714:158:    except json.JSONDecodeError:
6715:159:        return False, sorted(automatable_goals)
6716:160:    emitted = set(ls.get("goals", {}).keys())
6717:161:    skipped_with_reason: set[str] = set()
6718:162:    for gid, gdata in ls.get("goals", {}).items():
6719:163:        if isinstance(gdata, dict) and (gdata.get("skipped", False) or gdata.get("skip_reason")):
6720:164:            skipped_with_reason.add(gid)
6721:165:    omitted = automatable_goals - emitted - skipped_with_reason
6722:166:    return len(omitted) == 0, sorted(omitted)
