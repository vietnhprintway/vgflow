2070:215:      --payload "{\"phase\":\"${PHASE_NUMBER}\",\"err_id\":\"${ERR_ID:-unknown}\",\"rc\":${CODEX_FIX_RC},\"attempt\":${TOTAL_ITER:-0}}" >/dev/null 2>&1 || true
2071:216:  fi
2072:217:else
2073:218:  # Claude path — preserve existing Agent tool spawn (narrate first, then call).
2074:219:  bash scripts/vg-narrate-spawn.sh general-purpose spawning "fix-${ERR_ID:-$idx}" 2>/dev/null || true
2075:220:  # Then invoke the Agent tool with the prompt body below; model/$SPAWN_MODEL
