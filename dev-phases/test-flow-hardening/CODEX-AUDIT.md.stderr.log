150:        lines.append(f"label: \"{label}\"")
151:        lines.append(f"input_hint: \"{input_hint}\"")
152:        lines.append(f"expected: \"{expected}\"")
153:        lines.append("priority: important")
154:        lines.append("```")
155:        lines.append("")
156:
157:    lines.append("## Codegen contract")
158:    lines.append("")
159:    lines.append(f"Generated spec MUST emit one `test.each([variants])` row per variant_id above.")
160:    lines.append(f"Each test name MUST cite variant_id (e.g. `test('${goal_id}-b1 — min boundary', ...)`).")
161:    lines.append(f"verify-edge-coverage gate (delegation.md F.2.5) checks this binding.")
162:    lines.append("")
163:    return "\n".join(lines)
