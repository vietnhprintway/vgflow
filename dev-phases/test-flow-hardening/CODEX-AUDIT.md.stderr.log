7533:51:def name_slug(name: str) -> str:
7534:52:    """Element name to slug. 'Add Site' → 'add-site'"""
7535:53:    s = re.sub(r"[^a-zA-Z0-9]+", "-", name.lower()).strip("-")
7536:54:    return s[:40] or "unnamed"
