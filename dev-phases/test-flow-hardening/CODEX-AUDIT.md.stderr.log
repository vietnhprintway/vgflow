5784:459:def _stage_actor(stage: str, goal: dict[str, Any], actors: list[dict[str, Any]]) -> str:
5785:460:    """Resolve which actor performs this stage.
5786:461:
5787:462:    Heuristic:
5788:463:    - Single actor → that actor for all stages.
5789:464:    - update/read_after_update + 'admin'/'approver' words in goal → admin/approver actor.
5790:465:    - read_after_create/read_after_update + 'invitee'/'accept' words → invitee actor.
5791:466:    - Default → actors[0].
5792:467:    """
5793:468:    if not actors:
5794:469:        return "primary"
5795:470:    if len(actors) == 1:
5796:471:        return actors[0]["id"]
5797:472:    haystack = _combined(goal)
5798:473:    if stage in {"update", "read_after_update"} and APPROVER_WORDS.search(haystack):
5799:474:        # Find admin/approver actor
5800:475:        for a in actors:
5801:476:            if a["id"] in {"admin", "approver", "reviewer"}:
5802:477:                return a["id"]
5803:478:    if stage in {"read_after_create"} and INVITEE_WORDS.search(haystack):
5804:479:        for a in actors:
5805:480:            if a["id"] in {"invitee", "collaborator", "member"}:
5806:481:                return a["id"]
5807:482:    return actors[0]["id"]
