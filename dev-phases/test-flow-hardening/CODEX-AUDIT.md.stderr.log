30:  # e.g. "Click 'Create Ad Unit' button"
31:  #      "POST /api/sites/{id}/ad-units from client"
32:  #      "Kafka message on topic bid-requests"
33:
34:main_steps:
35:  # Ordered list of user-visible OR system actions. Each step = 1 observable.
36:  - S1: <action>              # e.g. "Open form modal"
37:  - S2: <action>              # e.g. "Fill name + size + type"
38:  - S3: <action>              # e.g. "Submit form"
39:  - S4: <action>              # e.g. "API validates + persists"
40:  - S5: <action>              # e.g. "List refresh with new entry"
41:
42:alternate_flows:
43:  # Named failure modes + expected system behavior
44:  - name: <short_id>
45:    trigger: <what causes alternate flow>
46:    expected: <observable outcome>
47:  # e.g.
48:  # - name: validation_fail
49:  #   trigger: missing required field
50:  #   expected: inline errors shown, stay on modal
51:  # - name: quota_exceeded
52:  #   trigger: user at/above site quota
53:  #   expected: upgrade prompt shown, submission blocked
54:
55:postcondition:
56:  # State after successful main_flow execution. MUST include side effects.
57:  - <db state change>         # e.g. "ad_unit row inserted with status=pending_review"
58:  - <event emission>          # e.g. "event 'ad_unit_created' emitted to Kafka"
59:  - <cache invalidation>      # e.g. "sites_list cache for publisher invalidated"
60:  - <ui state>                # e.g. "list UI shows new item at top"
61:
62:# Verification binding (existing v1.14 fields)
63:verification: automated | manual | deferred | skipped
64:tests: [TS-XX, TS-YY]         # bind to test files via TS-XX markers
65:
66:# ─────────────────────────────────────────────────────────────────────
67:# v2.46 Phase 6 enrichment — Business traceability (REQUIRED post-2026-05-01)
68:# ─────────────────────────────────────────────────────────────────────
69:# Closes "AI bịa goal/decision" gap surfaced in Phase 3.2 dogfood. Goals
70:# missing these fields → BLOCK at /vg:blueprint via verify-goal-traceability.py.
71:# Migration: pre-2026-05-01 phases run validators in WARN mode (set
72:# VG_TRACEABILITY_MODE=warn). New phases default BLOCK.
73:
74:spec_ref: <SPECS.md#section-anchor>
75:  # REQUIRED. Cite the SPECS.md section that drives this goal. Validator
76:  # greps SPECS.md for the heading.
77:  # e.g. "SPECS.md#suspicious-topup-detection"
78:
79:decisions: [P3.D-46, P3.D-15]
80:  # REQUIRED if goal cites any decision. Each entry must exist in
81:  # CONTEXT.md. Validator (verify-decisions-to-goals.py) cross-checks.
82:  # Convention: <PHASE>.D-<NUMBER> for cross-phase, D-<NUMBER> for same-phase.
83:
84:business_rules: [BR-S-01, BR-S-02]
85:  # REQUIRED for business-logic goals. Each entry must exist in
86:  # DISCUSSION-LOG.md as "BR-NN: <rule statement>".
87:  # Empty list = goal has no business-rule semantics (e.g. pure UI render goal).
88:
89:flow_ref: <FLOW-SPEC.md#flow-anchor>
90:  # REQUIRED if surface=ui AND goal involves multi-step flow.
91:  # Validator greps FLOW-SPEC.md for the anchor.
92:
93:api_contracts: [topup-flag-endpoint, topup-list-endpoint]
94:  # REQUIRED if surface=api OR goal touches network mutations.
95:  # Each entry must match an endpoint heading in API-CONTRACTS.md.
96:
97:expected_assertion: |
98:  # REQUIRED. Verbatim quote of business rule statement that scanner/test
99:  # must verify. Used by:
100:  #   - verify-business-rule-implemented.py (build): grep code for
101:  #     constants matching this assertion
102:  #   - verify-asserted-rule-match.py (review): scanner steps[].asserted_quote
103:  #     must match this text >= 80% similarity
104:  #   - verify-test-traces-to-rule.py (test): .spec.ts header must cite
105:  #
106:  # Example:
107:  #   "Topup count >= SUSPICIOUS_COUNT_THRESHOLD (5) trong 24h sliding window
108:  #    → flagged_suspicious=true; AND amount sum >= AMOUNT_THRESHOLD ($100)
109:  #    in same window → flagged_suspicious=true (count OR amount triggers)"
110:
111:goal_class: mutation | readonly | crud-roundtrip | wizard | approval | webhook | feature_chain | post_create_cascade
112:  # REQUIRED. Drives min_steps validator threshold.
113:  # readonly: ≥3 steps (navigate → snapshot → assert)
114:  # mutation: ≥6 steps (pre-snapshot → submit → wait → refresh → re-read → diff)
115:  # approval: ≥8 (read pending → drawer → click approve → confirm modal → submit
116:  #              → wait → refresh → assert status flip)
117:  # crud-roundtrip: ≥14 (Read empty → Create [4 steps] → Read populated →
118:  #                      Update [4 steps] → Read updated → Delete [3 steps] →
119:  #                      Read empty)
120:  # wizard: ≥10 (multi-step form, capture each step transition)
121:  # webhook: ≥4 (trigger event → wait → query downstream state → assert)
122:  # feature_chain: ≥8 (B62 — closed-loop feature lifecycle. Min 8 steps with
123:  #                    ≥1 step where target_view_class is NOT in
124:  #                    {source_view, source_view_modal, source_view_form} AND
125:  #                    ≥2 steps with non-empty downstream_effects[].
126:  #                    Models: create on view A → verify in target view B →
127:  #                    click → detail loads → edit → cascade check → delete →
128:  #                    archive check. Dispatches FEATURE_CHAIN_STAGES in
129:  #                    generate-lifecycle-specs.py: read_before, create,
130:  #                    read_after_create, visibility_check, interaction_chain,
131:  #                    update, read_after_update, cascade_check, delete,
132:  #                    read_after_delete, archive_visibility_check.)
133:  # post_create_cascade: alias for feature_chain (B62)
134:
135:# ─────────────────────────────────────────────────────────────────────
136:# B62: Feature-chain frontmatter (REQUIRED when goal_class=feature_chain)
137:# ─────────────────────────────────────────────────────────────────────
138:# Closed-loop modeling. Captures inverse-dependency edges + downstream
139:# state propagation. Validated by verify-feature-chain-coverage.py +
140:# verify-enables-deps-symmetry.py (B62-pre).
141:
142:enables:
143:  # OPTIONAL but recommended for mutation/crud-roundtrip/feature_chain.
144:  # List of G-XX goal ids that BECOME testable AFTER this goal succeeds.
145:  # Forward-edge declaration. Must mirror backward Dependencies[] on
146:  # target goal (validator: verify-enables-deps-symmetry.py).
147:  # Example: G-01 creates a site → enables: [G-04 (dashboard visible),
148:  #                                          G-07 (audit log entry)]
149:  # Truth-source rule: Dependencies[] is canonical; enables[] is a
150:  # readability + coverage hint. Both must agree or symmetry gate fires.
151:  - G-04
152:  - G-07
153:
154:chain_consumes_state:
155:  # OPTIONAL. Named state precondition this goal expects to exist.
156:  # Examples: "customer_exists", "tenant_authenticated", "site_in_active_pool".
157:  # Used by codegen subagent to wire beforeEach fixtures matching the
158:  # chain_produces_state of upstream goals.
159:  # Namespaced (B62 audit ID-11) to avoid collision with potential
160:  # state-machine `produces_state` / `consumes_state` fields in FLOW-SPEC.
161:  customer_exists: true
162:
163:chain_produces_state:
164:  # OPTIONAL. Named state postcondition this goal establishes.
165:  # Examples: "invoice_persisted", "site_in_active_pool", "user_logged_in".
166:  # Downstream goals reference this via chain_consumes_state.
167:  invoice_persisted: true
168:
169:chain_steps:
170:  # REQUIRED when goal_class=feature_chain. List of explicit chain steps.
171:  # MIN 8 entries (B62 + audit ID-3 anti-cheat). MIN 1 entry must have
172:  # target_view_class NOT in {source_view, source_view_modal,
173:  # source_view_form} — chain MUST traverse to a structurally different view.
174:  # MIN 2 entries must have non-empty downstream_effects[] — chain MUST
175:  # observe at least 2 downstream consequences, not just rename existing
176:  # shallow mutation steps.
177:  #
178:  # target_view_class enum (B62 + audit ID-6 view-rename-stable identity):
179:  #   - source_view: the originating view (e.g. /sites)
180:  #   - source_view_modal: modal/drawer on source view
181:  #   - source_view_form: dedicated form route for the source view
182:  #   - primary_list: list view for the resource type (NOT source_view)
183:  #   - dashboard_summary: aggregate dashboard cards / metrics
184:  #   - audit_log: change-log / activity feed view
185:  #   - sibling_list: list view for a related resource type
186:  #   - notification_feed: in-app notification surface
187:  #   - report_view: detailed report / drill-down
188:  #
189:  # Goal-id derived from (entity_canonical_id + target_view_class), NOT raw
190:  # view path → stable across view renames.
191:  - step_id: S1
192:    description: User authenticates and navigates to source view
193:    target_view_class: source_view
194:    expected_state: list_loaded_with_baseline_items
195:    downstream_effects: []
196:  - step_id: S2
197:    description: User clicks Create → form opens
198:    target_view_class: source_view_modal
199:    expected_state: create_form_visible
200:    downstream_effects: []
201:  - step_id: S3
202:    description: User fills form + submits, server returns 201
203:    target_view_class: source_view_modal
204:    expected_state: form_closes_toast_visible
205:    downstream_effects:
206:      - "row_count[/sites] increments by 1"
207:      - "audit_log entry appended"
208:  - step_id: S4
209:    description: Navigate to dashboard → newly created entity visible
210:    target_view_class: dashboard_summary
211:    expected_state: entity_in_active_count
212:    downstream_effects:
213:      - "dashboard counter +1"
214:  - step_id: S5
215:    description: Click entity card → detail view loads
216:    target_view_class: sibling_list
217:    expected_state: detail_route_resolved
218:    downstream_effects: []
219:  - step_id: S6
220:    description: Edit entity → status flips
221:    target_view_class: source_view
222:    expected_state: entity_status_updated
223:    downstream_effects:
224:      - "status badge updated"
225:  - step_id: S7
226:    description: Delete entity → confirm modal → confirmed
227:    target_view_class: source_view_modal
228:    expected_state: entity_deleted
229:    downstream_effects:
230:      - "row_count[/sites] decrements by 1"
231:  - step_id: S8
232:    description: Navigate to archive list → entity searchable but not in active
233:    target_view_class: audit_log
234:    expected_state: entity_in_archive_only
235:    downstream_effects:
236:      - "archive_count +1"
237:      - "active_count -1"
238:
239:goal_grounding: api | flow | presentation
240:  # REQUIRED post-2026-05-01 (PR-F). Drives /vg:test verification strategy
241:  # dispatch — different grounding = different proof shape:
242:  #
243:  # `api`            (B2B billing/orders/payments/wallet — most goals here)
244:  #   Anchor: API-CONTRACTS endpoint shape + business invariants.
245:  #   Verification: recipe_executor against openapi.json + lifecycle.post_state.
246:  #   UI = thin client, may have extras/gaps but NOT the source of truth.
247:  #
248:  # `flow`           (onboarding wizard, KYC, password recovery, multi-step)
249:  #   Anchor: FLOW-SPEC.md state-machine + checkpoint transitions.
250:  #   Verification: flow-runner walks declarative steps with assertions
251:  #   per checkpoint. Multiple API calls per step OK.
252:  #   API endpoints fragmented; flow itself IS the business semantics.
253:  #
254:  # `presentation`   (dashboards, charts, pricing previews, reports)
255:  #   Anchor: API raw data + UI display computation (totals, percentages,
256:  #   formatted dates).
257:  #   Verification: screenshot diff + computation check (verify
258:  #   formula: display_total = sum(items) × (1 + tax_rate)).
259:  #   UI legitimately has "extra fields" derived from API data — they're
260:  #   not phantom.
261:  #
262:  # Default if unspecified: infer from surface (api/data/integration → api;
263:  # ui + multi-step flow_ref → flow; ui + chart/dashboard/preview → presentation).
264:  # Validator (verify-goal-grounding) warns on unspecified for new phases.
265:
266:# ─────────────────────────────────────────────────────────────────────
267:# v2.5 Phase B enrichment — Security + Performance
268:# ─────────────────────────────────────────────────────────────────────
269:# Optional but REQUIRED for critical_goal_domains (auth/payment/billing).
270:# Severity logic in verify-goal-security.py:
271:#   - critical_goal_domain + section empty → HARD BLOCK
272:#   - mutation endpoint + csrf OR rate_limit empty → HARD BLOCK
273:#   - read-only GET + section empty → WARN + override debt
274:
275:security_checks:
276:  # OWASP Top 10 2021 subset relevant cho endpoint (không phải hết 10).
277:  # Format: "AXX:name: justification" — validator cross-references với
278:  # API-CONTRACTS schema để auto-tick (vd Zod schema → A03 injection OK).
279:  owasp_top10_2021:
280:    - "A01:Broken-Access-Control: owner check on update via ownerId middleware"
281:    - "A03:Injection: Zod schema parameterized query via Prisma"
282:    - "A05:Security-Misconfig: CSP default-src 'self' inherits project baseline"
283:    # Relevant categories (add as applicable):
284:    # - "A02:Cryptographic-Failures: bcrypt work factor 12, no SHA1"
285:    # - "A04:Insecure-Design: rate-limit + step-up auth cho destructive op"
286:    # - "A06:Vulnerable-Components: lockfile integrity + CVE scan CI"
287:    # - "A07:Identification-Auth: session fixation prevented + logout server-side"
288:    # - "A08:Software-Integrity: signed commits + dependency provenance"
289:    # - "A09:Logging-Monitoring: audit log with user_id + IP + UA"
290:    # - "A10:SSRF: URL whitelist, block 169.254/10/172.16/192.168"
291:
292:  # ASVS Level 2 controls (granular validation beyond OWASP Top 10).
293:  # Free-form string citing ASVS ID + justification.
294:  asvs_level2:
295:    - "V5.1.1: input validation per field via Zod schema"
296:    - "V5.3.3: output encoding context-aware (React auto-escape + CSP)"
297:    # - "V7.1.1: session generation cryptographically strong"
298:    # - "V9.1.2: TLS 1.2+ enforced cho all endpoints"
299:
300:  # Rate limiting: per-user + per-IP. Required cho mutation endpoints.
301:  # Empty → HARD BLOCK cho mutation. Format: free-form description.
302:  rate_limit: "10/min per user, 30/min per IP, 5/min anonymous"
303:
304:  # CSRF protection mechanism. Required cho state-changing endpoints
305:  # (POST/PUT/PATCH/DELETE) nếu accept cookie auth. Empty → HARD BLOCK
306:  # cho mutation + cookie auth (Bearer-only API có thể để trống).
307:  csrf: "SameSite=Strict session cookie + double-submit token verify"
308:
309:  # XSS protection — framework default + explicit overrides.
310:  xss_protection: "React auto-escape + CSP strict default-src 'self'"
311:
312:  # Auth model classification (cross-ref với API-CONTRACTS Block 1 auth line).
313:  # Values: public | authenticated | role:<name> | owner_only | multi
314:  auth_model: "owner_only"
315:
316:  # PII fields (if endpoint accepts/returns PII). Encryption + masking policy.
317:  pii_fields: ["email", "phone", "dob"]
318:
319:# ─────────────────────────────────────────────────────────────────────
320:# v2.8.4 Phase J enrichment — Interactive Controls (URL state)
321:# ─────────────────────────────────────────────────────────────────────
322:# REQUIRED for goals with surface=ui AND main_steps mention list/table/grid
323:# AND any of {filter, sort, paginate, search}. Empty → BLOCK at /vg:review
324:# phase 2.7 (verify-url-state-sync.py). Phase 0-13 grandfather: WARN only.
325:#
326:# Convention default (locked in FOUNDATION §9 + vg.config.md):
327:#   - list_view_state_in_url: true        (URL params reflect filter/sort/page state)
328:#   - url_param_naming: kebab             (status, sort-by, page-size — config override)
329:#   - array_format: csv                   (?tags=a,b,c — alternative: repeat-key)
330:#   - debounce_search_ms: 300             (search input debounce default)
331:#
332:# Override semantics:
333:#   url_sync: false → declare local-only state (e.g. modal-internal filter,
334:#     transient sort that resets on close). REQUIRES `url_sync_waive_reason`
335:#     to log soft debt + survive validator.
336:
337:interactive_controls:
338:  # Master flag — defaults true. Set false ONLY for local/transient state.
339:  url_sync: true
340:  url_sync_waive_reason: ""             # required when url_sync: false
341:
342:  # Filters: dropdown / chip / multi-select. Each entry = 1 user-controllable
343:  # filter. Validator clicks each value → asserts URL + data subset.
344:  filters:
345:    - name: status                      # filter id (matches data attr or test id)
346:      values: [active, paused, completed, archived]
347:      url_param: status                 # default: same as name (apply naming convention)
348:      assertion: "rows.status all match selected value; URL ?status={value} synced; reload preserves"
349:    # Multi-value example (array filter):
350:    # - name: tags
351:    #   values: [premium, mobile, video]
352:    #   url_param: tags
353:    #   array: true                     # → ?tags=premium,mobile (csv) or ?tags=premium&tags=mobile
354:    #   assertion: "rows have ALL selected tags; URL contains all values"
355:
356:  # Pagination: required if list expects > page_size rows.
357:  # UI MANDATORY pattern (v2.8.4 Phase J — locked convention):
358:  #   << < {N-5} {N-4} … {N} … {N+4} {N+5} > >>
359:  # which means: first-page (<<), prev (<), numbered window of current ±5,
360:  # next (>), last-page (>>). Plus visible "Showing X-Y of Z records" /
361:  # "Page N of M". Plain "prev / next + page-number-display" is BANNED —
362:  # it requires too many clicks to reach a known target page.
363:  pagination:
364:    page_size: 20                       # rows per page (validator inspects total ÷ size)
365:    url_param_page: page                # ?page=2
366:    url_param_size: pageSize            # ?pageSize=50 (optional — only if user-controllable)
367:    ui_pattern: "first-prev-numbered-window-next-last"  # MANDATORY value
368:    window_radius: 5                    # numbered buttons = current ±5 (locked default)
369:    show_total_records: true            # MANDATORY — "Showing X-Y of Z"
370:    show_total_pages: true              # MANDATORY — "Page N of M"
371:    assertion: "page2 first_row_id ≠ page1 first_row_id; total count consistent across pages; URL ?page=N synced; reload page=N preserves; UI shows << < numbered-window > >> + Showing X-Y of Z + Page N of M"
372:
373:  # Search: text input that filters list. Required if list has search box.
374:  search:
375:    field: name                         # which entity field is searched (or "fulltext")
376:    url_param: q                        # ?q=xyz
377:    debounce_ms: 300                    # framework debounce — must match config default
378:    assertion: "type query → debounce wait → URL ?q={query} synced; result rows all contain query (case-insensitive); empty query clears URL param"
379:
380:  # Sort: column header click toggles sort. Required if table has sortable columns.
381:  sort:
382:    columns: [created_at, name, status, updated_at]
383:    url_param_field: sort               # ?sort=created_at
384:    url_param_dir: dir                  # ?dir=desc
385:    default: created_at desc            # initial state when no URL params
386:    assertion: "click header toggles asc↔desc; URL ?sort={col}&dir={asc|desc} synced; ORDER BY assertion holds in data; reload preserves"
387:
388:# Performance budget — Required cho mutation + list endpoints.
389:# Read-only single-record GET có thể để trống (default project baseline).
390:perf_budget:
391:  p50_ms: 80                    # median response time target
392:  p95_ms: 250                   # 95th percentile target (alarm threshold)
393:  p99_ms: 500                   # 99th percentile (outlier floor)
394:  n_plus_one_max: 3             # max DB round-trips per request
395:  bundle_kb_fe_route: 250       # FE route-split bundle size (only applicable cho ui surface)
396:  cache_strategy: "Redis 5min TTL + tag-invalidate on mutation"
397:
398:# ─────────────────────────────────────────────────────────────────────
399:# v2.21 enrichment — Adversarial / cheat-path coverage
400:# ─────────────────────────────────────────────────────────────────────
401:# Declarative threat model per goal. Required cho mutation/auth/payment
402:# domains; warn-only cho read-only/UI presentation goals.
403:#
404:# verify-adversarial-coverage.py reads this block + emits WARN nếu thiếu
405:# cho domain bắt buộc. User opt-out qua `--skip-adversarial=<reason>` →
406:# OVERRIDE-DEBT critical entry → reviewer triage tại /vg:accept.
407:#
408:# Threat taxonomy (v1):
409:#   auth_bypass        — other-tenant ID, expired session, role downgrade
410:#   injection          — SQL / XSS / SSTI / cmd-injection payloads
411:#   race               — concurrent submit, double-spend, TOCTOU
412:#   duplicate_submit   — replay protection, idempotency-key
413:#   boundary_overflow  — int overflow, length limit, file size
414:#   role_escalation    — privilege jump, IDOR
415:#   csrf_replay        — cross-site request without token
416:
417:adversarial_scope:
418:  threats: [auth_bypass, injection, duplicate_submit]
419:  per_threat:
420:    auth_bypass:
421:      paths: ["other-tenant-id", "different-role", "expired-session"]
422:      assertions:
423:        - "status: 403 OR 404"
424:        - "no PII leak in error body"
425:    injection:
426:      payloads: ["${SQLI_PAYLOAD}", "${XSS_PAYLOAD}", "${SSTI_PAYLOAD}"]
427:      assertions:
428:        - "no payload execution (response echo escaped)"
429:        - "no DB error 500 with SQL fragment in body"
430:    duplicate_submit:
431:      method: "replay POST within 100ms"
432:      assertions:
433:        - "second response: 409 OR 200-with-existing-id (idempotent)"
434:        - "exactly 1 row created (verify via DB)"
435:  # Empty `threats: []` is an EXPLICIT decision — AI must include
436:  # comment why the goal is low-risk (e.g., "read-only GET, no PII").
437:
438:# Evidence fields (populated by /vg:test, /vg:review)
439:status: NOT_SCANNED | READY | BLOCKED | UNREACHABLE | FAILED | DEFERRED | INFRA_PENDING | MANUAL
440:evidence_file: apps/web/e2e/xxx.spec.ts:42 | apps/api/test/xxx.test.ts
441:adversarial_evidence:                            # populated by /vg:test
442:  - threat: auth_bypass
443:    file: apps/web/e2e/G-01.adversarial.auth_bypass.spec.ts
444:    status: PASS
445:---
446:
447:## Prose description (optional)
448:
449:Narrative context for humans reviewing goal. Not parsed by validators.
450:```
451:
452:## Example — real goal (phase 14 G-01)
453:
454:```yaml
455:---
456:id: G-01
457:title: "Publisher login respects domain-role fit"
458:priority: critical
459:surface: api + ui
460:actor: publisher (role=publisher, unauthenticated before login)
461:precondition:
462:  - has_verified_account
463:  - domain_route_configured (ssp.vollx.com → publisher app)
464:trigger: "POST /api/v1/auth/login from ssp.vollx.com origin"
465:main_steps:
466:  - S1: Client POST credentials + domain header to /api/v1/auth/login
467:  - S2: API validates domain-role fit via AuthDomain enum
468:  - S3: API issues JWT with domain=ssp claim + refresh cookie scoped to ssp domain
469:  - S4: Client redirected to publisher dashboard
470:  - S5: Subsequent requests include JWT — middleware validates JWT.domain matches Origin header
471:alternate_flows:
472:  - name: domain_role_mismatch
473:    trigger: admin account attempts login from ssp.vollx.com
474:    expected: 403 with VG_ERR_DOMAIN_ROLE_UNFIT + Vietnamese toast "Tài khoản không có quyền cho domain này"
475:  - name: invalid_origin
476:    trigger: request from unapproved domain (e.g. evil.com)
477:    expected: 403 via CORS preflight + VG_ERR_DOMAIN_ORIGIN_INVALID logged
478:postcondition:
479:  - jwt_issued with domain=ssp in payload
480:  - refresh_cookie set with Domain=.ssp.vollx.com Path=/api/v1/auth
481:  - session row in Redis with key "session:ssp:{user_id}:{device_id}"
482:  - event "auth.login" emitted with {domain, user_id, success: true}
483:verification: automated
484:tests: [TS-01, TS-02]
485:status: READY
486:evidence_file: apps/web/e2e/auth-domain-isolation.spec.ts:23
487:---
488:
489:Publisher can only log in from their designated SSP domain. Cross-domain
490:attempts (admin credentials on SSP domain) are rejected with clear error
491:message in Vietnamese. Session cookies scoped to domain prevent cross-
492:site token leak.
493:```
494:
495:## Migration
496:
497:- **Existing goals** (v1.14 format): no action needed. Missing fields = validators skip enrichment checks.
498:- **New phases** (scope/blueprint v2+): blueprint step 2b5 SHOULD emit enriched format. AI reads this template to infer structure.
499:- **Manual enrichment**: user edits TEST-GOALS.md adding fields. Validators re-run, may unlock additional coverage.
500:
501:## Consumer behavior
502:
503:| Command | Reads enriched fields | Effect |
504:|---------|----------------------|--------|
505:| `/vg:blueprint` step 2b5 | Generates via AI prompt | AI pattern-matches template → uses enriched format |
506:| `/vg:build` executor | Reads `precondition` + `alternate_flows` | Task context includes error handling requirements |
507:| `/vg:review` goal comparison | Reads `main_steps` + `postcondition` | Maps to RUNTIME-MAP observed sequences |
508:| `/vg:test` codegen | Reads all enriched fields | Generates Playwright scenarios per `alternate_flows` names |
509:| `/vg:accept` UAT checklist | Reads `actor` + `postcondition` | User UAT items phrased in enriched language |
510:
511:Each consumer's enrichment is **additive** — absence of field = legacy path.
