8121:639:def render_markdown(stubs: list[dict], existing_count: int,
8122:640:                    runtime_views: int, threshold: int) -> str:
8123:641:    now = _dt.datetime.now(_dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
8124:642:    lines: list[str] = []
8125:643:    lines.append(f"# TEST-GOALS-DISCOVERED.md")
8126:644:    lines.append("")
8127:645:    lines.append(f"_Generated: {now} by `/vg:review` Phase 2c (v2.34.0+)._")
8128:646:    lines.append("")
8129:647:    lines.append("Auto-emitted goal stubs from runtime UI discovery (Haiku/in-session Codex scans).")
8130:648:    lines.append("Each stub maps to a real UI element observed during review. `/vg:test` codegen consumes")
8131:649:    lines.append("this file alongside `TEST-GOALS.md`. Generated specs prefixed `auto-{goal-id}.spec.ts`.")
8132:650:    lines.append("")
8133:651:    lines.append(f"## Source")
8134:652:    lines.append("")
8135:653:    lines.append(f"- Existing TEST-GOALS.md: **{existing_count}** goals")
8136:654:    lines.append(f"- Runtime views scanned: **{runtime_views}**")
8137:655:    lines.append(f"- Auto-discovered goals: **{len(stubs)}**")
8138:656:    lines.append(f"- Coverage threshold (min elements/view to require enrichment): {threshold}")
8139:657:    lines.append("")
8140:658:    lines.append("## Triage")
8141:659:    lines.append("")
8142:660:    lines.append("Auto-goals are **review-grade** (heuristically derived). Human triage on next blueprint:")
8143:661:    lines.append("- Promote useful auto-goals → migrate to `TEST-GOALS.md` with proper IDs")
8144:662:    lines.append("- Reject false-positives → add to `interactive_controls.exclude` in source goal")
8145:663:    lines.append("- Keep `G-AUTO-*` IDs for repeat runs — script dedupes against existing IDs")
8146:664:    lines.append("")
8147:665:    lines.append("## Auto-emitted goals")
8148:666:    lines.append("")
8149:667:
8150:668:    for stub in stubs:
8151:669:        lines.append("---")
8152:670:        lines.append(f"id: {stub['id']}")
8153:671:        lines.append(f"title: \"{stub['title']}\"")
8154:672:        lines.append(f"priority: {stub['priority']}")
8155:673:        lines.append(f"surface: {stub['surface']}")
8156:674:        lines.append(f"source: {stub['source']}")
8157:675:        lines.append(f"evidence:")
8158:676:        for k, v in (stub.get("evidence") or {}).items():
8159:677:            if v is not None:
8160:678:                lines.append(f"  {k}: {json.dumps(v)}")
8161:679:        lines.append(f"trigger: \"{stub.get('trigger', '')}\"")
8162:680:        lines.append("main_steps:")
8163:681:        for step in stub.get("main_steps") or []:
8164:682:            for sk, sv in step.items():
8165:683:                lines.append(f"  - {sk}: \"{sv}\"")
8166:684:        if stub.get("alternate_flows"):
8167:685:            lines.append("alternate_flows:")
8168:686:            for af in stub["alternate_flows"]:
8169:687:                lines.append(f"  - name: {af['name']}")
8170:688:                lines.append(f"    trigger: \"{af['trigger']}\"")
8171:689:                lines.append(f"    expected: \"{af['expected']}\"")
8172:690:        if stub.get("postcondition"):
8173:691:            lines.append("postcondition:")
8174:692:            for pc in stub["postcondition"]:
8175:693:                lines.append(f"  - \"{pc}\"")
8176:694:        lines.append("---")
8177:695:        lines.append("")
8178:696:
8179:697:    return "\n".join(lines)
