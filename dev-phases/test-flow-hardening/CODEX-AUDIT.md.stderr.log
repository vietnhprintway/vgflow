231:        action = obs.get("action") or "create"
232:        action_class = action_class_map.get(action, "visibility")
233:        target_class = (obs.get("target_view_class") or "").strip()
234:        if not target_class:
235:            continue
236:        entity_canon = (obs.get("entity_canonical_id") or "").strip()
237:        if not entity_canon:
238:            # fallback: derive from source_view path
239:            sv = (obs.get("source_view") or "").strip("/")
240:            entity_canon = f"{name_slug(sv) or 'entity'}:{action}"
241:        # idempotent goal-id (audit ID-6 view-rename-stable)
242:        entity_slug = name_slug(entity_canon.split(":")[0])
243:        gid = f"G-AUTO-{entity_slug}-{action_class}-{target_class}"
244:        if gid in seen_propagations:
245:            continue
246:        seen_propagations.add(gid)
247:        stubs.append({
248:            "id": gid,
