5560:235:def _parse_goals(phase_dir: Path) -> list[dict[str, Any]]:
5561:236:    split_dir = phase_dir / "TEST-GOALS"
5562:237:    goals: list[dict[str, Any]] = []
5563:238:    if split_dir.is_dir():
5564:239:        for path in sorted(split_dir.glob("G-*.md")):
5565:240:            goal = _parse_goal_block(_read(path), path)
5566:241:            if goal:
5567:242:                goals.append(goal)
5568:243:    if goals:
5569:244:        return goals
5570:245:
5571:246:    text = _read(phase_dir / "TEST-GOALS.md")
5572:247:    pattern = re.compile(
5573:248:        r"^##\s+(?:Goal\s+)?(G-[\w.-]+):?\s*(.*?)$"
5574:249:        r"(?P<body>(?:(?!^##\s+(?:Goal\s+)?G-[\w.-]+).)*)",
5575:250:        re.MULTILINE | re.DOTALL,
5576:251:    )
5577:252:    for match in pattern.finditer(text):
5578:253:        body = f"## Goal {match.group(1)}: {match.group(2)}\n{match.group('body') or ''}"
5579:254:        goal = _parse_goal_block(body, phase_dir / "TEST-GOALS.md")
5580:255:        if goal:
5581:256:            goals.append(goal)
5582:257:    return goals
