5843:518:DECISION_HEADER_RE = re.compile(
5844:519:    r"^#{2,3}\s+(D-[\w.-]+):?\s*(.+?)\s*$",
5845:520:    re.MULTILINE,
5846:521:)
5847:522:DECISION_FIELD_RE = re.compile(
5848:523:    r"^\*\*expected_assertion:\*\*\s*(.+?)(?=^\*\*|\n##|\n#\s+D-|\Z)",
5849:524:    re.MULTILINE | re.DOTALL,
