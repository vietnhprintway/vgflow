1195:305:def render_playwright_plan(lifecycle: dict[str, Any], surfaces: dict[str, Any]) -> str:
1196:306:    lines = [
1197:307:        "# Compatibility Test Execution Plan",
1198:308:        "",
1199:309:        "## Global Requirements",
1200:310:        "",
1201:311:        "- Use the runner selected in `TEST-EXECUTION-PLAN.json` for this phase profile.",
1202:312:        "- Capture profile-native logs, traces, state snapshots, and failure artifacts for every scenario.",
1203:313:        "- Use stable entrypoints: selectors, accessibility ids, commands, endpoints, public APIs, jobs, events, or fixtures.",
1204:314:        "- Seed through fixture DAG order, cleanup in reverse order.",
1205:315:        "- Assert response/output/state and fresh re-read after every mutation.",
1206:316:        "",
1207:317:        "## Runner Skeletons",
1208:318:        "",
1209:319:    ]
1210:320:    for goal_id, spec in (lifecycle.get("goals") or {}).items():
1211:321:        title = spec.get("title", "")
1212:322:        plan = spec.get("execution_plan") or {}
1213:323:        profile = plan.get("profile") or lifecycle.get("phase_profile") or "mixed"
1214:324:        family = plan.get("family") or "mixed"
1215:325:        runner = plan.get("runner") or "custom"
1216:326:        if family == "web":
1217:327:            file_hint = f"tests/e2e/{goal_id.lower().replace('.', '-')}.lifecycle.spec.ts"
1218:328:        elif family == "mobile":
1219:329:            file_hint = f"tests/mobile/{goal_id.lower().replace('.', '-')}.lifecycle.yaml"
1220:330:        elif family == "cli":
1221:331:            file_hint = f"tests/cli/{goal_id.lower().replace('.', '-')}.lifecycle.test"
1222:332:        elif family == "backend":
1223:333:            file_hint = f"tests/api/{goal_id.lower().replace('.', '-')}.lifecycle.test"
1224:334:        elif family == "library":
1225:335:            file_hint = f"tests/unit/{goal_id.lower().replace('.', '-')}.lifecycle.test"
1226:336:        else:
1227:337:            file_hint = f"tests/lifecycle/{goal_id.lower().replace('.', '-')}.test"
1228:338:        lines.extend(
1229:339:            [
1230:340:                f"### `{goal_id}` — {title}",
1231:341:                "",
1232:342:                f"- Profile: `{profile}`",
1233:343:                f"- Runner: `{runner}`",
1234:344:                f"- File hint: `{file_hint}`",
1235:345:                f"- Actors: `{', '.join(str(a.get('id')) for a in spec.get('actors') or [])}`",
1236:346:                f"- Fixtures: `{', '.join(str(f.get('id')) for f in spec.get('fixture_dag') or [])}`",
1237:347:                f"- Entrypoints: `{', '.join(str(item) for item in plan.get('entrypoints') or [])}`",
1238:348:                "- Steps:",
1239:349:            ]
1240:350:        )
1241:351:        for step in spec.get("steps") or []:
1242:352:            lines.append(f"  - `{step.get('stage')}`: {step.get('action')}")
1243:353:        lines.append("")
1244:354:    lines.extend(["## Surface Hints", ""])
1245:355:    for form in surfaces["forms"][:80]:
1246:356:        lines.append(f"- Form candidate: `{form['file']}`")
1247:357:    for mutation in surfaces["mutations"][:80]:
1248:358:        lines.append(f"- Mutation candidate: `{mutation['file']}`")
1249:359:    return "\n".join(lines).rstrip() + "\n"
