999:def generate(phase_dir: Path, include_readonly: bool = False) -> dict[str, Any]:
1000:    goals = _parse_goals(phase_dir)
1001:    contracts = _parse_api_contracts(phase_dir)
1002:    decisions = _parse_context_decisions(phase_dir)
1003:    selected = [goal for goal in goals if include_readonly or _needs_lifecycle(goal)]
1004:    specs = {goal["id"]: _goal_spec(goal, contracts, decisions) for goal in selected}
1005:    return {
