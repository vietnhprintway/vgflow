5854:529:def _parse_context_decisions(phase_dir: Path) -> dict[str, dict[str, str]]:
5855:530:    """Parse CONTEXT.md → {D-ID: {title, expected_assertion}}."""
5856:531:    ctx_path = phase_dir / "CONTEXT.md"
5857:532:    if not ctx_path.is_file():
5858:533:        return {}
5859:534:    text = _read(ctx_path)
5860:535:    decisions: dict[str, dict[str, str]] = {}
5861:536:    matches = list(DECISION_HEADER_RE.finditer(text))
5862:537:    for i, m in enumerate(matches):
5863:538:        d_id = m.group(1)
5864:539:        title = m.group(2).strip()
5865:540:        # Body = text from end of this header to next header or end
5866:541:        start = m.end()
5867:542:        end = matches[i + 1].start() if i + 1 < len(matches) else len(text)
5868:543:        body = text[start:end]
5869:544:        assertion_match = DECISION_FIELD_RE.search(body)
5870:545:        decisions[d_id] = {
5871:546:            "title": title,
5872:547:            "expected_assertion": assertion_match.group(1).strip() if assertion_match else "",
5873:548:        }
5874:549:    return decisions
