988:98:def find_phase_dir(phase: str, explicit: str | None = None) -> Path:
989:99:    if explicit:
990:100:        path = Path(explicit)
991:101:        if not path.exists():
992:102:            raise SystemExit(f"phase-dir not found: {path}")
993:103:        return path
994:104:
995:105:    root = Path(os.environ.get("VG_REPO_ROOT") or os.getcwd())
996:106:    phases_root = root / ".vg" / "phases"
997:107:    if not phases_root.is_dir():
998:108:        raise SystemExit(f"phase directory root not found: {phases_root}")
999:109:
1000:110:    candidates = [p for p in phases_root.iterdir() if p.is_dir()]
1001:111:    exact = [p for p in candidates if p.name == phase]
1002:112:    if exact:
1003:113:        return exact[0]
1004:114:
1005:115:    prefix = phase_pad(phase) if str(phase).isdigit() else str(phase)
1006:116:    matches = [p for p in candidates if p.name == prefix or p.name.startswith(prefix + "-")]
1007:117:    if len(matches) == 1:
1008:118:        return matches[0]
1009:119:    if not matches:
1010:120:        raise SystemExit(f"phase not found: {phase}")
1011:121:    raise SystemExit(f"phase is ambiguous: {phase}: {', '.join(p.name for p in matches)}")
1012:122:
