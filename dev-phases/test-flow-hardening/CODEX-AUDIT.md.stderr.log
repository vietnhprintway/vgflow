1252:362:def render_gaps(lifecycle: dict[str, Any], surfaces: dict[str, Any], phase_dir: Path) -> str:
1253:363:    gaps: list[str] = []
1254:364:    strategy = lifecycle.get("execution_strategy") if isinstance(lifecycle.get("execution_strategy"), dict) else {}
1255:365:    family = strategy.get("family") or "mixed"
1256:366:    if not has_build_evidence(phase_dir):
1257:367:        gaps.append("Build evidence missing; run `/vg:build` first.")
1258:368:    if not (phase_dir / "TEST-GOALS.md").exists() and not (phase_dir / "TEST-GOALS").is_dir():
1259:369:        gaps.append("TEST-GOALS missing; run `/vg:blueprint` first.")
1260:370:    if not lifecycle.get("goals"):
1261:371:        gaps.append("No lifecycle goals emitted; verify mutation/multi-actor goals are tagged in TEST-GOALS.")
1262:372:    if surfaces["mutations"] and not lifecycle.get("goals"):
1263:373:        gaps.append("Mutation code exists but TEST-GOALS did not produce lifecycle contracts.")
1264:374:    if family == "web" and surfaces["forms"] and surfaces["selector_files"] == 0:
1265:375:        gaps.append("Forms detected but no stable selector/role/label hints found in scanned files.")
1266:376:    if family == "web" and not surfaces["routes"]:
1267:377:        gaps.append("No browser routes detected by static scan; review must rely on runtime navigation or framework-specific scanner.")
1268:378:    if family in {"mobile", "cli", "backend", "library"}:
1269:379:        gaps.append(f"Profile `{lifecycle.get('phase_profile', 'mixed')}` needs runner-native executable specs from `/vg:test`; browser-only coverage is insufficient.")
1270:380:    if not gaps:
1271:381:        gaps.append("No deterministic deep-spec gaps detected.")
1272:382:    return "# Test Spec Gaps\n\n" + "\n".join(f"- {gap}" for gap in gaps) + "\n"
