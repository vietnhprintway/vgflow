235:def _parse_goals(phase_dir: Path) -> list[dict[str, Any]]:
236:    split_dir = phase_dir / "TEST-GOALS"
237:    goals: list[dict[str, Any]] = []
238:    if split_dir.is_dir():
239:        for path in sorted(split_dir.glob("G-*.md")):
240:            goal = _parse_goal_block(_read(path), path)
241:            if goal:
242:                goals.append(goal)
