577:def _bind_endpoint(stage: str, goal: dict[str, Any], contracts: list[dict[str, str]]) -> dict[str, str] | None:
578:    """Match stage to a contract endpoint via heuristic on stage verb + goal text."""
579:    if not contracts:
580:        return None
581:    verb_map: dict[str, tuple[str, ...]] = {
582:        "create": ("POST",),
583:        "read_before": ("GET",),
584:        "read_after_create": ("GET",),
585:        "update": ("PUT", "PATCH"),
586:        "read_after_update": ("GET",),
587:        "delete": ("DELETE",),
588:        "read_after_delete": ("GET",),
589:    }
590:    candidates_methods = verb_map.get(stage, ())
591:    if not candidates_methods:
592:        return None
593:    # First: try match in mutation_evidence + dependencies + persistence_check text
594:    haystack = " ".join(str(goal.get(k) or "") for k in
595:                        ("mutation_evidence", "persistence_check", "dependencies", "title"))
596:    for c in contracts:
597:        if c["method"] in candidates_methods and c["path"] in haystack:
598:            return {"method": c["method"], "path": c["path"]}
599:    # Fallback: first contract entry whose method matches
600:    for c in contracts:
601:        if c["method"] in candidates_methods:
602:            return {"method": c["method"], "path": c["path"]}
603:    return None
