459:def _stage_actor(stage: str, goal: dict[str, Any], actors: list[dict[str, Any]]) -> str:
460:    """Resolve which actor performs this stage.
461:
462:    Heuristic:
463:    - Single actor → that actor for all stages.
464:    - update/read_after_update + 'admin'/'approver' words in goal → admin/approver actor.
465:    - read_after_create/read_after_update + 'invitee'/'accept' words → invitee actor.
466:    - Default → actors[0].
467:    """
468:    if not actors:
469:        return "primary"
470:    if len(actors) == 1:
471:        return actors[0]["id"]
472:    haystack = _combined(goal)
473:    if stage in {"update", "read_after_update"} and APPROVER_WORDS.search(haystack):
474:        # Find admin/approver actor
475:        for a in actors:
476:            if a["id"] in {"admin", "approver", "reviewer"}:
477:                return a["id"]
478:    if stage in {"read_after_create"} and INVITEE_WORDS.search(haystack):
479:        for a in actors:
480:            if a["id"] in {"invitee", "collaborator", "member"}:
481:                return a["id"]
482:    return actors[0]["id"]
