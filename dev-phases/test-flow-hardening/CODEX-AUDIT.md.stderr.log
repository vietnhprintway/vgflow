1074:184:
1075:185:def scan_surfaces(root: Path, max_files: int = 1200) -> dict[str, Any]:
1076:186:    routes: dict[str, dict[str, Any]] = {}
1077:187:    mutations: list[dict[str, str]] = []
1078:188:    forms: list[dict[str, str]] = []
1079:189:    selector_files = 0
1080:190:
1081:191:    source_files = iter_source_files(root, max_files)
1082:192:    for path in source_files:
1083:193:        text = read(path)
1084:194:        rel = str(path.relative_to(root)) if path.is_relative_to(root) else str(path)
1085:195:        if TESTID_RE.search(text):
1086:196:            selector_files += 1
1087:197:        if FORM_RE.search(text):
1088:198:            forms.append({"file": rel, "hint": "form or form-library usage detected"})
1089:199:        if MUTATION_RE.search(text):
1090:200:            mutations.append({"file": rel, "hint": "mutation verb or method detected"})
1091:201:        for match in ROUTE_RE.finditer(text):
1092:202:            route = next((g for g in match.groups() if g), "")
1093:203:            if not route or route.startswith(("//", "http://", "https://")):
1094:204:                continue
1095:205:            item = routes.setdefault(route, {"route": route, "files": []})
1096:206:            if rel not in item["files"]:
1097:207:                item["files"].append(rel)
1098:208:
1099:209:    return {
1100:210:        "routes": sorted(routes.values(), key=lambda item: item["route"])[:300],
1101:211:        "forms": forms[:300],
1102:212:        "mutations": mutations[:300],
1103:213:        "selector_files": selector_files,
1104:214:        "files_scanned": len(source_files),
1105:215:    }
