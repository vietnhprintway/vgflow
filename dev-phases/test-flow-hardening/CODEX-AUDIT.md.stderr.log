62:def _collect_variants(goal_id: str, goal_spec: dict) -> list[dict]:
63:    """Batch 56: flatten edge_cases + negative_specs to variant rows.
64:
65:    Returns list of dicts shaped:
66:      { variant_id, kind, label, input_hint, expected, source,
67:        priority, idempotent }
68:
69:    variant_id format matches _render_edge_case_md + generate-seed-recipes:
70:      - edge cases: {goal_id}-{kind_letter}{idx}
71:      - negative:   {goal_id}-n{idx}
72:    """
73:    out: list[dict] = []
74:    title = goal_spec.get("title") or goal_id
75:    for idx, ec in enumerate(goal_spec.get("edge_cases") or [], 1):
76:        if not isinstance(ec, dict):
77:            continue
78:        kind = ec.get("kind") or "unknown"
79:        letter = (kind[:1].lower() or "x")
80:        out.append({
81:            "variant_id": f"{goal_id}-{letter}{idx}",
82:            "goal_id": goal_id,
83:            "goal_title": title,
84:            "kind": kind,
85:            "label": ec.get("label") or kind,
86:            "input_hint": ec.get("input_hint") or "",
87:            "expected": ec.get("expected") or "",
88:            "source": "edge_cases",
89:            "priority": ec.get("priority") or "important",
90:            "idempotent": True,
91:        })
92:    for idx, neg in enumerate(goal_spec.get("negative_specs") or [], 1):
93:        if not isinstance(neg, dict):
94:            continue
95:        kind = neg.get("kind") or "unknown"
96:        out.append({
97:            "variant_id": f"{goal_id}-n{idx}",
98:            "goal_id": goal_id,
99:            "goal_title": title,
100:            "kind": kind,
101:            "label": neg.get("label") or kind,
102:            "input_hint": neg.get("setup") or "",
103:            "expected": (
104:                neg.get("assert")
105:                or (f"HTTP {neg.get('expected_status')}" if neg.get("expected_status") else "")
106:            ),
107:            "source": "negative_specs",
108:            "priority": neg.get("priority") or "important",
109:            "idempotent": kind != "rate_limit_429",
110:        })
111:    return out
