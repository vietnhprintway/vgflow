1014:124:def repo_root_from_phase(phase_dir: Path) -> Path:
1015:125:    env_root = os.environ.get("VG_REPO_ROOT")
1016:126:    if env_root:
1017:127:        return Path(env_root)
1018:128:    try:
1019:129:        return phase_dir.parents[2]
1020:130:    except IndexError:
1021:131:        return Path.cwd()
