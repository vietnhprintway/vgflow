5683:358:def _preconditions(goal: dict[str, Any]) -> list[str]:
5684:359:    """Build preconditions list from goal.dependencies + infra_deps. Fallback to boilerplate."""
5685:360:    deps = goal.get("dependencies") or ""
5686:361:    infra = goal.get("infra_deps") or ""
5687:362:    items: list[str] = []
5688:363:    if deps:
5689:364:        for d in (deps if isinstance(deps, list) else [s.strip() for s in str(deps).replace("\n", ",").split(",")]):
5690:365:            if d and d.lower() not in ("none", "n/a"):
5691:366:                items.append(f"Dependency: {d}")
5692:367:    if infra:
5693:368:        for d in (infra if isinstance(infra, list) else [s.strip() for s in str(infra).replace("\n", ",").split(",")]):
5694:369:            if d:
5695:370:                items.append(f"Infrastructure: {d} available")
5696:371:    return items or list(_PRECOND_BOILERPLATE)
