7401:183:    except json.JSONDecodeError as e:
7402:184:        print(f"⛔ Batch 48 F7: malformed LIFECYCLE-SPECS.json: {e}", file=sys.stderr)
7403:185:        return 1
7404:186:
7405:187:    goals = lifecycle.get("goals") or {}
7406:188:    if not goals:
7407:189:        print(f"ℹ Batch 48 F7: no goals in LIFECYCLE-SPECS — nothing to derive", file=sys.stderr)
7408:190:        return 2
7409:191:
7410:192:    edge_dir = phase_dir / "EDGE-CASES"
7411:193:    edge_dir.mkdir(exist_ok=True)
7412:194:
7413:195:    written = 0
7414:196:    skipped = 0
7415:197:    no_edge = 0
7416:198:    variants_index: dict[str, list[dict]] = {}
7417:199:
7418:200:    for gid, gspec in sorted(goals.items()):
7419:201:        if not isinstance(gspec, dict):
7420:202:            continue
7421:203:        # Batch 56: collect variants for ALL goals (even when md exists).
7422:204:        gv = _collect_variants(gid, gspec)
7423:205:        if gv:
7424:206:            variants_index[gid] = gv
7425:207:        if not gspec.get("edge_cases"):
7426:208:            no_edge += 1
7427:209:            continue
7428:210:        out_path = edge_dir / f"{gid}.md"
7429:211:        if out_path.is_file() and not args.force:
7430:212:            skipped += 1
7431:213:            continue
7432:214:        body = _render_edge_case_md(gid, gspec)
7433:215:        if not body:
7434:216:            no_edge += 1
7435:217:            continue
7436:218:        if args.dry_run:
7437:219:            print(f"  would write: {out_path.relative_to(phase_dir)}")
7438:220:        else:
7439:221:            out_path.write_text(body, encoding="utf-8")
7440:222:        written += 1
7441:223:
7442:224:    # Batch 56: emit VARIANTS.json — machine-readable index for codegen.
7443:225:    variants_path = edge_dir / "VARIANTS.json"
7444:226:    if variants_index and (args.force or not variants_path.is_file()):
7445:227:        variants_doc = {
7446:228:            "phase": args.phase,
7447:229:            "schema_version": "1.0",
7448:230:            "source": "LIFECYCLE-SPECS.json (Batch 37) + derive (Batch 48+56)",
7449:231:            "goals": variants_index,
7450:232:        }
7451:233:        if args.dry_run:
7452:234:            print(f"  would write: {variants_path.relative_to(phase_dir)}")
7453:235:        else:
7454:236:            variants_path.write_text(
7455:237:                json.dumps(variants_doc, ensure_ascii=False, indent=2),
7456:238:                encoding="utf-8",
7457:239:            )
7458:240:        # do not count VARIANTS.json toward `written` (md file count)
7459:241:    variant_count = sum(len(v) for v in variants_index.values())
7460:242:
7461:243:    summary = f"Batch 48 F7: derived {written} EDGE-CASES files"
7462:244:    if skipped:
7463:245:        summary += f", {skipped} skipped (exists; use --force)"
7464:246:    if no_edge:
7465:247:        summary += f", {no_edge} goals had no edge_cases"
7466:248:    if variants_index:
7467:249:        summary += f"; Batch 56: VARIANTS.json with {variant_count} variants across {len(variants_index)} goals"
7468:250:    print(summary)
7469:251:    return 0
