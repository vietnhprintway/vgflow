172:def iter_source_files(root: Path, max_files: int) -> list[Path]:
173:    files: list[Path] = []
174:    for path in root.rglob("*"):
175:        if len(files) >= max_files:
176:            break
177:        if any(part in EXCLUDED_DIRS for part in path.parts):
178:            continue
179:        if not path.is_file() or path.suffix.lower() not in SOURCE_EXTS:
180:            continue
181:        files.append(path)
182:    return files
