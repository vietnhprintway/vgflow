565:def _parse_api_contracts(phase_dir: Path) -> list[dict[str, str]]:
566:    """Parse API-CONTRACTS.md → list of {method, path} dicts."""
567:    contracts_path = phase_dir / "API-CONTRACTS.md"
568:    if not contracts_path.is_file():
569:        return []
570:    text = _read(contracts_path)
571:    return [
572:        {"method": m.group(1), "path": m.group(2)}
573:        for m in ENDPOINT_HEADER_RE.finditer(text)
574:    ]
