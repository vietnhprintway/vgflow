700:def main() -> int:
701:    ap = argparse.ArgumentParser(description=__doc__)
702:    ap.add_argument("--phase-dir", required=True)
703:    ap.add_argument("--threshold", type=int, default=3,
704:                    help="Min elements per view that triggers required enrichment (default 3)")
705:    ap.add_argument("--validate-only", action="store_true",
706:                    help="Exit 1 if any view has elements >= threshold but TEST-GOALS-DISCOVERED has no goals for that view")
707:    ap.add_argument("--merge-recursive", action="store_true",
708:                    help="After writing G-AUTO-* stubs, append G-RECURSE-* stubs from "
709:                         "runs/goals-*.partial.yaml via aggregate_recursive_goals.py "
710:                         "(v2.40 Phase 2b-2.5 back-flow). Existing G-AUTO-* are preserved.")
711:    ap.add_argument("--recurse-mode", choices=["light", "deep", "exhaustive"],
712:                    default="light",
713:                    help="Forwarded to aggregate_recursive_goals.py --mode "
714:                         "(controls per-mode cap on G-RECURSE-* count). Ignored "
715:                         "unless --merge-recursive is set.")
716:    ap.add_argument("--json", action="store_true")
717:    ap.add_argument("--quiet", action="store_true")
718:    args = ap.parse_args()
719:
720:    phase_dir = Path(args.phase_dir).resolve()
721:    if not phase_dir.is_dir():
722:        print(f"\033[38;5;208mPhase dir not found: {phase_dir}\033[0m", file=sys.stderr)
723:        return 2
724:
725:    existing_ids, declared_per_view = load_existing_goals(phase_dir)
726:    rmap = load_runtime_map(phase_dir)
727:    scans = load_scans(phase_dir)
728:
729:    runtime_views = len(rmap.get("views", {}) or {})
730:
731:    all_stubs: list[dict] = []
732:    per_view_stub_count: dict[str, int] = {}
