6052:727:        negs.append({
6053:728:            "kind": "not_found_404",
6054:729:            "label": "GET non-existent resource",
6055:730:            "expected_status": 404,
6056:731:            "setup": "navigate to URL with id that doesn't exist",
6057:732:            "assert": "404 page or empty state; no white-screen",
6058:733:        })
6059:734:    negs.append({
6060:735:        "kind": "rate_limit_429",
6061:736:        "label": "burst traffic triggers rate limit",
6062:737:        "expected_status": 429,
6063:738:        "setup": "issue rapid repeated requests beyond burst limit",
6064:739:        "assert": "429 with Retry-After header; subsequent OK after delay",
6065:740:        "advisory": True,
6066:741:    })
