1108:218:def flatten_fixture_dag(lifecycle: dict[str, Any]) -> dict[str, Any]:
1109:219:    nodes: dict[str, dict[str, Any]] = {}
1110:220:    edges: list[dict[str, str]] = []
1111:221:    for goal_id, spec in (lifecycle.get("goals") or {}).items():
1112:222:        for actor in spec.get("actors") or []:
1113:223:            node_id = f"{goal_id}:{actor.get('id')}"
1114:224:            nodes[node_id] = {
1115:225:                "id": node_id,
1116:226:                "goal": goal_id,
1117:227:                "kind": "actor",
1118:228:                "role": actor.get("role"),
1119:229:                "session": actor.get("session"),
1120:230:                "cleanup": "revoke session/token when test owns it",
1121:231:            }
1122:232:        for fixture in spec.get("fixture_dag") or []:
1123:233:            fixture_id = f"{goal_id}:{fixture.get('id')}"
1124:234:            nodes[fixture_id] = {
1125:235:                "id": fixture_id,
1126:236:                "goal": goal_id,
1127:237:                "kind": fixture.get("kind"),
1128:238:                "cleanup": fixture.get("cleanup"),
1129:239:            }
1130:240:            for dep in fixture.get("depends_on") or []:
1131:241:                edges.append({"from": f"{goal_id}:{dep}", "to": fixture_id})
1132:242:    return {
1133:243:        "schema_version": "1.0",
1134:244:        "generated_at": datetime.now(timezone.utc).isoformat(),
1135:245:        "nodes": list(nodes.values()),
1136:246:        "edges": edges,
1137:247:    }
