5902:577:def _bind_endpoint(stage: str, goal: dict[str, Any], contracts: list[dict[str, str]]) -> dict[str, str] | None:
5903:578:    """Match stage to a contract endpoint via heuristic on stage verb + goal text."""
5904:579:    if not contracts:
5905:580:        return None
5906:581:    verb_map: dict[str, tuple[str, ...]] = {
5907:582:        "create": ("POST",),
5908:583:        "read_before": ("GET",),
5909:584:        "read_after_create": ("GET",),
5910:585:        "update": ("PUT", "PATCH"),
5911:586:        "read_after_update": ("GET",),
5912:587:        "delete": ("DELETE",),
5913:588:        "read_after_delete": ("GET",),
5914:589:    }
5915:590:    candidates_methods = verb_map.get(stage, ())
5916:591:    if not candidates_methods:
5917:592:        return None
5918:593:    # First: try match in mutation_evidence + dependencies + persistence_check text
5919:594:    haystack = " ".join(str(goal.get(k) or "") for k in
5920:595:                        ("mutation_evidence", "persistence_check", "dependencies", "title"))
5921:596:    for c in contracts:
5922:597:        if c["method"] in candidates_methods and c["path"] in haystack:
5923:598:            return {"method": c["method"], "path": c["path"]}
5924:599:    # Fallback: first contract entry whose method matches
5925:600:    for c in contracts:
5926:601:        if c["method"] in candidates_methods:
5927:602:            return {"method": c["method"], "path": c["path"]}
5928:603:    return None
