752:      --payload "{\"phase\":\"${PHASE_NUMBER}\"}" >/dev/null 2>&1 || true
753:    if [[ ! "${ARGUMENTS:-}" =~ --allow-seed-binding-shortfall ]]; then
754:      echo "⛔ Batch 52 BLOCK: spec variants lack seed binding (runSeedRecipe + cleanup)" >&2
755:      exit 1
756:    fi
757:  fi
758:fi
