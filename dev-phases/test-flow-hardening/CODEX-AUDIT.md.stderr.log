6153:828:def _step(
6154:829:    stage: str,
6155:830:    goal: dict[str, Any],
6156:831:    actor_id: str,
6157:832:    contracts: list[dict[str, str]] | None = None,
6158:833:    decisions: dict[str, dict[str, str]] | None = None,
6159:834:    decision_refs: list[str] | None = None,
