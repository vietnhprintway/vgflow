57:def load_existing_goals(phase_dir: Path) -> tuple[set[str], dict[str, list[str]]]:
58:    """Return (existing_goal_ids, declared_controls_per_view).
59:    declared_controls_per_view maps view→list of declared filter/sort/page names
60:    so we don't regenerate goals for things blueprint already specified.
61:    """
62:    tg_path = phase_dir / "TEST-GOALS.md"
63:    if not tg_path.is_file():
64:        return set(), {}
65:
66:    text = tg_path.read_text(encoding="utf-8", errors="replace")
67:    ids: set[str] = set()
68:    declared: dict[str, list[str]] = {}
69:
70:    try:
71:        import yaml  # type: ignore
72:    except ImportError:
73:        yaml = None  # type: ignore
74:
75:    if yaml is not None:
76:        blocks: list[str] = []
77:        cur: list[str] = []
78:        in_block = False
79:        for line in text.splitlines():
80:            if line.strip() == "---":
81:                if in_block:
82:                    blocks.append("\n".join(cur))
83:                    cur = []
84:                    in_block = False
85:                else:
86:                    in_block = True
87:                continue
88:            if in_block:
89:                cur.append(line)
90:        for blob in blocks:
91:            try:
92:                data = yaml.safe_load(blob) or {}
93:            except Exception:
94:                continue
95:            if not isinstance(data, dict):
96:                continue
97:            gid = str(data.get("id", ""))
98:            if gid:
99:                ids.add(gid)
100:            ic = data.get("interactive_controls") or {}
101:            view_key = str(data.get("maps_to_view") or data.get("view") or "")
102:            if view_key and isinstance(ic, dict):
103:                names = []
104:                for f in ic.get("filters") or []:
105:                    if isinstance(f, dict) and "name" in f:
106:                        names.append(f"filter:{f['name']}")
107:                    elif isinstance(f, str):
108:                        names.append(f"filter:{f}")
109:                if ic.get("pagination"):
110:                    names.append("pagination")
111:                if ic.get("sort"):
112:                    names.append("sort")
113:                declared.setdefault(view_key, []).extend(names)
114:
115:    if not ids:
116:        for m in re.finditer(r"\bG-[A-Z0-9-]+\b", text):
117:            ids.add(m.group(0))
