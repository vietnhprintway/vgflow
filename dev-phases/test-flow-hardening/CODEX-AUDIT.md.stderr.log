90:def _stages_for_goal(goal: dict[str, Any]) -> tuple[str, ...]:
91:    """Derive lifecycle stages.
92:
93:    Dispatch precedence (B62-pre — audit ID-1):
94:      1. goal_class (NEW dispatch key — feature_chain wins over RCRURDR default)
95:      2. goal_type (existing dispatch — backward compatible)
96:      3. HTTP verb inference from mutation_evidence (legacy fallback)
97:
98:    Without B62-pre fix, AI setting goal_class=feature_chain produced no
99:    stage change because pipeline read goal_type only.
100:    """
101:    # B62-pre: goal_class takes priority (feature_chain etc.)
102:    gclass = (goal.get("goal_class") or "").strip().lower()
103:    if gclass in GOAL_CLASS_STAGES:
104:        return GOAL_CLASS_STAGES[gclass]
105:
106:    gtype = (goal.get("goal_type") or "").strip().lower()
107:    # Explicit goal_type mapping takes priority over inference
108:    if gtype in GOAL_TYPE_STAGES:
109:        return GOAL_TYPE_STAGES[gtype]
110:    # Non-empty but unrecognised goal_type (e.g. multi-actor, wizard) → full RCRURDR
111:    # so existing tests and behaviours are not broken by unrecognised types.
112:    if gtype:
113:        return REQUIRED_STAGES
114:    # goal_type absent — infer from HTTP verb hints in mutation_evidence
115:    evidence = " ".join(
116:        str(goal.get(k) or "")
117:        for k in ("mutation_evidence", "persistence_check", "title")
118:    ).upper()
119:    has_post = "POST " in evidence or " POST" in evidence
120:    has_put_patch = "PUT " in evidence or "PATCH " in evidence
121:    has_del = "DELETE " in evidence
122:    if has_post and not has_put_patch and not has_del:
123:        return GOAL_TYPE_STAGES["create-only"]
124:    if has_del and not has_post and not has_put_patch:
125:        return GOAL_TYPE_STAGES["delete-only"]
126:    if has_put_patch and not has_post and not has_del:
127:        return GOAL_TYPE_STAGES["update-only"]
128:    return REQUIRED_STAGES
