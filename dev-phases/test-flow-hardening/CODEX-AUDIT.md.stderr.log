334:        elif family == "library":
335:            file_hint = f"tests/unit/{goal_id.lower().replace('.', '-')}.lifecycle.test"
336:        else:
337:            file_hint = f"tests/lifecycle/{goal_id.lower().replace('.', '-')}.test"
338:        lines.extend(
