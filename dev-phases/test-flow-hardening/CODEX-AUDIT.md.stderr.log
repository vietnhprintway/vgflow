57:# CRUD-SURFACES.md "resource: <name>" or "## <resource>" headings
58:# Per Batch 33 schema. Conservative match — strip leading marker.
59:RESOURCE_RE = re.compile(r"^(?:##\s+|resource:\s+)([\w_-]+)", re.M)
60:# CREATE detection: "method: POST" or fenced JSON with "method": "POST"
61:CREATE_METHOD_RE = re.compile(r'"method"\s*:\s*"POST"|method:\s*POST', re.I)
