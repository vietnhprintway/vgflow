137:def _check_goal_parity(phase_dir: Path) -> tuple[bool, list[str]]:
138:    """Returns (ok, omitted_goal_ids). Goals are 'automatable' unless skipped."""
139:    import re
140:    tg_path = phase_dir / "TEST-GOALS.md"
141:    ls_path = phase_dir / "LIFECYCLE-SPECS.json"
142:    if not tg_path.is_file() or not ls_path.is_file():
143:        return True, []  # nothing to check
144:    automatable_goals: set[str] = set()
145:    body = tg_path.read_text(encoding="utf-8")
146:    for m in re.finditer(r"^##\s+(G-\d+)\b", body, re.M):
147:        gid = m.group(1)
148:        # Find this goal's section
149:        sec_start = m.start()
150:        next_sec = re.search(r"\n##\s+G-\d+\b", body[sec_start + 1:])
151:        sec_end = sec_start + 1 + next_sec.start() if next_sec else len(body)
152:        sec = body[sec_start:sec_end]
153:        if re.search(r"automation:\s*(?:no|skip|deferred)", sec, re.I):
154:            continue
155:        automatable_goals.add(gid)
156:    try:
157:        ls = json.loads(ls_path.read_text(encoding="utf-8"))
158:    except json.JSONDecodeError:
159:        return False, sorted(automatable_goals)
160:    emitted = set(ls.get("goals", {}).keys())
161:    skipped_with_reason: set[str] = set()
162:    for gid, gdata in ls.get("goals", {}).items():
163:        if isinstance(gdata, dict) and (gdata.get("skipped", False) or gdata.get("skip_reason")):
164:            skipped_with_reason.add(gid)
165:    omitted = automatable_goals - emitted - skipped_with_reason
166:    return len(omitted) == 0, sorted(omitted)
