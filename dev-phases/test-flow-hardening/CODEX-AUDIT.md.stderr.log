777:      "test_spec.decision_coverage_failed" --payload "{\"phase\":\"${PHASE_NUMBER}\"}" >/dev/null 2>&1 || true
778:    if [[ ! "${ARGUMENTS:-}" =~ --allow-decision-shortfall ]]; then
779:      exit 1
780:    fi
781:  fi
782:fi
