5639:314:def _infer_actors(goal: dict[str, Any]) -> list[dict[str, Any]]:
5640:315:    text = _combined(goal).lower()
5641:316:    actors: list[dict[str, Any]] = []
5642:317:
5643:318:    def add(actor_id: str, role: str, session: str) -> None:
5644:319:        if not any(actor["id"] == actor_id for actor in actors):
5645:320:            actors.append({
5646:321:                "id": actor_id,
5647:322:                "role": role,
5648:323:                "session": session,
5649:324:                "permissions": [f"least privilege required for {role} path"],
5650:325:            })
5651:326:
5652:327:    if "admin" in text:
5653:328:        add("admin", "admin", "admin_session")
5654:329:    if "owner" in text:
5655:330:        add("owner_actor", "resource_owner", "owner_session")
5656:331:    if INVITEE_WORDS.search(text):
5657:332:        add("invitee", "invitee", "invitee_session")
5658:333:    if "approver" in text or "approve" in text:
5659:334:        add("approver", "approver", "approver_session")
5660:335:    if "reviewer" in text or "review" in text:
5661:336:        add("reviewer", "reviewer", "reviewer_session")
5662:337:    if any(word in text for word in ("collaborator", "member")):
5663:338:        add("secondary_actor", "secondary_user", "secondary_session")
5664:339:    if "external system" in text or "oauth" in text or "webhook" in text:
5665:340:        add("external_actor", "external_system_or_webhook", "signed_callback_context")
5666:341:
5667:342:    if not actors:
5668:343:        add("system_actor", "system", "authenticated or service context required by TEST-GOALS")
5669:344:    elif _is_multi_actor(goal) and len(actors) == 1:
5670:345:        add("secondary_actor", "secondary_user_or_external_system", "secondary_session")
5671:346:    return actors
