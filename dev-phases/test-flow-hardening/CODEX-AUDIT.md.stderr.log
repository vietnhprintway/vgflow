107:def _parse_goals_with_chains(text: str) -> list[dict]:
108:    """Return list of {id, goal_class, chain_steps} dicts."""
109:    goals: list[dict] = []
110:    headings = list(GOAL_HEADING_RE.finditer(text))
111:    for i, m in enumerate(headings):
112:        gid = m.group(1)
113:        start = m.end()
114:        end = headings[i + 1].start() if i + 1 < len(headings) else len(text)
115:        block = text[start:end]
116:        gc_match = GOAL_CLASS_FIELD_RE.search(block)
117:        goal_class = (gc_match.group(1) if gc_match else "").lower()
118:        # chain_steps parse — coarse YAML-ish step extraction
119:        steps: list[dict] = []
120:        step_block_m = CHAIN_STEPS_BLOCK_RE.search(block)
121:        if step_block_m:
122:            step_text = step_block_m.group(1)
123:            # split per step (each starts with "- step_id:")
124:            step_starts = list(STEP_ITEM_RE.finditer(step_text))
125:            for j, s_m in enumerate(step_starts):
126:                s_start = s_m.start()
127:                s_end = step_starts[j + 1].start() if j + 1 < len(step_starts) else len(step_text)
128:                s_block = step_text[s_start:s_end]
129:                es = EXPECTED_STATE_RE.search(s_block)
130:                tv = TARGET_VIEW_CLASS_RE.search(s_block)
131:                de_m = DOWNSTREAM_EFFECTS_BLOCK_RE.search(s_block)
132:                de_lines = []
133:                if de_m:
134:                    de_lines = [
135:                        ln.strip()[2:].strip()
136:                        for ln in de_m.group(1).split("\n")
137:                        if ln.strip().startswith("-")
138:                    ]
139:                steps.append({
140:                    "step_id": s_m.group(1),
141:                    "expected_state": (es.group(1) if es else "").strip().strip('"\''),
142:                    "target_view_class": (tv.group(1) if tv else "").strip().strip('"\''),
143:                    "downstream_effects": de_lines,
144:                })
145:        goals.append({
146:            "id": gid,
147:            "goal_class": goal_class,
148:            "chain_steps": steps,
149:        })
150:    return goals
