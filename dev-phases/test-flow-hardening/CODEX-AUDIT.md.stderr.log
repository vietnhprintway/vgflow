925:def _goal_spec(
926:    goal: dict[str, Any],
927:    contracts: list[dict[str, str]] | None = None,
928:    decisions: dict[str, dict[str, str]] | None = None,
929:) -> dict[str, Any]:
930:    # G4: use explicit metadata-aware actor inference
931:    actors = _infer_actors_v2(goal)
932:    fixture_dag = _fixture_dag(goal, actors)
933:    _contracts = contracts or []
934:    _decisions = decisions or {}
935:    decision_refs = _goal_decision_refs(goal, _decisions)
936:    return {
937:        "title": goal["title"],
938:        "priority": goal.get("priority") or "important",
939:        "goal_type": goal.get("goal_type") or ("multi-actor" if _is_multi_actor(goal) else "mutation"),
940:        "surface": goal.get("surface") or "unknown",
941:        "source_goal": goal.get("source"),
942:        "primary_endpoints": _extract_endpoints(goal),
943:        "source_assertions": {
944:            "success_criteria": goal.get("success_criteria") or "",
945:            "mutation_evidence": goal.get("mutation_evidence") or "",
946:            "persistence_check": goal.get("persistence_check") or "",
947:            "dependencies": goal.get("dependencies") or "",
948:            "infra_deps": goal.get("infra_deps") or "",
949:        },
950:        "actors": actors,
951:        "fixture_dag": fixture_dag,
952:        # G1: preconditions derived from goal.dependencies + infra_deps
953:        "preconditions": _preconditions(goal),
954:        "decision_refs": decision_refs,
955:        "steps": [
956:            _step(stage, goal, _stage_actor(stage, goal, actors), _contracts, _decisions, decision_refs)
957:            for stage in _stages_for_goal(goal)
958:        ],
959:        # G6: artifact_capture reflects goal.artifact_kind
960:        "artifact_capture": _artifact_capture_v2(goal),
961:        # Batch 37 F3: first-class edge case variants per goal
962:        "edge_cases": _derive_edge_cases(goal),
963:        # Batch 37 F4: first-class negative path variants per goal
964:        "negative_specs": _derive_negative_specs(goal),
965:        "cleanup": [
966:            {"target": fixture["id"], "action": fixture["cleanup"]}
967:            for fixture in reversed(fixture_dag)
968:        ],
969:        "generator_note": "Generated from phase docs; executable tests must bind TS-XX to this goal and implement these steps. Edge cases + negative specs MUST be rendered as test.each([...]) variants.",
970:    }
