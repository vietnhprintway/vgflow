298:            "- Mutation goals require read-before, create, read-after-create, update, read-after-update, delete, read-after-delete evidence.",
299:            "- `TEST-EXECUTION-PLAN.json` selects runner family per phase profile; do not force Playwright for mobile, CLI, backend, or library phases.",
300:        ]
301:    )
302:    return "\n".join(lines).rstrip() + "\n"
