8182:700:def main() -> int:
8183:701:    ap = argparse.ArgumentParser(description=__doc__)
8184:702:    ap.add_argument("--phase-dir", required=True)
8185:703:    ap.add_argument("--threshold", type=int, default=3,
8186:704:                    help="Min elements per view that triggers required enrichment (default 3)")
8187:705:    ap.add_argument("--validate-only", action="store_true",
8188:706:                    help="Exit 1 if any view has elements >= threshold but TEST-GOALS-DISCOVERED has no goals for that view")
8189:707:    ap.add_argument("--merge-recursive", action="store_true",
8190:708:                    help="After writing G-AUTO-* stubs, append G-RECURSE-* stubs from "
8191:709:                         "runs/goals-*.partial.yaml via aggregate_recursive_goals.py "
8192:710:                         "(v2.40 Phase 2b-2.5 back-flow). Existing G-AUTO-* are preserved.")
8193:711:    ap.add_argument("--recurse-mode", choices=["light", "deep", "exhaustive"],
8194:712:                    default="light",
8195:713:                    help="Forwarded to aggregate_recursive_goals.py --mode "
8196:714:                         "(controls per-mode cap on G-RECURSE-* count). Ignored "
8197:715:                         "unless --merge-recursive is set.")
8198:716:    ap.add_argument("--json", action="store_true")
8199:717:    ap.add_argument("--quiet", action="store_true")
8200:718:    args = ap.parse_args()
8201:719:
8202:720:    phase_dir = Path(args.phase_dir).resolve()
8203:721:    if not phase_dir.is_dir():
8204:722:        print(f"\033[38;5;208mPhase dir not found: {phase_dir}\033[0m", file=sys.stderr)
