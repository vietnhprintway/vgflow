10903:43:def _parse_crud_resources(phase_dir: Path) -> set[str]:
10904:44:    surfaces = phase_dir / "CRUD-SURFACES.md"
10905:45:    if surfaces.is_file():
10906:46:        text = surfaces.read_text(encoding="utf-8", errors="replace")
10907:47:    else:
10908:48:        sd = phase_dir / "CRUD-SURFACES"
10909:49:        if not sd.is_dir():
10910:50:            return set()
10911:51:        text = "\n".join(p.read_text(encoding="utf-8", errors="replace")
10912:52:                          for p in sd.glob("*.md"))
10913:53:    resources: set[str] = set()
10914:54:    last_r: str | None = None
10915:55:    last_start = 0
10916:56:    chunks: list[tuple[str, str]] = []
10917:57:    for m in RESOURCE_RE.finditer(text):
10918:58:        if last_r is not None:
10919:59:            chunks.append((last_r, text[last_start:m.start()]))
10920:60:        last_r = m.group(1)
10921:61:        last_start = m.end()
10922:62:    if last_r is not None:
10923:63:        chunks.append((last_r, text[last_start:]))
10924:64:    for resource, block in chunks:
10925:65:        if CREATE_METHOD_RE.search(block):
10926:66:            resources.add(resource)
10927:67:    return resources
