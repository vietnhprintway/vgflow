3000:1145:- Total goals: {N}
3001:1146:- READY: {N}
3002:1147:- BLOCKED: {N}
3003:1148:- NOT_SCANNED: {N} (intermediate)
3004:1149:- UNREACHABLE: {N}
3005:1150:- INFRA_PENDING: {N}
3006:1151:- FAILED: {N} (intermediate)
3007:1152:
