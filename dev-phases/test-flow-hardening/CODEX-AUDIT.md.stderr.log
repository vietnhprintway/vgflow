954:64:      (?:app|router|route|server)\.(?:get|post|put|patch|delete)\s*\(\s*['"](?P<api1>/[^'"]+)['"]
955:65:      |
956:66:      @(?:app|router)\.(?:get|post|put|patch|delete)\s*\(\s*['"](?P<api2>/[^'"]+)['"]
957:67:      |
958:68:      path\s*[:=]\s*['"](?P<path>/[^'"]+)['"]
959:69:      |
960:70:      href\s*=\s*['"](?P<href>/[^'"]+)['"]
961:71:      |
962:72:      to\s*=\s*['"](?P<to>/[^'"]+)['"]
963:73:    )
