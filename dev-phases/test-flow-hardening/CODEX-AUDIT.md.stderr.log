8012:530:        severity = (finding.get("severity") or "").lower()
8013:531:        if severity not in ("critical", "serious"):
8014:532:            continue
8015:533:        rule = (finding.get("rule") or "").strip()
8016:534:        if not rule or rule in a11y_seen:
8017:535:            continue
8018:536:        a11y_seen.add(rule)
8019:537:        selector = finding.get("selector") or ""
8020:538:        stubs.append({
