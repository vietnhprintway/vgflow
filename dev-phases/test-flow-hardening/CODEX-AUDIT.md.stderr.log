189:def _field(body: str, name: str) -> str:
190:    patterns = (
191:        rf"^\*\*{re.escape(name)}:\*\*\s*(.+?)(?=^\*\*|\n##|\n#\s+G-|\Z)",
192:        rf"^{re.escape(name)}:\s*(.+?)(?=^\w[\w -]*:|\n##|\n#\s+G-|\Z)",
193:        rf"^###\s+{re.escape(name)}\s*\n(.+?)(?=^###\s+|\n##\s+|\n#\s+|\Z)",
194:    )
195:    for pattern in patterns:
196:        match = re.search(pattern, body, re.MULTILINE | re.DOTALL | re.IGNORECASE)
197:        if match:
198:            return match.group(1).strip()
199:    return ""
