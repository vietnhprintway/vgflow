5890:565:def _parse_api_contracts(phase_dir: Path) -> list[dict[str, str]]:
5891:566:    """Parse API-CONTRACTS.md → list of {method, path} dicts."""
5892:567:    contracts_path = phase_dir / "API-CONTRACTS.md"
5893:568:    if not contracts_path.is_file():
5894:569:        return []
5895:570:    text = _read(contracts_path)
5896:571:    return [
5897:572:        {"method": m.group(1), "path": m.group(2)}
