3024:1169:### 4d: Inline triage + apply scope-tag actions (v1.14.0+ A.2)
3025:1170:
3026:1171:Triage chạy **inline** ngay sau matrix ghi, TRƯỚC 100% gate. Mục đích: đọc scope tag (`depends_on_phase`, `verification_strategy`) từ CONTEXT.md, phân loại mỗi UNREACHABLE thành verdict + action_required, rồi áp dụng action nào autonomous được (mark_deferred/mark_manual). Các action cần người quyết định (spawn_fix_agent, draft_amendment_ask, prompt_scope_tag) sẽ ghi vào hàng đợi nhưng vẫn BLOCK gate — **không có đường thoát ngụỵ trang**.
3027:1172:
3028:1173:```bash
3029:1174:session_mark_step "4d-inline-triage"
3030:1175:echo ""
3031:1176:echo "🔍 Triage + áp dụng action cho UNREACHABLE goals (v1.14.0+)..."
3032:1177:
3033:1178:# v1.14.3 H3 — pre-scan test source for @deferred markers so triage sees them
3034:1179:# alongside scope tags. Fixes gap where executor-written it.skip('@deferred X')
3035:1180:# was ignored (tests were skipped but matrix still BLOCKED).
3036:1181:DEFER_SCANNER="${VG_SCRIPT_ROOT:-${VG_HOME:-$HOME/.vgflow}/scripts}/scan-deferred-tests.py"
3037:1182:if [ -f "$DEFER_SCANNER" ]; then
3038:1183:  echo "▸ Pre-scan: @deferred markers in test source..."
3039:1184:  ${PYTHON_BIN:-python3} "$DEFER_SCANNER" \
3040:1185:    --phase-dir "${PHASE_DIR}" --repo-root "${REPO_ROOT:-.}" 2>&1 | tail -12 || true
3041:1186:  # Writes .deferred-tests.json — consumed by unreachable-triage below
3042:1187:fi
3043:1188:
3044:1189:# Chạy triage (sinh .unreachable-triage.json + UNREACHABLE-TRIAGE.md)
3045:1190:source "${VG_COMMAND_ROOT:-${VG_HOME:-$HOME/.vgflow}/commands/vg}/_shared/lib/unreachable-triage.sh" 2>/dev/null || true
3046:1191:if type -t triage_unreachable_goals >/dev/null 2>&1; then
3047:1192:  triage_unreachable_goals "$PHASE_DIR" "$PHASE_NUMBER"
3048:1193:else
3049:1194:  echo "⚠ unreachable-triage.sh missing — triage bị bỏ qua, 100% gate sẽ hard-block mọi UNREACHABLE." >&2
3050:1195:fi
3051:1196:
3052:1197:TRIAGE_JSON="${PHASE_DIR}/.unreachable-triage.json"
3053:1198:MATRIX="${PHASE_DIR}/GOAL-COVERAGE-MATRIX.md"
3054:1199:
3055:1200:if [ -f "$TRIAGE_JSON" ] && [ -f "$MATRIX" ]; then
3056:1201:  # Áp dụng action_required autonomous: mark_deferred, mark_manual
3057:1202:  # Những action còn lại (spawn_fix_agent, draft_amendment_ask, prompt_scope_tag) ghi log + để BLOCK.
3058:1203:  PYTHONIOENCODING=utf-8 ${PYTHON_BIN} - "$TRIAGE_JSON" "$MATRIX" "$PHASE_DIR" "$PHASE_NUMBER" <<'PY'
3059:1204:import json, sys, re
3060:1205:from pathlib import Path
3061:1206:from datetime import datetime, timezone
3062:1207:
3063:1208:triage_path = Path(sys.argv[1])
3064:1209:matrix_path = Path(sys.argv[2])
3065:1210:phase_dir   = Path(sys.argv[3])
3066:1211:phase_num   = sys.argv[4]
3067:1212:
3068:1213:try:
3069:1214:    triage = json.loads(triage_path.read_text(encoding="utf-8"))
3070:1215:except Exception as e:
3071:1216:    print(f"⚠ Không đọc được triage JSON: {e}")
3072:1217:    sys.exit(0)
3073:1218:
3074:1219:verdicts = triage.get("verdicts", {})
3075:1220:
3076:1221:# v1.14.3 H3 — merge .deferred-tests.json as additional deferral source
3077:1222:# (test files with it.skip('@deferred X') markers that aren't in CONTEXT.md scope tags).
3078:1223:deferred_tests_path = phase_dir / ".deferred-tests.json"
3079:1224:test_deferrals = {}  # ts_id → {reason, kind}
3080:1225:if deferred_tests_path.exists():
3081:1226:    try:
3082:1227:        dt = json.loads(deferred_tests_path.read_text(encoding="utf-8"))
3083:1228:        for entry in dt.get("deferred_tests", []):
3084:1229:            ts = entry.get("ts_id")
3085:1230:            if ts:
3086:1231:                test_deferrals[ts] = entry
3087:1232:    except Exception as e:
3088:1233:        print(f"⚠ Không đọc được .deferred-tests.json: {e}")
3089:1234:
3090:1235:if not verdicts and not test_deferrals:
3091:1236:    print("ℹ Không có UNREACHABLE cần triage — skip.")
3092:1237:    sys.exit(0)
3093:1238:
3094:1239:matrix_text = matrix_path.read_text(encoding="utf-8")
3095:1240:pending_queue = []   # cho các action chờ user / destructive
3096:1241:applied       = {"mark_deferred": [], "mark_manual": [], "pending": []}
3097:1242:
3098:1243:def update_status_in_matrix(text, gid, new_status, note=""):
3099:1244:    # Tìm dòng trong ## Goal Details có `| G-XX | ... | UNREACHABLE | ... |`
3100:1245:    # Thay UNREACHABLE → new_status; append note vào evidence nếu có.
3101:1246:    pat = re.compile(r'^(\| *' + re.escape(gid) + r' *\|[^|]*\|[^|]*\|) *UNREACHABLE *(\|[^\n]*)', re.M)
3102:1247:    def _repl(m):
3103:1248:        prefix = m.group(1)
3104:1249:        suffix = m.group(2)
3105:1250:        if note:
3106:1251:            suffix = suffix.rstrip("|").rstrip() + f" ({note})|"
3107:1252:        return f"{prefix} {new_status} {suffix}"
3108:1253:    return pat.sub(_repl, text, count=1)
3109:1254:
3110:1255:for gid, v in verdicts.items():
3111:1256:    action   = v.get("action_required")
3112:1257:    params   = v.get("action_params", {})
3113:1258:    verdict  = v.get("verdict", "")
3114:1259:
3115:1260:    if action == "mark_deferred":
3116:1261:        target = params.get("target_phase", "?")
3117:1262:        matrix_text = update_status_in_matrix(matrix_text, gid, "DEFERRED", f"depends_on_phase: {target}")
3118:1263:        applied["mark_deferred"].append((gid, target))
3119:1264:    elif action == "mark_manual":
3120:1265:        strat = params.get("strategy", "manual")
3121:1266:        matrix_text = update_status_in_matrix(matrix_text, gid, "MANUAL", f"verification: {strat}")
3122:1267:        applied["mark_manual"].append((gid, strat))
3123:1268:    elif action in ("spawn_fix_agent", "draft_amendment_ask", "prompt_scope_tag"):
3124:1269:        # Giữ UNREACHABLE — gate sẽ block; ghi vào pending queue
3125:1270:        pending_queue.append({
3126:1271:            "phase":   phase_num,
3127:1272:            "goal_id": gid,
3128:1273:            "verdict": verdict,
3129:1274:            "action":  action,
3130:1275:            "params":  params,
3131:1276:            "title":   v.get("title", "(no title)"),
3132:1277:            "queued_at": datetime.now(timezone.utc).isoformat(),
3133:1278:        })
3134:1279:        applied["pending"].append((gid, action))
3135:1280:
3136:1281:# v1.14.3 H3 — apply test-level deferrals (fills gap where scope tags missing
3137:1282:# but test source has it.skip('@deferred X')). Status depends on defer_kind:
3138:1283:#   depends_on_phase + test-codegen → DEFERRED
3139:1284:#   manual + faketime               → MANUAL
3140:1285:#   unknown                         → log as pending, leave as UNREACHABLE
3141:1286:for ts_id, entry in test_deferrals.items():
3142:1287:    # ts_id is "TS-XX"; matrix may have goal_ids like "TS-16" or "G-XX" — try TS- first
3143:1288:    gid = ts_id
3144:1289:    kind = entry.get("defer_kind", "unknown")
3145:1290:    reason = entry.get("defer_reason", "")
3146:1291:    if kind in ("depends_on_phase", "test-codegen"):
3147:1292:        matrix_text = update_status_in_matrix(
3148:1293:            matrix_text, gid, "DEFERRED",
3149:1294:            f"test.skip @deferred: {reason[:50]}",
3150:1295:        )
3151:1296:        applied["mark_deferred"].append((gid, f"test-marker:{kind}"))
3152:1297:    elif kind in ("manual", "faketime"):
3153:1298:        matrix_text = update_status_in_matrix(
3154:1299:            matrix_text, gid, "MANUAL",
3155:1300:            f"test.skip @deferred: {reason[:50]}",
3156:1301:        )
3157:1302:        applied["mark_manual"].append((gid, kind))
3158:1303:    else:
3159:1304:        pending_queue.append({
3160:1305:            "phase":   phase_num,
3161:1306:            "goal_id": gid,
3162:1307:            "verdict": "test-level @deferred with unknown kind",
3163:1308:            "action":  "review_test_defer_reason",
3164:1309:            "params":  {"reason": reason, "source": entry.get("source_file", "")},
3165:1310:            "title":   entry.get("test_title", ""),
3166:1311:            "queued_at": datetime.now(timezone.utc).isoformat(),
3167:1312:        })
3168:1313:        applied["pending"].append((gid, "test-defer-unknown"))
3169:1314:
3170:1315:# Re-sync header counts trong "## Summary" block nếu có thay đổi
3171:1316:def recount_summary(text):
3172:1317:    details = re.search(r'^## Goal Details\s*\n(.*?)(?=^\s*## |\Z)', text, re.M|re.S)
3173:1318:    if not details:
3174:1319:        return text
3175:1320:    body = details.group(1)
3176:1321:    counts = {"READY":0, "BLOCKED":0, "UNREACHABLE":0, "INFRA_PENDING":0,
3177:1322:              "DEFERRED":0, "MANUAL":0, "NOT_SCANNED":0, "FAILED":0}
3178:1323:    for line in body.splitlines():
3179:1324:        for k in counts:
3180:1325:            # Status cell đứng giữa 2 dấu | — tránh match keyword trong evidence
3181:1326:            if re.search(r'\|\s*' + k + r'\s*\|', line):
3182:1327:                counts[k] += 1
3183:1328:                break
3184:1329:    def _rewrite_summary(m):
3185:1330:        total = sum(counts.values())
3186:1331:        new = [
3187:1332:            "## Summary",
3188:1333:            f"- Total goals: {total}",
