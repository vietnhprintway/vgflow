1062:172:def iter_source_files(root: Path, max_files: int) -> list[Path]:
1063:173:    files: list[Path] = []
1064:174:    for path in root.rglob("*"):
1065:175:        if len(files) >= max_files:
1066:176:            break
1067:177:        if any(part in EXCLUDED_DIRS for part in path.parts):
1068:178:            continue
1069:179:        if not path.is_file() or path.suffix.lower() not in SOURCE_EXTS:
1070:180:            continue
1071:181:        files.append(path)
1072:182:    return files
