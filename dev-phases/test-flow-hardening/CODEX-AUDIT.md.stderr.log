202:def _parse_goal_block(text: str, source: Path) -> dict[str, Any] | None:
203:    heading = re.search(r"^#\s+(G-[\w.-]+):?\s*(.+)$", text, re.MULTILINE)
204:    if not heading:
205:        heading = re.search(
206:            r"^##\s+(?:Goal\s+)?(G-[\w.-]+):?\s*(.+)$",
207:            text,
208:            re.MULTILINE,
209:        )
210:    if not heading:
211:        return None
212:    goal_id = heading.group(1).strip()
213:    title = heading.group(2).strip()
214:    return {
215:        "id": goal_id,
216:        "title": title,
217:        "body": text,
218:        "goal_type": _field(text, "goal_type").lower(),
219:        "goal_class": _field(text, "goal_class").lower(),
220:        "surface": _field(text, "Surface").lower(),
221:        "priority": _field(text, "Priority").lower(),
222:        "success_criteria": _field(text, "Success criteria"),
223:        "mutation_evidence": _field(text, "Mutation evidence"),
224:        "persistence_check": _field(text, "Persistence check"),
225:        "dependencies": _field(text, "Dependencies"),
226:        "infra_deps": _field(text, "Infra deps"),
227:        # G4: explicit actors metadata
228:        "actors": _field(text, "actors") or _field(text, "actor"),
229:        # G6: artifact_kind field
230:        "artifact_kind": _field(text, "artifact_kind"),
