5703:378:def _infer_actors_v2(goal: dict[str, Any]) -> list[dict[str, Any]]:
5704:379:    """Read explicit actors metadata first; fall back to word-match heuristic."""
5705:380:    explicit = None
5706:381:    for k in ACTOR_METADATA_KEYS:
5707:382:        v = goal.get(k)
5708:383:        if v:
5709:384:            explicit = v
5710:385:            break
5711:386:    if explicit:
5712:387:        # parse comma-separated list or list-of-strings
5713:388:        if isinstance(explicit, list):
5714:389:            items = [str(x).strip() for x in explicit if str(x).strip()]
5715:390:        else:
5716:391:            items = [s.strip() for s in str(explicit).split(",") if s.strip()]
5717:392:        actors = []
5718:393:        seen: set[str] = set()
5719:394:        for item in items:
5720:395:            aid = item.lower().replace(" ", "_")
5721:396:            if aid in seen:
5722:397:                continue
5723:398:            seen.add(aid)
5724:399:            actors.append({"id": aid, "role": item, "session": f"{aid}_session",
5725:400:                           "permissions": [f"least privilege required for {item} path"]})
5726:401:        if actors:
5727:402:            return actors
5728:403:    # Fallback to existing _infer_actors() word-match
5729:404:    return _infer_actors(goal)
