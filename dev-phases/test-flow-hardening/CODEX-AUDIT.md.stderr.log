828:def _step(
829:    stage: str,
830:    goal: dict[str, Any],
831:    actor_id: str,
832:    contracts: list[dict[str, str]] | None = None,
833:    decisions: dict[str, dict[str, str]] | None = None,
834:    decision_refs: list[str] | None = None,
835:) -> dict[str, Any]:
836:    title = goal["title"]
837:    mutation_evidence = goal.get("mutation_evidence") or "created resource id, state transition, response envelope, or emitted event from TEST-GOALS"
838:    persistence = goal.get("persistence_check") or "fresh read must prove persisted state, derived state, permissions, and absence of stale cached data"
839:    criteria = goal.get("success_criteria") or title
840:    actions = {
841:        "read_before": _read_before_action(goal),
842:        "create": f"Execute primary API/UI action from TEST-GOALS; capture mutation evidence: {mutation_evidence}",
843:        "read_after_create": f"Re-read from a fresh request/session; assert create effect persisted. Persistence check: {persistence}",
844:        "update": "Mutate the created resource again, exercise status transition, retry/idempotency, role switch, or configured update path.",
845:        "read_after_update": f"Re-read from a clean context and assert updated fields, derived state, events, permissions, or view state. Re-apply goal assertions: {criteria}",
846:        "delete": "Cleanup by delete, revoke, cancel, deactivate, rollback fixture, or restore original view/config state.",
847:        "read_after_delete": "Re-read active list/detail and assert no active test-owned resource remains; audit row may remain if required.",
848:        # Batch 36 R2: read-only stages for display/list/dashboard/filter goals
849:        "render_initial": f"Navigate to the page; assert layout renders, no console errors, key elements visible. Acceptance: {criteria}",
850:        "interaction_filter": "Apply filter control (dropdown/text/date/select); assert URL updates with filter param, list re-renders with subset, filter state persists on refresh.",
851:        "interaction_sort": "Click sort header (asc + desc); assert order changes, URL persists sort key+dir, multi-column sort respects priority.",
852:        "interaction_paginate": "Navigate next/prev/last/first/jump-to-page; assert URL page param updates, deep-link works (paste URL → correct page), out-of-range clamps gracefully.",
853:        "empty_state": "Filter/search to zero-result state; assert friendly empty UI (illustration/message), no error console, CTA visible if applicable.",
854:        "error_state_4xx": "Trigger 4xx/5xx response (invalid filter, unauthorized, server down); assert user-facing error message, no white-screen, retry CTA where applicable.",
855:        "loading_state": "Throttle network; assert skeleton/spinner shown during fetch, replaced by content on resolve, no layout shift after replace.",
856:        "accessibility": "Tab through interactive controls; assert focus visible, ARIA labels on inputs, screen-reader announcements for state changes, color contrast ≥4.5:1 on text.",
857:    }
858:    evidence = {
859:        "read_before": ["response envelope", "DB/query snapshot", "no stale fixture collision"],
860:        "create": ["2xx response or expected 4xx", "correlation/request id", "created resource id or emitted event id"],
861:        "read_after_create": ["fresh read response", "DB persisted fields", "audit/outbox row when applicable"],
862:        "update": ["2xx/expected 4xx response", "version/idempotency behavior", "actor authorization result"],
863:        # Batch 36 R2: read-only stage evidence
864:        "render_initial": ["screenshot", "console messages (zero errors)", "key element snapshot"],
865:        "interaction_filter": ["URL after filter applied", "filtered row count", "filter state in DOM"],
866:        "interaction_sort": ["URL with sort param", "first/last row id post-sort", "ARIA sort indicator"],
867:        "interaction_paginate": ["URL page param", "current page indicator", "row count per page"],
868:        "empty_state": ["empty UI screenshot", "console (no errors)", "empty-state DOM signature"],
869:        "error_state_4xx": ["error UI screenshot", "console message text", "HTTP response captured"],
870:        "loading_state": ["skeleton DOM snapshot", "network throttled response time", "post-resolve content"],
871:        "accessibility": ["axe-core findings", "keyboard nav trace", "screen-reader transcript"],
872:        "read_after_update": ["fresh read response", "event/webhook/queue capture when applicable", "no cross-tenant leakage"],
873:        "delete": ["cleanup mutation response or fixture cleanup receipt", "audit reason", "session/job/resource cleanup marker"],
874:        "read_after_delete": ["404/empty active list or terminal status", "revoked sessions/jobs", "cleanup confirmation"],
875:    }
876:    endpoint = _bind_endpoint(stage, goal, contracts or [])
877:    # G3 Batch 3: override action description with endpoint-binding when available
878:    if endpoint:
879:        actions[stage] = _step_description(stage, goal, endpoint)
880:    # Build assertions from decision_refs + API-CONTRACTS
881:    assertions: list[dict[str, str]] = []
882:    if stage in {"create", "update"}:
883:        for d_id in (decision_refs or []):
884:            d_data = (decisions or {}).get(d_id, {})
885:            ea = d_data.get("expected_assertion", "").strip()
886:            if ea:
887:                assertions.append({"source": d_id, "check": ea})
888:    if endpoint:
889:        assertions.append({
890:            "source": "API-CONTRACTS",
891:            "check": f"{endpoint['method']} {endpoint['path']} returns expected envelope and status",
892:        })
893:    # Batch 36 R3: append acceptance_criteria assertions on key stages.
894:    # Apply criteria to read_after_* + render_initial stages (where user-
895:    # visible behavior is asserted). Skip raw mutation stages to avoid
896:    # double-counting (criteria better verified after persistence).
897:    if stage in {"read_after_create", "read_after_update", "read_after_delete",
898:                 "render_initial", "empty_state", "error_state_4xx",
899:                 "interaction_filter", "interaction_sort", "interaction_paginate"}:
900:        assertions.extend(_criteria_assertions(goal))
901:    return {
902:        "name": stage,
903:        "stage": stage,
904:        "actor": actor_id,
905:        "endpoint": endpoint,
906:        "assertions": assertions,
907:        "action": actions[stage],
908:        "evidence": evidence[stage],
909:    }
