807:def _step_description(stage: str, goal: dict[str, Any], endpoint: dict[str, str] | None) -> str:
808:    """G3 Batch 3: build action description from endpoint binding when available.
809:
810:    When endpoint is bound, embed method + path directly in the description so
811:    codegen has concrete references instead of generic template strings.
812:    Falls back to _DEFAULT_DESCRIPTIONS[stage] when endpoint is absent.
813:    """
814:    if endpoint and endpoint.get("method") and endpoint.get("path"):
815:        method, path = endpoint["method"], endpoint["path"]
816:        if stage == "create":
817:            return f"{method} {path} with sample payload from API-CONTRACTS; assert response status + body."
818:        if stage == "update":
819:            return f"{method} {path} for the created entity; assert update applied."
820:        if stage == "delete":
821:            return f"{method} {path}; assert 204/200 and resource gone."
822:        if stage.startswith("read_"):
823:            state = stage.replace("read_", "").replace("_", " ")
824:            return f"GET {path}; assert {state} state per persistence_check."
825:    return _DEFAULT_DESCRIPTIONS.get(stage, f"Execute {stage} stage.")
