1007:        "phase": phase_dir.name,
1008:        "generated_at": datetime.now(timezone.utc).isoformat(),
1009:        "generator": "generate-lifecycle-specs.py",
1010:        "scope": "Generated closed-loop lifecycle contracts from phase docs. Human/executable tests must implement these contracts.",
1011:        "formula": {
1012:            "selection": "side-effecting or multi-actor goals from TEST-GOALS split files or TEST-GOALS.md",
1013:            "stages": list(REQUIRED_STAGES),
1014:            "minimum_contract": ["actors", "fixture_dag", "preconditions", "steps", "artifact_capture when applicable", "cleanup"],
1015:            "source_artifacts": ["TEST-GOALS/", "TEST-GOALS.md", "API endpoint mentions", "phase context embedded in goal text"],
1016:        },
1017:        "summary": {
1018:            "goals_seen": len(goals),
1019:            "goals_emitted": len(specs),
1020:            "include_readonly": include_readonly,
1021:        },
1022:        # G5 Batch 4: root-level fixture DAG from cross-goal dependencies
1023:        "fixture_dag": _root_fixture_dag(selected),
1024:        "goals": specs,
1025:    }
