5877:552:def _goal_decision_refs(goal: dict[str, Any], decisions: dict[str, dict[str, str]]) -> list[str]:
5878:553:    """Extract D-XX refs from goal text — match against parsed decisions."""
5879:554:    if not decisions:
5880:555:        return []
5881:556:    haystack = _combined(goal)
5882:557:    found: set[str] = set()
5883:558:    for m in DECISION_REF_RE.finditer(haystack):
5884:559:        d_id = m.group(1)
5885:560:        if d_id in decisions:
5886:561:            found.add(d_id)
5887:562:    return sorted(found)
