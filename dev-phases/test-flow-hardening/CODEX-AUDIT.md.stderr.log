45:def _find_phase_dir(phase: str, override: str | None = None) -> Path:
46:    if override:
47:        return Path(override)
48:    for root in (Path(".vg/phases"), Path("dev-phases"), Path("phases")):
49:        if not root.is_dir():
50:            continue
51:        for p in root.iterdir():
52:            if p.is_dir() and (p.name == phase or p.name.startswith(f"{phase}-")):
53:                return p
54:    raise SystemExit(f"phase dir not found for {phase}")
