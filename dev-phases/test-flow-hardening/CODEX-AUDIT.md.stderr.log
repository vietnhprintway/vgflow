5733:408:def _root_fixture_dag(goals_meta: list[dict[str, Any]]) -> dict[str, Any]:
5734:409:    """Build fixture DAG from goal.dependencies field referencing other goal IDs."""
5735:410:    nodes = []
5736:411:    edges = []
5737:412:    for g in goals_meta:
5738:413:        gid = g.get("id") or g.get("goal_id")
5739:414:        if not gid:
5740:415:            continue
5741:416:        nodes.append({"id": gid, "kind": g.get("goal_type", "mutation")})
5742:417:        deps = g.get("dependencies") or ""
5743:418:        deps_text = deps if isinstance(deps, str) else " ".join(str(d) for d in deps)
5744:419:        for m in re.finditer(r"\b(G-\d+)\b", deps_text):
5745:420:            ref = m.group(1)
5746:421:            if ref != gid:
5747:422:                edges.append({"from": gid, "to": ref})
5748:423:    return {"nodes": nodes, "edges": edges}
