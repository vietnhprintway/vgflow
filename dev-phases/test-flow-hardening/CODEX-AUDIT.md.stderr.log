7524:42:def view_slug(view_url: str) -> str:
7525:43:    """Convert URL path to a goal-id-safe slug. /admin/topup-requests → admin-topup-requests"""
7526:44:    s = view_url.strip("/").replace("/", "-")
7527:45:    s = re.sub(r":[a-zA-Z_]+", "id", s)
7528:46:    s = re.sub(r"[^a-zA-Z0-9-]", "-", s)
7529:47:    s = re.sub(r"-+", "-", s).strip("-")
7530:48:    return s or "root"
