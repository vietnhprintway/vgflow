186:def _parse_waivers(phase_dir: Path) -> set[str]:
187:    """CONTEXT.md feature_chain_waiver: <reason>."""
188:    ctx = phase_dir / "CONTEXT.md"
189:    if not ctx.is_file():
190:        return set()
191:    text = ctx.read_text(encoding="utf-8", errors="replace")
192:    # Capture lines like: `feature_chain_waiver[<resource>]: <reason>`
193:    waivers: set[str] = set()
194:    for m in re.finditer(
195:        r"feature_chain_waiver\[?([\w_-]*)\]?\s*:\s*([^\n]+)", text
196:    ):
197:        if m.group(1):
198:            waivers.add(m.group(1))
199:        else:
200:            waivers.add("*")  # global waiver
201:    return waivers
