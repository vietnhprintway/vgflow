791:def _criteria_assertions(goal: dict[str, Any]) -> list[dict[str, str]]:
792:    """Batch 36 R3: convert acceptance_criteria to assertion[] entries.
793:
794:    Each criterion becomes a structured assertion the spec body MUST verify
795:    with expect(). Validator verify-spec-criteria-coverage.py (separate)
796:    will cross-check spec body against this list.
797:    """
798:    out: list[dict[str, str]] = []
799:    for i, crit in enumerate(_parse_acceptance_criteria(goal), 1):
800:        out.append({
801:            "source": f"acceptance_criteria[{i}]",
802:            "check": crit,
803:        })
804:    return out
