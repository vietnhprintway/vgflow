529:def _parse_context_decisions(phase_dir: Path) -> dict[str, dict[str, str]]:
530:    """Parse CONTEXT.md → {D-ID: {title, expected_assertion}}."""
531:    ctx_path = phase_dir / "CONTEXT.md"
532:    if not ctx_path.is_file():
533:        return {}
534:    text = _read(ctx_path)
535:    decisions: dict[str, dict[str, str]] = {}
536:    matches = list(DECISION_HEADER_RE.finditer(text))
537:    for i, m in enumerate(matches):
538:        d_id = m.group(1)
539:        title = m.group(2).strip()
540:        # Body = text from end of this header to next header or end
541:        start = m.end()
542:        end = matches[i + 1].start() if i + 1 < len(matches) else len(text)
543:        body = text[start:end]
544:        assertion_match = DECISION_FIELD_RE.search(body)
545:        decisions[d_id] = {
546:            "title": title,
547:            "expected_assertion": assertion_match.group(1).strip() if assertion_match else "",
548:        }
549:    return decisions
