745:def _parse_acceptance_criteria(goal: dict[str, Any]) -> list[str]:
746:    """Batch 36 R3: extract acceptance_criteria from goal frontmatter.
747:
748:    Goal frontmatter may declare criteria in multiple shapes:
749:      - list[str]: ["criterion 1", "criterion 2"]
750:      - dict {"main": [...], "alternate": [...]}
751:      - prose string: "Criteria: A. B. C." (split on sentence punctuation)
752:      - alternate keys: acceptance_criteria, success_criteria, criteria
753:    Returns deduplicated non-empty list.
754:    """
755:    candidates = (
756:        goal.get("acceptance_criteria")
757:        or goal.get("success_criteria")
758:        or goal.get("criteria")
759:        or []
760:    )
761:    items: list[str] = []
762:    if isinstance(candidates, list):
763:        for c in candidates:
764:            if isinstance(c, str) and c.strip():
765:                items.append(c.strip())
766:            elif isinstance(c, dict):
767:                for v in c.values():
768:                    if isinstance(v, str) and v.strip():
769:                        items.append(v.strip())
770:    elif isinstance(candidates, dict):
771:        for v in candidates.values():
772:            if isinstance(v, list):
773:                items.extend(s.strip() for s in v if isinstance(s, str) and s.strip())
774:            elif isinstance(v, str) and v.strip():
775:                items.append(v.strip())
776:    elif isinstance(candidates, str):
777:        for chunk in re.split(r"(?<=[.!?])\s+|\n+", candidates):
778:            chunk = chunk.strip().lstrip("-•").strip()
779:            if chunk:
780:                items.append(chunk)
781:    # Dedup preserving order
782:    seen: set[str] = set()
783:    out: list[str] = []
784:    for it in items:
785:        if it not in seen:
786:            seen.add(it)
787:            out.append(it)
788:    return out
