1279:389:def main() -> int:
1280:390:    parser = argparse.ArgumentParser(description=__doc__)
1281:391:    parser.add_argument("--phase", required=True)
1282:392:    parser.add_argument("--phase-dir")
1283:393:    parser.add_argument("--root")
1284:394:    parser.add_argument("--max-files", type=int, default=1200)
1285:395:    parser.add_argument("--ai-response", help="Optional AI expansion JSON/markdown response to merge into lifecycle specs")
1286:396:    parser.add_argument("--json", action="store_true")
1287:397:    args = parser.parse_args()
1288:398:
1289:399:    phase_dir = find_phase_dir(args.phase, args.phase_dir)
1290:400:    root = Path(args.root) if args.root else repo_root_from_phase(phase_dir)
1291:401:
1292:402:    if not has_build_evidence(phase_dir):
1293:403:        raise SystemExit(f"build evidence missing for {phase_dir}; run /vg:build first")
1294:404:
1295:405:    lifecycle_module = load_lifecycle_generator()
1296:406:    expander = load_test_spec_expander()
1297:407:    # Batch 36 R1: include read-only goals so LIFECYCLE-SPECS.json covers
1298:408:    # display/list/dashboard/filter/search/error views — not only mutation.
1299:409:    # Codegen subagent reads LIFECYCLE → generates specs per goal entry.
1300:410:    # Without read-only, subagent ignores most goals, producing sparse specs.
1301:411:    lifecycle = lifecycle_module.generate(phase_dir, include_readonly=True)
1302:412:    surfaces = scan_surfaces(root, max_files=args.max_files)
1303:413:    profile = expander.normalize_profile(
1304:414:        str(lifecycle.get("phase_profile") or "") or expander.detect_phase_profile(phase_dir, root)
1305:415:    )
1306:416:    lifecycle = expander.ensure_execution_plans(lifecycle, profile, surfaces)
1307:417:    ai_expansion: dict[str, Any] | None = None
1308:418:    if args.ai_response:
1309:419:        payload = expander.load_expansion_file(Path(args.ai_response))
1310:420:        lifecycle, ai_expansion = expander.apply_expansion(lifecycle, payload)
1311:421:        lifecycle = expander.ensure_execution_plans(lifecycle, profile, surfaces)
1312:422:    fixture_dag = flatten_fixture_dag(lifecycle)
1313:423:    execution_plan = expander.build_execution_plan_artifact(lifecycle, surfaces)
1314:424:
1315:425:    write_json(phase_dir / "LIFECYCLE-SPECS.json", lifecycle)
1316:426:    write_json(phase_dir / "TEST-FIXTURE-DAG.json", fixture_dag)
1317:427:    write_json(phase_dir / "TEST-EXECUTION-PLAN.json", execution_plan)
1318:428:    localizer = expander.prepare(phase_dir, root, phase_dir / "TEST-SPEC-LOCALIZER")
1319:429:    (phase_dir / "DEEP-TEST-SPECS.md").write_text(
1320:430:        render_deep_specs(phase_dir, lifecycle, surfaces),
1321:431:        encoding="utf-8",
1322:432:    )
1323:433:    (phase_dir / "PLAYWRIGHT-SPEC-PLAN.md").write_text(
1324:434:        render_playwright_plan(lifecycle, surfaces),
1325:435:        encoding="utf-8",
1326:436:    )
1327:437:    (phase_dir / "TEST-SPEC-GAPS.md").write_text(
1328:438:        render_gaps(lifecycle, surfaces, phase_dir),
1329:439:        encoding="utf-8",
1330:440:    )
1331:441:
1332:442:    summary = {
1333:443:        "phase_dir": str(phase_dir),
1334:444:        "root": str(root),
1335:445:        "phase_profile": lifecycle.get("phase_profile"),
1336:446:        "lifecycle_goals": len(lifecycle.get("goals") or {}),
1337:447:        "fixture_nodes": len(fixture_dag["nodes"]),
1338:448:        "fixture_edges": len(fixture_dag["edges"]),
1339:449:        "execution_plan_goals": len(execution_plan["goals"]),
1340:450:        "routes": len(surfaces["routes"]),
1341:451:        "forms": len(surfaces["forms"]),
1342:452:        "mutations": len(surfaces["mutations"]),
1343:453:        "localizer": localizer,
1344:454:        "ai_expansion": ai_expansion,
1345:455:        "artifacts": [
1346:456:            "DEEP-TEST-SPECS.md",
1347:457:            "LIFECYCLE-SPECS.json",
1348:458:            "TEST-FIXTURE-DAG.json",
1349:459:            "TEST-EXECUTION-PLAN.json",
1350:460:            "TEST-SPEC-LOCALIZER/REQUEST.json",
1351:461:            "TEST-SPEC-LOCALIZER/PROMPT.md",
1352:462:            "TEST-SPEC-LOCALIZER/OUTPUT.schema.json",
1353:463:            "TEST-SPEC-LOCALIZER/OUTPUT.template.json",
1354:464:            "PLAYWRIGHT-SPEC-PLAN.md",
1355:465:            "TEST-SPEC-GAPS.md",
1356:466:        ],
1357:467:    }
1358:468:    if args.json:
1359:469:        print(json.dumps(summary, indent=2, ensure_ascii=False))
1360:470:    else:
