1024:134:def load_lifecycle_generator() -> Any:
1025:135:    here = Path(__file__).resolve().parent
1026:136:    path = here / "generate-lifecycle-specs.py"
1027:137:    if not path.exists():
1028:138:        path = Path.cwd() / ".claude" / "scripts" / "generate-lifecycle-specs.py"
1029:139:    if not path.exists():
1030:140:        raise SystemExit("generate-lifecycle-specs.py not found")
1031:141:    spec = importlib.util.spec_from_file_location("vg_generate_lifecycle_specs", path)
1032:142:    if spec is None or spec.loader is None:
1033:143:        raise SystemExit(f"cannot import lifecycle generator: {path}")
1034:144:    module = importlib.util.module_from_spec(spec)
1035:145:    spec.loader.exec_module(module)
1036:146:    return module
