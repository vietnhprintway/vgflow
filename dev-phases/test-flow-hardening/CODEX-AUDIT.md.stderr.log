4813:8:## Schema
4814:9:
4815:10:```yaml
4816:11:---
4817:12:id: G-XX
4818:13:title: "Short user-observable behavior"
4819:14:priority: critical | important | nice
4820:15:surface: ui | api | data | integration | time-driven | custom
4821:16:
4822:17:# v2.2 enrichment (all optional but recommended)
4823:18:actor: <role + authentication state>
4824:19:  # e.g. "publisher (role=publisher, authenticated)"
4825:20:  #      "anonymous (unauthenticated visitor)"
4826:21:  #      "cron (system, runs 0 */5 * * *)"
4827:22:
4828:23:precondition:
4829:24:  # List of system state required before goal can trigger
4830:25:  - <imported_goal_or_UC_id>  # e.g. UC-GEN-AUTH-01 (logged in)
4831:26:  - <explicit state>          # e.g. "has_verified_site"
4832:27:  - <data requirement>        # e.g. "quota_available"
4833:28:
4834:29:trigger: <user-observable action or event>
4835:30:  # e.g. "Click 'Create Ad Unit' button"
4836:31:  #      "POST /api/sites/{id}/ad-units from client"
4837:32:  #      "Kafka message on topic bid-requests"
4838:33:
4839:34:main_steps:
4840:35:  # Ordered list of user-visible OR system actions. Each step = 1 observable.
4841:36:  - S1: <action>              # e.g. "Open form modal"
4842:37:  - S2: <action>              # e.g. "Fill name + size + type"
4843:38:  - S3: <action>              # e.g. "Submit form"
4844:39:  - S4: <action>              # e.g. "API validates + persists"
4845:40:  - S5: <action>              # e.g. "List refresh with new entry"
4846:41:
4847:42:alternate_flows:
4848:43:  # Named failure modes + expected system behavior
4849:44:  - name: <short_id>
4850:45:    trigger: <what causes alternate flow>
4851:46:    expected: <observable outcome>
4852:47:  # e.g.
4853:48:  # - name: validation_fail
4854:49:  #   trigger: missing required field
4855:50:  #   expected: inline errors shown, stay on modal
4856:51:  # - name: quota_exceeded
4857:52:  #   trigger: user at/above site quota
4858:53:  #   expected: upgrade prompt shown, submission blocked
4859:54:
4860:55:postcondition:
4861:56:  # State after successful main_flow execution. MUST include side effects.
4862:57:  - <db state change>         # e.g. "ad_unit row inserted with status=pending_review"
4863:58:  - <event emission>          # e.g. "event 'ad_unit_created' emitted to Kafka"
4864:59:  - <cache invalidation>      # e.g. "sites_list cache for publisher invalidated"
4865:60:  - <ui state>                # e.g. "list UI shows new item at top"
