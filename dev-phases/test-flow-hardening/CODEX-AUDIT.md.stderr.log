8080:598:                "skeleton_visible_ms": st.get("skeleton_visible_ms"),
8081:599:                "trigger_observed": st.get("trigger"),
8082:600:            },
8083:601:            "trigger": trigger + f" on {view}",
8084:602:            "main_steps": [
