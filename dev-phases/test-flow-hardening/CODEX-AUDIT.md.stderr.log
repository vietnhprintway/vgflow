133:        kind = ec.get("kind") or "unknown"
134:        label = ec.get("label") or kind
135:        # variant_id format: {goal_id}-{letter}{number} per existing scheme
136:        # Use first letter of kind + index
137:        letter = (kind[:1].lower() or "x")
138:        variant_id = f"{goal_id}-{letter}{idx}"
139:        input_hint = ec.get("input_hint") or "(no input hint)"
140:        expected = ec.get("expected") or "(no expected outcome)"
141:        lines.append(f"### {variant_id} — {label}")
142:        lines.append("")
143:        lines.append(f"- **kind**: `{kind}`")
144:        lines.append(f"- **input_hint**: {input_hint}")
145:        lines.append(f"- **expected**: {expected}")
