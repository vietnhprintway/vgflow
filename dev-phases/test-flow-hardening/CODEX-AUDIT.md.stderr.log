478:### F.2.5 — edge-case variant coverage gate (P1 v2.49+)
479:
480:Before goal-test binding gate, verify each variant from EDGE-CASES has a
481:matching `test()` or `test.each()` row in generated `.spec.ts`:
482:
483:```bash
484:# Batch 45 F6 fix: deterministic gate — no env-var dependency.
485:# Previously relied on EDGE_CASES_AVAILABLE / GOALS_LIST / ALLOW_SKIP
486:# which no orchestrator step set → gate was dead code.
487:if [ -d "${PHASE_DIR}/EDGE-CASES" ]; then
488:  EDGE_GAP_COUNT=0
489:  # Iterate EDGE-CASES/G-*.md directly — derive goal list inline.
490:  for EDGE_FILE in "${PHASE_DIR}/EDGE-CASES/"G-*.md; do
491:    [ -f "$EDGE_FILE" ] || continue
492:    gid=$(basename "$EDGE_FILE" .md)
493:
494:    # Extract variant_ids from edge case file (G-NN-a1, G-NN-b2, etc.)
495:    VARIANTS=$(grep -oE "${gid}-[a-z][0-9]+" "$EDGE_FILE" | sort -u)
496:    for vid in $VARIANTS; do
497:      # Variant must appear in spec.ts comment OR test name
498:      if ! grep -rqE "vg-edge-case[: ]+${vid}|test\\(['\"].*${vid}|test\\.each.*${vid}" "${GENERATED_TESTS_DIR}/" 2>/dev/null; then
499:        echo "  ⚠ ${gid}: variant ${vid} không có test (spec.ts thiếu coverage)"
500:        EDGE_GAP_COUNT=$((EDGE_GAP_COUNT + 1))
501:      fi
502:    done
503:  done
504:  if [ "$EDGE_GAP_COUNT" -gt 0 ]; then
505:    echo "⛔ Batch 45 F6: ${EDGE_GAP_COUNT} variant(s) không có test coverage."
506:    echo "   AI phải re-codegen với test.each(...) per variant từ EDGE-CASES."
507:    echo "   Reference variant_id ở comment hoặc test name."
508:    "${PYTHON_BIN:-python3}" "${VG_SCRIPT_ROOT:-${VG_HOME:-$HOME/.vgflow}/scripts}/vg-orchestrator" \
509:      emit-event "test.edge_coverage_failed" \
510:      --payload "{\"phase\":\"${PHASE_NUMBER}\",\"gaps\":${EDGE_GAP_COUNT}}" >/dev/null 2>&1 || true
511:    if [[ ! "${ARGUMENTS:-}" =~ --skip-edge-coverage ]]; then
512:      exit 1
513:    fi
514:    echo "⚠ --skip-edge-coverage set — proceeding with ${EDGE_GAP_COUNT} gap(s) (debt logged)"
515:  fi
516:fi
517:```
518:
519:Severity: BLOCK by default; degrades to WARN if `--allow-edge-case-gap` flag
520:set (paired with override-reason).
