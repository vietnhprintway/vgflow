251:            invalid_chains.append(g["id"])
252:            errors.extend(chain_errors)
253:
254:    # Coverage: every CRUD resource needs ≥1 valid feature_chain goal.
255:    # Resource→goal mapping heuristic: goal id or text mentions resource name.
256:    covered: set[str] = set()
257:    valid_chain_ids = {g["id"] for g in chain_goals if g["id"] not in invalid_chains}
258:    for resource in resources:
259:        if resource in waivers:
260:            covered.add(resource)
261:            continue
262:        rname = resource.lower()
263:        for cgid in valid_chain_ids:
264:            # match if goal id or full text mentions resource lowercased
265:            if rname in cgid.lower():
266:                covered.add(resource)
267:                break
268:            # fallback: scan goal body for resource mention
269:            # (relax heuristic — exact resource name in goal heading is fine
270:            #  but goal body may also indicate which entity it covers)
271:            if re.search(
272:                rf"\b{re.escape(rname)}\b",
273:                test_goals_text.lower(),
274:            ):
275:                # at least one feature_chain goal AND test-goals mentions resource
276:                # → assume coverage. Optimistic; tighter check requires
277:                # explicit goal→resource binding field (out of scope B62).
278:                if chain_goals:
279:                    covered.add(resource)
280:                    break
281:
282:    uncovered = sorted(resources - covered)
283:    print(f"B62: {len(resources)} CRUD resource(s), {len(chain_goals)} feature_chain goal(s) "
284:          f"({len(invalid_chains)} invalid), {len(uncovered)} uncovered")
