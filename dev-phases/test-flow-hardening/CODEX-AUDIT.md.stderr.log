486:    fixtures = [
487:        {
488:            "id": f"{actor['id']}_session",
489:            "kind": "auth_or_service_context",
490:            "depends_on": [],
491:            "cleanup": "revoke session/token or clear service fixture if created by test",
492:        }
493:        for actor in actors
494:    ]
495:    fixtures.append({
496:        "id": "owned_resource",
497:        "kind": "resource_or_state_under_test",
498:        "depends_on": [fixtures[0]["id"]] if fixtures else [],
499:        "cleanup": "delete/deactivate/cancel/rollback or restore original state",
500:    })
501:    if _meaningful(goal.get("dependencies")):
502:        fixtures.append({
503:            "id": "cross_phase_dependencies",
504:            "kind": "seeded dependencies named in TEST-GOALS",
505:            "depends_on": [fixtures[0]["id"]] if fixtures else [],
506:            "cleanup": "leave shared seed intact; cleanup only test-owned children",
507:        })
508:    if _needs_artifact_capture(goal):
509:        fixtures.append({
510:            "id": "artifact_sink",
511:            "kind": "mailbox/webhook/queue/token capture fixture",
512:            "depends_on": [fixtures[0]["id"]] if fixtures else [],
513:            "cleanup": "clear captured artifacts owned by this test run",
514:        })
515:    return fixtures
