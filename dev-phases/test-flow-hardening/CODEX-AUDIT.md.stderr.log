2:"""B63: verify scanner cross_view_propagation observations cover CRUD.
3:
4:For every CRUD-creating resource in CRUD-SURFACES.md, at least one
5:scan-*.json under phase_dir must have:
6:  cross_view_propagation_observations[] entry where:
7:    - entity_canonical_id matches resource (or source_view contains
8:      resource slug)
9:    - action=create
10:    - observed_in_target in {yes, partial}
11:
12:Waiver: `.vg/scanner-overrides.yaml` with `skip_cross_view: true` per
13:resource OR global `cross_view_scan: disabled`.
14:
15:Usage:
16:  verify-cross-view-coverage.py --phase 7
17:  verify-cross-view-coverage.py --phase 7 --strict
18:"""
19:from __future__ import annotations
20:import argparse
21:import json
22:import re
23:import sys
24:from pathlib import Path
25:
26:
27:def _find_phase_dir(phase: str, override: str | None = None) -> Path:
28:    if override:
29:        return Path(override)
30:    for root in (Path(".vg/phases"), Path("dev-phases"), Path("phases")):
31:        if not root.is_dir():
32:            continue
33:        for p in root.iterdir():
34:            if p.is_dir() and (p.name == phase or p.name.startswith(f"{phase}-")):
35:                return p
36:    raise SystemExit(f"phase dir not found for {phase}")
37:
38:
39:RESOURCE_RE = re.compile(r"^(?:##\s+|resource:\s+)([\w_-]+)", re.M)
40:CREATE_METHOD_RE = re.compile(r'"method"\s*:\s*"POST"|method:\s*POST', re.I)
41:
42:
43:def _parse_crud_resources(phase_dir: Path) -> set[str]:
44:    surfaces = phase_dir / "CRUD-SURFACES.md"
45:    if surfaces.is_file():
46:        text = surfaces.read_text(encoding="utf-8", errors="replace")
47:    else:
48:        sd = phase_dir / "CRUD-SURFACES"
49:        if not sd.is_dir():
50:            return set()
51:        text = "\n".join(p.read_text(encoding="utf-8", errors="replace")
52:                          for p in sd.glob("*.md"))
53:    resources: set[str] = set()
54:    last_r: str | None = None
55:    last_start = 0
56:    chunks: list[tuple[str, str]] = []
57:    for m in RESOURCE_RE.finditer(text):
58:        if last_r is not None:
59:            chunks.append((last_r, text[last_start:m.start()]))
60:        last_r = m.group(1)
61:        last_start = m.end()
62:    if last_r is not None:
63:        chunks.append((last_r, text[last_start:]))
64:    for resource, block in chunks:
65:        if CREATE_METHOD_RE.search(block):
66:            resources.add(resource)
67:    return resources
68:
69:
70:def _parse_overrides(phase_dir: Path) -> dict:
71:    """Parse .vg/scanner-overrides.yaml (tiny subset).
72:    Returns {global_disabled: bool, skip_resources: set[str]}.
73:    """
74:    candidates = [
75:        phase_dir / ".vg" / "scanner-overrides.yaml",
76:        phase_dir.parent.parent / ".vg" / "scanner-overrides.yaml",
77:        Path(".vg") / "scanner-overrides.yaml",
78:    ]
79:    out = {"global_disabled": False, "skip_resources": set()}
80:    for c in candidates:
81:        if c.is_file():
82:            text = c.read_text(encoding="utf-8", errors="replace")
83:            if re.search(r"cross_view_scan:\s*disabled", text):
84:                out["global_disabled"] = True
85:            for m in re.finditer(r"skip_cross_view\[?([\w_-]*)\]?\s*:\s*true", text):
86:                if m.group(1):
87:                    out["skip_resources"].add(m.group(1))
88:                else:
89:                    out["global_disabled"] = True
90:            break
91:    return out
92:
93:
94:def _load_scan_observations(phase_dir: Path) -> list[dict]:
95:    """Collect cross_view_propagation_observations from all scans."""
96:    obs: list[dict] = []
97:    for scan_file in sorted(phase_dir.glob("scan-*.json")):
98:        try:
99:            doc = json.loads(scan_file.read_text(encoding="utf-8", errors="replace"))
100:        except json.JSONDecodeError:
101:            continue
102:        for entry in doc.get("cross_view_propagation_observations") or []:
103:            if isinstance(entry, dict):
104:                obs.append(entry)
105:    return obs
106:
107:
108:def main() -> int:
109:    ap = argparse.ArgumentParser()
110:    ap.add_argument("--phase", required=True)
111:    ap.add_argument("--phase-dir")
112:    ap.add_argument("--strict", action="store_true")
113:    args = ap.parse_args()
114:
115:    phase_dir = _find_phase_dir(args.phase, args.phase_dir)
116:    resources = _parse_crud_resources(phase_dir)
117:    if not resources:
118:        print(f"ℹ B63: no CRUD resources with POST — no cross-view required")
119:        return 0
120:
121:    overrides = _parse_overrides(phase_dir)
122:    if overrides["global_disabled"]:
123:        print(f"ℹ B63: cross_view_scan disabled globally (scanner-overrides.yaml) — skipping")
124:        return 0
125:
126:    observations = _load_scan_observations(phase_dir)
127:
128:    # Resource→observation matching: substring on entity_canonical_id or source_view.
129:    # Check waiver FIRST so phases with override but no scan still PASS.
130:    covered: set[str] = set()
