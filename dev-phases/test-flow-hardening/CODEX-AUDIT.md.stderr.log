1140:250:def render_deep_specs(phase_dir: Path, lifecycle: dict[str, Any], surfaces: dict[str, Any]) -> str:
1141:251:    lines = [
1142:252:        f"# Deep Test Specs — {phase_dir.name}",
1143:253:        "",
1144:254:        "_Generated after build and before review. Review must consume this as the test-depth contract._",
1145:255:        "",
1146:256:        "## Source Evidence",
1147:257:        "",
1148:258:        f"- Build evidence present: `{has_build_evidence(phase_dir)}`",
1149:259:        f"- Source files scanned: `{surfaces['files_scanned']}`",
1150:260:        f"- Routes detected: `{len(surfaces['routes'])}`",
1151:261:        f"- Form surfaces detected: `{len(surfaces['forms'])}`",
1152:262:        f"- Mutation candidates detected: `{len(surfaces['mutations'])}`",
1153:263:        f"- Files exposing selectors/roles/labels: `{surfaces['selector_files']}`",
1154:264:        f"- Phase profile: `{lifecycle.get('phase_profile', 'mixed')}`",
1155:265:        "",
1156:266:        "## Lifecycle Goals",
1157:267:        "",
1158:268:    ]
1159:269:    goals = lifecycle.get("goals") or {}
1160:270:    if not goals:
1161:271:        lines.append("- No side-effecting or multi-actor goals detected. Read-only smoke specs still belong in `/vg:test`.")
1162:272:    for goal_id, spec in goals.items():
1163:273:        stages = [step.get("stage") for step in spec.get("steps") or []]
1164:274:        lines.extend(
1165:275:            [
1166:276:                f"### {goal_id} — {spec.get('title', '')}",
1167:277:                "",
1168:278:                f"- Type: `{spec.get('goal_type', 'mutation')}`",
1169:279:                f"- Actors: `{', '.join(str(a.get('id')) for a in spec.get('actors') or [])}`",
1170:280:                f"- Fixture count: `{len(spec.get('fixture_dag') or [])}`",
1171:281:                f"- RCRURDR stages: `{', '.join(stages)}`",
1172:282:                f"- Artifact capture: `{len(spec.get('artifact_capture') or [])}` item(s)",
1173:283:                f"- Cleanup: `{len(spec.get('cleanup') or [])}` item(s)",
1174:284:                f"- Runner: `{(spec.get('execution_plan') or {}).get('runner', 'unplanned')}`",
1175:285:                "",
1176:286:            ]
1177:287:        )
1178:288:    lines.extend(["## Runtime Surface Hints", ""])
1179:289:    for item in surfaces["routes"][:60]:
1180:290:        lines.append(f"- `{item['route']}` — {', '.join(item['files'][:3])}")
1181:291:    if len(surfaces["routes"]) > 60:
1182:292:        lines.append(f"- ... +{len(surfaces['routes']) - 60} routes")
1183:293:    lines.extend(["", "## Required Review Usage", ""])
1184:294:    lines.extend(
1185:295:        [
1186:296:            "- `/vg:review` must compare browser discovery against these lifecycle goals.",
1187:297:            "- Runtime blockers stay in review/debug; missing executable specs route to `/vg:test` only after runtime is clean.",
1188:298:            "- Mutation goals require read-before, create, read-after-create, update, read-after-update, delete, read-after-delete evidence.",
1189:299:            "- `TEST-EXECUTION-PLAN.json` selects runner family per phase profile; do not force Playwright for mobile, CLI, backend, or library phases.",
1190:300:        ]
1191:301:    )
1192:302:    return "\n".join(lines).rstrip() + "\n"
