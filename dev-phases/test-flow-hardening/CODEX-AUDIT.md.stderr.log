518:DECISION_HEADER_RE = re.compile(
519:    r"^#{2,3}\s+(D-[\w.-]+):?\s*(.+?)\s*$",
520:    re.MULTILINE,
521:)
522:DECISION_FIELD_RE = re.compile(
523:    r"^\*\*expected_assertion:\*\*\s*(.+?)(?=^\*\*|\n##|\n#\s+D-|\Z)",
524:    re.MULTILINE | re.DOTALL,
525:)
526:DECISION_REF_RE = re.compile(r"\b(D-[\w.-]+)\b")
