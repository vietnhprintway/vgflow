314:def _infer_actors(goal: dict[str, Any]) -> list[dict[str, Any]]:
315:    text = _combined(goal).lower()
316:    actors: list[dict[str, Any]] = []
317:
318:    def add(actor_id: str, role: str, session: str) -> None:
319:        if not any(actor["id"] == actor_id for actor in actors):
320:            actors.append({
321:                "id": actor_id,
322:                "role": role,
323:                "session": session,
324:                "permissions": [f"least privilege required for {role} path"],
325:            })
326:
327:    if "admin" in text:
328:        add("admin", "admin", "admin_session")
329:    if "owner" in text:
330:        add("owner_actor", "resource_owner", "owner_session")
331:    if INVITEE_WORDS.search(text):
332:        add("invitee", "invitee", "invitee_session")
333:    if "approver" in text or "approve" in text:
334:        add("approver", "approver", "approver_session")
335:    if "reviewer" in text or "review" in text:
336:        add("reviewer", "reviewer", "reviewer_session")
337:    if any(word in text for word in ("collaborator", "member")):
338:        add("secondary_actor", "secondary_user", "secondary_session")
339:    if "external system" in text or "oauth" in text or "webhook" in text:
340:        add("external_actor", "external_system_or_webhook", "signed_callback_context")
341:
342:    if not actors:
343:        add("system_actor", "system", "authenticated or service context required by TEST-GOALS")
344:    elif _is_multi_actor(goal) and len(actors) == 1:
345:        add("secondary_actor", "secondary_user_or_external_system", "secondary_session")
346:    return actors
