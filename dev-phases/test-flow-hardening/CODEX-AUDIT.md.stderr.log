6298:973:def _find_phase_dir(phase: str, explicit: str | None) -> Path:
6299:974:    if explicit:
6300:975:        path = Path(explicit)
6301:976:        if not path.exists():
6302:977:            raise SystemExit(f"phase-dir not found: {path}")
6303:978:        return path
6304:979:
6305:980:    root = Path(os.environ.get("VG_REPO_ROOT") or os.getcwd())
6306:981:    phases_dir = root / ".vg" / "phases"
6307:982:    if not phases_dir.is_dir():
6308:983:        raise SystemExit(f"phase directory root not found: {phases_dir}")
6309:984:
6310:985:    candidates = [p for p in phases_dir.iterdir() if p.is_dir()]
6311:986:    exact = [p for p in candidates if p.name == phase]
6312:987:    if exact:
6313:988:        return exact[0]
6314:989:
6315:990:    prefix = phase_pad(phase) if str(phase).isdigit() else str(phase)
6316:991:    matches = [p for p in candidates if p.name == prefix or p.name.startswith(prefix + "-")]
6317:992:    if len(matches) == 1:
6318:993:        return matches[0]
6319:994:    if not matches:
6320:995:        raise SystemExit(f"phase not found: {phase}")
6321:996:    raise SystemExit(f"phase is ambiguous: {phase}: {', '.join(p.name for p in matches)}")
