97:# Match goal blocks. Heading + body until next ## heading.
98:GOAL_HEADING_RE = re.compile(r"^##\s+(?:Goal\s+)?(G-[\w.-]+)", re.M)
99:GOAL_CLASS_FIELD_RE = re.compile(r"goal_class:\s*([\w_-]+)")
100:CHAIN_STEPS_BLOCK_RE = re.compile(r"chain_steps:\s*\n((?:\s*-\s.*\n(?:\s+\S.*\n)*)+)", re.M)
101:STEP_ITEM_RE = re.compile(r"-\s+step_id:\s*(\S+)", re.M)
102:EXPECTED_STATE_RE = re.compile(r"expected_state:\s*(\S+)")
103:TARGET_VIEW_CLASS_RE = re.compile(r"target_view_class:\s*(\S+)")
104:DOWNSTREAM_EFFECTS_BLOCK_RE = re.compile(r"downstream_effects:\s*\n((?:\s+-\s.*\n)*)", re.M)
