244:        return goals
245:
246:    text = _read(phase_dir / "TEST-GOALS.md")
247:    pattern = re.compile(
248:        r"^##\s+(?:Goal\s+)?(G-[\w.-]+):?\s*(.*?)$"
249:        r"(?P<body>(?:(?!^##\s+(?:Goal\s+)?G-[\w.-]+).)*)",
250:        re.MULTILINE | re.DOTALL,
251:    )
252:    for match in pattern.finditer(text):
253:        body = f"## Goal {match.group(1)}: {match.group(2)}\n{match.group('body') or ''}"
254:        goal = _parse_goal_block(body, phase_dir / "TEST-GOALS.md")
255:        if goal:
