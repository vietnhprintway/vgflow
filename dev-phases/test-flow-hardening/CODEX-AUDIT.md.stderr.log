7333:115:    title = goal_spec.get("title") or goal_id
7334:116:    edge_cases = goal_spec.get("edge_cases") or []
7335:117:    if not edge_cases:
7336:118:        return ""
7337:119:
7338:120:    lines = [
7339:121:        f"# EDGE-CASES — {goal_id}: {title}",
7340:122:        "",
7341:123:        f"_Auto-derived from LIFECYCLE-SPECS.json by Batch 48 (F7 closure)._",
7342:124:        f"_Source: `LIFECYCLE-SPECS.json.goals[{goal_id}].edge_cases[]`._",
7343:125:        "",
7344:126:        "## Variants (test.each rows)",
7345:127:        "",
7346:128:    ]
7347:129:
7348:130:    for idx, ec in enumerate(edge_cases, 1):
7349:131:        if not isinstance(ec, dict):
7350:132:            continue
7351:133:        kind = ec.get("kind") or "unknown"
7352:134:        label = ec.get("label") or kind
7353:135:        # variant_id format: {goal_id}-{letter}{number} per existing scheme
7354:136:        # Use first letter of kind + index
7355:137:        letter = (kind[:1].lower() or "x")
7356:138:        variant_id = f"{goal_id}-{letter}{idx}"
7357:139:        input_hint = ec.get("input_hint") or "(no input hint)"
7358:140:        expected = ec.get("expected") or "(no expected outcome)"
7359:141:        lines.append(f"### {variant_id} — {label}")
7360:142:        lines.append("")
7361:143:        lines.append(f"- **kind**: `{kind}`")
7362:144:        lines.append(f"- **input_hint**: {input_hint}")
7363:145:        lines.append(f"- **expected**: {expected}")
7364:146:        lines.append("")
7365:147:        lines.append("```yaml")
7366:148:        lines.append(f"variant_id: {variant_id}")
7367:149:        lines.append(f"kind: {kind}")
7368:150:        lines.append(f"label: \"{label}\"")
7369:151:        lines.append(f"input_hint: \"{input_hint}\"")
7370:152:        lines.append(f"expected: \"{expected}\"")
7371:153:        lines.append("priority: important")
7372:154:        lines.append("```")
7373:155:        lines.append("")
7374:156:
7375:157:    lines.append("## Codegen contract")
7376:158:    lines.append("")
7377:159:    lines.append(f"Generated spec MUST emit one `test.each([variants])` row per variant_id above.")
7378:160:    lines.append(f"Each test name MUST cite variant_id (e.g. `test('${goal_id}-b1 — min boundary', ...)`).")
7379:161:    lines.append(f"verify-edge-coverage gate (delegation.md F.2.5) checks this binding.")
7380:162:    lines.append("")
7381:163:    return "\n".join(lines)
