185:def scan_surfaces(root: Path, max_files: int = 1200) -> dict[str, Any]:
186:    routes: dict[str, dict[str, Any]] = {}
187:    mutations: list[dict[str, str]] = []
188:    forms: list[dict[str, str]] = []
189:    selector_files = 0
190:
191:    source_files = iter_source_files(root, max_files)
192:    for path in source_files:
193:        text = read(path)
194:        rel = str(path.relative_to(root)) if path.is_relative_to(root) else str(path)
195:        if TESTID_RE.search(text):
196:            selector_files += 1
197:        if FORM_RE.search(text):
198:            forms.append({"file": rel, "hint": "form or form-library usage detected"})
199:        if MUTATION_RE.search(text):
200:            mutations.append({"file": rel, "hint": "mutation verb or method detected"})
201:        for match in ROUTE_RE.finditer(text):
202:            route = next((g for g in match.groups() if g), "")
203:            if not route or route.startswith(("//", "http://", "https://")):
204:                continue
205:            item = routes.setdefault(route, {"route": route, "files": []})
206:            if rel not in item["files"]:
207:                item["files"].append(rel)
208:
209:    return {
210:        "routes": sorted(routes.values(), key=lambda item: item["route"])[:300],
211:        "forms": forms[:300],
212:        "mutations": mutations[:300],
213:        "selector_files": selector_files,
214:        "files_scanned": len(source_files),
215:    }
