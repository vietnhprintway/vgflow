5415:90:def _stages_for_goal(goal: dict[str, Any]) -> tuple[str, ...]:
5416:91:    """Derive lifecycle stages.
5417:92:
5418:93:    Dispatch precedence (B62-pre — audit ID-1):
5419:94:      1. goal_class (NEW dispatch key — feature_chain wins over RCRURDR default)
5420:95:      2. goal_type (existing dispatch — backward compatible)
5421:96:      3. HTTP verb inference from mutation_evidence (legacy fallback)
5422:97:
5423:98:    Without B62-pre fix, AI setting goal_class=feature_chain produced no
5424:99:    stage change because pipeline read goal_type only.
5425:100:    """
5426:101:    # B62-pre: goal_class takes priority (feature_chain etc.)
5427:102:    gclass = (goal.get("goal_class") or "").strip().lower()
5428:103:    if gclass in GOAL_CLASS_STAGES:
5429:104:        return GOAL_CLASS_STAGES[gclass]
5430:105:
5431:106:    gtype = (goal.get("goal_type") or "").strip().lower()
5432:107:    # Explicit goal_type mapping takes priority over inference
5433:108:    if gtype in GOAL_TYPE_STAGES:
5434:109:        return GOAL_TYPE_STAGES[gtype]
5435:110:    # Non-empty but unrecognised goal_type (e.g. multi-actor, wizard) → full RCRURDR
5436:111:    # so existing tests and behaviours are not broken by unrecognised types.
5437:112:    if gtype:
5438:113:        return REQUIRED_STAGES
5439:114:    # goal_type absent — infer from HTTP verb hints in mutation_evidence
5440:115:    evidence = " ".join(
5441:116:        str(goal.get(k) or "")
5442:117:        for k in ("mutation_evidence", "persistence_check", "title")
5443:118:    ).upper()
5444:119:    has_post = "POST " in evidence or " POST" in evidence
5445:120:    has_put_patch = "PUT " in evidence or "PATCH " in evidence
5446:121:    has_del = "DELETE " in evidence
5447:122:    if has_post and not has_put_patch and not has_del:
5448:123:        return GOAL_TYPE_STAGES["create-only"]
5449:124:    if has_del and not has_post and not has_put_patch:
5450:125:        return GOAL_TYPE_STAGES["delete-only"]
5451:126:    if has_put_patch and not has_post and not has_del:
5452:127:        return GOAL_TYPE_STAGES["update-only"]
5453:128:    return REQUIRED_STAGES
