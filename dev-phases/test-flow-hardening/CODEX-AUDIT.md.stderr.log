639:def render_markdown(stubs: list[dict], existing_count: int,
640:                    runtime_views: int, threshold: int) -> str:
641:    now = _dt.datetime.now(_dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
642:    lines: list[str] = []
643:    lines.append(f"# TEST-GOALS-DISCOVERED.md")
644:    lines.append("")
645:    lines.append(f"_Generated: {now} by `/vg:review` Phase 2c (v2.34.0+)._")
646:    lines.append("")
647:    lines.append("Auto-emitted goal stubs from runtime UI discovery (Haiku/in-session Codex scans).")
648:    lines.append("Each stub maps to a real UI element observed during review. `/vg:test` codegen consumes")
649:    lines.append("this file alongside `TEST-GOALS.md`. Generated specs prefixed `auto-{goal-id}.spec.ts`.")
650:    lines.append("")
651:    lines.append(f"## Source")
652:    lines.append("")
653:    lines.append(f"- Existing TEST-GOALS.md: **{existing_count}** goals")
654:    lines.append(f"- Runtime views scanned: **{runtime_views}**")
655:    lines.append(f"- Auto-discovered goals: **{len(stubs)}**")
656:    lines.append(f"- Coverage threshold (min elements/view to require enrichment): {threshold}")
657:    lines.append("")
658:    lines.append("## Triage")
659:    lines.append("")
660:    lines.append("Auto-goals are **review-grade** (heuristically derived). Human triage on next blueprint:")
661:    lines.append("- Promote useful auto-goals → migrate to `TEST-GOALS.md` with proper IDs")
662:    lines.append("- Reject false-positives → add to `interactive_controls.exclude` in source goal")
663:    lines.append("- Keep `G-AUTO-*` IDs for repeat runs — script dedupes against existing IDs")
664:    lines.append("")
665:    lines.append("## Auto-emitted goals")
666:    lines.append("")
667:
668:    for stub in stubs:
669:        lines.append("---")
670:        lines.append(f"id: {stub['id']}")
671:        lines.append(f"title: \"{stub['title']}\"")
672:        lines.append(f"priority: {stub['priority']}")
673:        lines.append(f"surface: {stub['surface']}")
674:        lines.append(f"source: {stub['source']}")
675:        lines.append(f"evidence:")
676:        for k, v in (stub.get("evidence") or {}).items():
677:            if v is not None:
678:                lines.append(f"  {k}: {json.dumps(v)}")
679:        lines.append(f"trigger: \"{stub.get('trigger', '')}\"")
680:        lines.append("main_steps:")
681:        for step in stub.get("main_steps") or []:
682:            for sk, sv in step.items():
683:                lines.append(f"  - {sk}: \"{sv}\"")
684:        if stub.get("alternate_flows"):
685:            lines.append("alternate_flows:")
686:            for af in stub["alternate_flows"]:
687:                lines.append(f"  - name: {af['name']}")
688:                lines.append(f"    trigger: \"{af['trigger']}\"")
689:                lines.append(f"    expected: \"{af['expected']}\"")
690:        if stub.get("postcondition"):
691:            lines.append("postcondition:")
692:            for pc in stub["postcondition"]:
693:                lines.append(f"  - \"{pc}\"")
694:        lines.append("---")
695:        lines.append("")
696:
697:    return "\n".join(lines)
