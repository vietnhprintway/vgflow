408:def _root_fixture_dag(goals_meta: list[dict[str, Any]]) -> dict[str, Any]:
409:    """Build fixture DAG from goal.dependencies field referencing other goal IDs."""
410:    nodes = []
411:    edges = []
412:    for g in goals_meta:
413:        gid = g.get("id") or g.get("goal_id")
414:        if not gid:
415:            continue
416:        nodes.append({"id": gid, "kind": g.get("goal_type", "mutation")})
417:        deps = g.get("dependencies") or ""
418:        deps_text = deps if isinstance(deps, str) else " ".join(str(d) for d in deps)
419:        for m in re.finditer(r"\b(G-\d+)\b", deps_text):
420:            ref = m.group(1)
421:            if ref != gid:
422:                edges.append({"from": gid, "to": ref})
423:    return {"nodes": nodes, "edges": edges}
