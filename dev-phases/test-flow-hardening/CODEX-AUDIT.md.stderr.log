1505:126:**Forbidden-without-override enforcement (A5):**
1506:127:
1507:128:The flags listed in `forbidden_without_override` (test.md runtime_contract)
1508:129:MUST be paired with `--override-reason "<≥50 chars>"`. Each accepted skip
1509:130:flag emits a canonical `override.used` event via `vg-orchestrator override`
1510:131:so the override-debt register has a stable record. Lone `--override-reason`
1511:132:(no companion skip flag) is also gated and emits its own `override.used`
1512:133:event tagged with `flag=--override-reason` — that way the contract drift
1513:134:called out in review-v2 A5 can never silently swallow a justification.
1514:135:
1515:136:```bash
1516:137:# Detect any forbidden skip/allow flags present in $ARGUMENTS.
1517:138:# --override-reason itself is also in forbidden_without_override (test.md)
1518:139:# but is handled separately below so we can attribute the override event.
1519:140:FORBIDDEN_FLAGS=(--skip-deploy --skip-flow --allow-missing-console-check)
1520:141:USED_FORBIDDEN=()
1521:142:for FF in "${FORBIDDEN_FLAGS[@]}"; do
1522:143:  if [[ " ${ARGUMENTS} " =~ [[:space:]]${FF}([[:space:]=]|$) ]]; then
1523:144:    USED_FORBIDDEN+=("$FF")
1524:145:  fi
1525:146:done
1526:147:
1527:148:HAS_OVERRIDE_REASON=false
1528:149:if [[ " ${ARGUMENTS} " =~ [[:space:]]--override-reason([[:space:]=]) ]]; then
1529:150:  HAS_OVERRIDE_REASON=true
1530:151:fi
1531:152:
1532:153:# Extract reason text once (vg-orchestrator validates ≥50 chars + non-placeholder).
1533:154:OVR_REASON=""
1534:155:if [ "$HAS_OVERRIDE_REASON" = "true" ]; then
1535:156:  OVR_REASON=$(echo "$ARGUMENTS" | ${PYTHON_BIN:-python3} -c "
1536:157:import re, sys
1537:158:arg = sys.stdin.read()
1538:159:m = re.search(r'--override-reason[ =](?:\"([^\"]+)\"|(\S.*))', arg)
1539:160:if m:
1540:161:    print((m.group(1) or m.group(2) or '').strip())
1541:162:")
1542:163:fi
1543:164:
1544:165:if [ ${#USED_FORBIDDEN[@]} -gt 0 ]; then
1545:166:  if [ "$HAS_OVERRIDE_REASON" != "true" ]; then
1546:167:    echo "⛔ Forbidden flag(s) used without --override-reason:"
1547:168:    for FF in "${USED_FORBIDDEN[@]}"; do echo "   ${FF}"; done
1548:169:    echo ""
1549:170:    echo "Re-run with: --override-reason \"<≥50 char justification>\""
1550:171:    exit 1
1551:172:  fi
1552:173:
1553:174:  for FF in "${USED_FORBIDDEN[@]}"; do
1554:175:    "${PYTHON_BIN:-python3}" .claude/scripts/vg-orchestrator override \
1555:176:      --flag "$FF" --reason "$OVR_REASON" || {
1556:177:        echo "⛔ vg-orchestrator override rejected $FF (reason too short / placeholder)."
1557:178:        exit 1
1558:179:      }
1559:180:  done
1560:181:elif [ "$HAS_OVERRIDE_REASON" = "true" ]; then
1561:182:  # Lone --override-reason (no skip/allow companion). The flag is still
1562:183:  # in forbidden_without_override so it MUST emit a canonical override.used
1563:184:  # event — otherwise the parser+contract drift detected by review-v2 A5
1564:185:  # remains: telemetry would never see the justification.
1565:186:  "${PYTHON_BIN:-python3}" .claude/scripts/vg-orchestrator override \
1566:187:    --flag "--override-reason" --reason "$OVR_REASON" || {
1567:188:      echo "⛔ vg-orchestrator override rejected --override-reason (reason too short / placeholder)."
1568:189:      exit 1
1569:190:    }
1570:191:fi
1571:192:```
