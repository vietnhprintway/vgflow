98:def find_phase_dir(phase: str, explicit: str | None = None) -> Path:
99:    if explicit:
100:        path = Path(explicit)
101:        if not path.exists():
102:            raise SystemExit(f"phase-dir not found: {path}")
103:        return path
104:
105:    root = Path(os.environ.get("VG_REPO_ROOT") or os.getcwd())
106:    phases_root = root / ".vg" / "phases"
107:    if not phases_root.is_dir():
108:        raise SystemExit(f"phase directory root not found: {phases_root}")
109:
110:    candidates = [p for p in phases_root.iterdir() if p.is_dir()]
111:    exact = [p for p in candidates if p.name == phase]
112:    if exact:
113:        return exact[0]
114:
115:    prefix = phase_pad(phase) if str(phase).isdigit() else str(phase)
116:    matches = [p for p in candidates if p.name == prefix or p.name.startswith(prefix + "-")]
117:    if len(matches) == 1:
118:        return matches[0]
119:    if not matches:
120:        raise SystemExit(f"phase not found: {phase}")
121:    raise SystemExit(f"phase is ambiguous: {phase}: {', '.join(p.name for p in matches)}")
