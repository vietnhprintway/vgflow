5527:202:def _parse_goal_block(text: str, source: Path) -> dict[str, Any] | None:
5528:203:    heading = re.search(r"^#\s+(G-[\w.-]+):?\s*(.+)$", text, re.MULTILINE)
5529:204:    if not heading:
5530:205:        heading = re.search(
5531:206:            r"^##\s+(?:Goal\s+)?(G-[\w.-]+):?\s*(.+)$",
5532:207:            text,
5533:208:            re.MULTILINE,
5534:209:        )
5535:210:    if not heading:
5536:211:        return None
5537:212:    goal_id = heading.group(1).strip()
5538:213:    title = heading.group(2).strip()
5539:214:    return {
5540:215:        "id": goal_id,
5541:216:        "title": title,
5542:217:        "body": text,
5543:218:        "goal_type": _field(text, "goal_type").lower(),
5544:219:        "goal_class": _field(text, "goal_class").lower(),
5545:220:        "surface": _field(text, "Surface").lower(),
5546:221:        "priority": _field(text, "Priority").lower(),
5547:222:        "success_criteria": _field(text, "Success criteria"),
5548:223:        "mutation_evidence": _field(text, "Mutation evidence"),
5549:224:        "persistence_check": _field(text, "Persistence check"),
5550:225:        "dependencies": _field(text, "Dependencies"),
5551:226:        "infra_deps": _field(text, "Infra deps"),
5552:227:        # G4: explicit actors metadata
5553:228:        "actors": _field(text, "actors") or _field(text, "actor"),
5554:229:        # G6: artifact_kind field
5555:230:        "artifact_kind": _field(text, "artifact_kind"),
5556:231:        "source": str(source),
5557:232:    }
