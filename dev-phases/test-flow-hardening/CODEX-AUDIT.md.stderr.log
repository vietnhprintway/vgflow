985:    candidates = [p for p in phases_dir.iterdir() if p.is_dir()]
986:    exact = [p for p in candidates if p.name == phase]
987:    if exact:
988:        return exact[0]
989:
990:    prefix = phase_pad(phase) if str(phase).isdigit() else str(phase)
991:    matches = [p for p in candidates if p.name == prefix or p.name.startswith(prefix + "-")]
992:    if len(matches) == 1:
993:        return matches[0]
994:    if not matches:
995:        raise SystemExit(f"phase not found: {phase}")
996:    raise SystemExit(f"phase is ambiguous: {phase}: {', '.join(p.name for p in matches)}")
