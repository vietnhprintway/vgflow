2052:197:    echo "⚠ codex-spawn fix-agent failed for ${ERR_ID:-$idx} (rc=${CODEX_FIX_RC}) — see CODEX-FIX-FAILURES.json + escalating to REVIEW-FEEDBACK.md" >&2
