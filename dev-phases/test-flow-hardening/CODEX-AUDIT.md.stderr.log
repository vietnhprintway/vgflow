6116:791:def _criteria_assertions(goal: dict[str, Any]) -> list[dict[str, str]]:
6117:792:    """Batch 36 R3: convert acceptance_criteria to assertion[] entries.
6118:793:
6119:794:    Each criterion becomes a structured assertion the spec body MUST verify
6120:795:    with expect(). Validator verify-spec-criteria-coverage.py (separate)
6121:796:    will cross-check spec body against this list.
6122:797:    """
6123:798:    out: list[dict[str, str]] = []
6124:799:    for i, crit in enumerate(_parse_acceptance_criteria(goal), 1):
6125:800:        out.append({
6126:801:            "source": f"acceptance_criteria[{i}]",
6127:802:            "check": crit,
6128:803:        })
6129:804:    return out
